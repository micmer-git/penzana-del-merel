---
interface Props {
  lang: 'it' | 'en';
  currentPath: string;
}
const { lang, currentPath } = Astro.props;
const base = '/penzana-del-merel';

const navIT = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/storia/`, label: 'Storia' },
  { href: `${base}/pizzometro/`, label: 'Pizzometro' },
  { href: `${base}/famiglia/`, label: 'Famiglia' },
  { href: `${base}/territorio/`, label: 'Territorio' },
  { href: `${base}/menu/`, label: 'Menu' },
  { href: `${base}/galleria/`, label: 'Galleria' },
  { href: `${base}/contatti/`, label: 'Contatti' },
];

const navEN = [
  { href: `${base}/en/`, label: 'Home' },
  { href: `${base}/en/history/`, label: 'History' },
  { href: `${base}/en/pizzameter/`, label: 'Pizzameter' },
  { href: `${base}/en/family/`, label: 'Family' },
  { href: `${base}/en/area/`, label: 'Area' },
  { href: `${base}/en/menu/`, label: 'Menu' },
  { href: `${base}/en/gallery/`, label: 'Gallery' },
  { href: `${base}/en/contact/`, label: 'Contact' },
];

const nav = lang === 'it' ? navIT : navEN;
const menuPath = lang === 'it' ? `${base}/menu/` : `${base}/en/menu/`;
const phoneLabel = lang === 'it' ? 'Chiama' : 'Call';
const bookLabel = lang === 'it' ? 'Menu / ordina' : 'Menu / order';
const navLabel = lang === 'it' ? 'Apri menu di navigazione' : 'Open navigation menu';
const navTitle = lang === 'it' ? 'Un posto che sa di sera buona, forno a legna e collina.' : 'A place that feels like a good evening, wood-fired oven and hillside air.';
const navKicker = lang === 'it' ? 'Orezzo · Valle Seriana' : 'Orezzo · Valle Seriana';
const navIntro = lang === 'it'
  ? 'Navigazione, contatti rapidi e scorciatoie per prenotare o ordinare dal tavolo.'
  : 'Navigation, quick contacts and shortcuts to book or order from your table.';

const itTarget = currentPath.replace(`${base}/en`, base).replace(/\/$/, '') + '/';
const enTarget = currentPath.startsWith(`${base}/en`)
  ? currentPath
  : currentPath === `${base}/` || currentPath === `${base}`
    ? `${base}/en/`
    : currentPath.replace(base, `${base}/en`).replace(/\/\/$/, '/');
---

<header class="site-header" role="banner">
  <div class="container">
    <div class="inner">
      <div class="site-brand">
        <a href={lang === 'it' ? `${base}/` : `${base}/en/`} class="site-logo" aria-label="La Penzana del Merel — Home">
          La Penzana
          <span>del Merel</span>
        </a>
        <p class="site-logo-meta">{lang === 'it' ? 'Orezzo · dal 1959' : 'Orezzo · since 1959'}</p>
      </div>

      <div class="header-actions">
        <a href={menuPath} class="header-cta">{bookLabel}</a>
        <a
          href="https://www.instagram.com/lapenzanadelmerel/?hl=en"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-social"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" ry="5" stroke-width="1.8"></rect>
            <circle cx="12" cy="12" r="4" stroke-width="1.8"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-controls="main-nav" aria-expanded="false" aria-label={navLabel}>
          <span class="nav-toggle-label">Menu</span>
          <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" style="display:none;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="nav-overlay" id="nav-overlay"></div>

      <nav class="main-nav" id="main-nav" role="navigation" aria-label={lang === 'it' ? 'Navigazione principale' : 'Main navigation'}>
        <div class="nav-panel">
          <div class="nav-panel-top">
            <span class="nav-kicker">{navKicker}</span>
            <p class="nav-blurb">{navTitle}</p>
            <p class="nav-blurb">{navIntro}</p>
          </div>

          <div class="nav-links">
            {nav.map((link) => (
              <a
                href={link.href}
                aria-current={currentPath === link.href || currentPath === link.href.replace(/\/$/, '') ? 'page' : undefined}
              >{link.label}</a>
            ))}
          </div>

          <div class="nav-panel-footer">
            <a class="nav-meta-link" href="tel:+39035712021">{phoneLabel} · 035 712021</a>
            <a class="nav-meta-link" href={menuPath}>{bookLabel}</a>
            <span class="nav-lang">
              <a href={itTarget} class={lang === 'it' ? 'active' : ''} aria-label="Italiano" hreflang="it">IT</a>
              <a href={enTarget} class={lang === 'en' ? 'active' : ''} aria-label="English" hreflang="en">EN</a>
            </span>
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const nav = document.getElementById('main-nav') as HTMLElement;
  const overlay = document.getElementById('nav-overlay') as HTMLElement;
  const iconMenu = toggle?.querySelector('.icon-menu') as HTMLElement;
  const iconClose = toggle?.querySelector('.icon-close') as HTMLElement;

  function openNav() {
    nav.classList.add('open');
    overlay.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.classList.add('scroll-locked');
    if (iconMenu) iconMenu.style.display = 'none';
    if (iconClose) iconClose.style.display = 'block';
  }

  function closeNav() {
    nav.classList.remove('open');
    overlay.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('scroll-locked');
    if (iconMenu) iconMenu.style.display = 'block';
    if (iconClose) iconClose.style.display = 'none';
  }

  if (toggle && nav && overlay) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.contains('open');
      isOpen ? closeNav() : openNav();
    });

    overlay.addEventListener('click', closeNav);

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeNav);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('open')) {
        closeNav();
        toggle.focus();
      }
    });
  }
</script>
