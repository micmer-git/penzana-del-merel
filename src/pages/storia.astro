---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';

const chapters = [
  {
    year: '1936',
    title: "L'edificio",
    paragraphs: [
      "L'edificio viene acquisito nel 1936 da Alessandro Merelli. Per anni resta un presidio del borgo di Orezzo, un luogo concreto prima ancora che simbolico.",
      "Quel punto fermo diventerà la base di tutto il resto: famiglia, ospitalità, lavoro fatto con pazienza.",
    ],
    image: {
      src: `${base}/img/trattoria_alpina_historical_photo.png`,
      alt: "Foto storica della Trattoria Alpina a Orezzo",
      caption: "Orezzo — Trattoria Alpina, l'edificio originale",
    },
  },
  {
    year: '31 dicembre 1959',
    title: 'Nasce la locanda',
    paragraphs: [
      "È l'ultimo giorno dell'anno quando Tarcisio, figlio di Alessandro, inaugura la locanda con il nome di Trattoria Cima Verde.",
      "Sin da subito il locale si distingue per la sua genuinità: un posto dove fermarsi, bere un rosso al banco, giocare a bocce e passare il tempo sotto l'ippocastano secolare.",
    ],
    quote: "Calici di rosso al banco, partite di bocce, l'ombra del secolare ippocastano. Qui il tempo poteva ancora rallentare.",
  },
  {
    year: '1989',
    title: 'La passione per il forno',
    paragraphs: [
      "Tarcisio si appassiona alla costruzione di forni alimentari e porta questa cura dentro ogni gesto del lavoro quotidiano.",
      "Nel 1989 arriva fino a Napoli come finalista pizzaiolo al Centenario della pizza Margherita: un traguardo raro per un artigiano bergamasco.",
    ],
  },
  {
    year: "Anni '90",
    title: 'La Penzana del Merel',
    paragraphs: [
      "Con Efrem e Laura Merla, la trattoria si trasforma in pizzeria. Il nome scelto richiama le piccole costruzioni in lamiera dove si riponevano rastei e furchine.",
      "È un nome che sa di terra, di mani che lavorano, di identità bergamasca tenuta stretta senza nostalgia finta.",
    ],
    quote: "La Penzana del Merel: un nome che odora di terra, lamiere vissute e vera bergamasca.",
    image: {
      src: `${base}/img/general_pizza_overview.png`,
      alt: 'Pizze appena sfornate dal forno a legna',
      caption: 'Le pizze della Penzana — curate in ogni dettaglio',
    },
  },
  {
    year: 'Oggi',
    title: 'Terza generazione',
    paragraphs: [
      "Credendo che il presente sia ciò che domani diventerà storia, la famiglia continua il racconto senza perdere il carattere costruito negli anni.",
      "Cambiare resta importante, ma solo se serve a riconoscersi ancora e a restare vicini alle persone che scelgono questo posto.",
    ],
    quote: "VOGLIAMO CAMBIARE PER RIMANERE NOI STESSI, RIMANERE CON VOI.",
  },
];
---

<BaseLayout
  title="La nostra storia — La Penzana del Merel"
  description="La storia della Penzana del Merel: dalla Trattoria Cima Verde del 1959 alla pizzeria di famiglia di oggi. Radici bergamasche e tre generazioni."
  lang="it"
  pageType="website"
  currentPath={`${base}/storia/`}
>
  <section class="story-hero">
    <div class="container story-hero__inner">
      <span class="story-hero__kicker">Storia</span>
      <h1>Un filo che parte da Orezzo</h1>
      <p>
        Dalla Trattoria Cima Verde alla pizzeria di famiglia: una storia fatta di forno, collina,
        lavoro vero e generazioni che si passano il mestiere senza perderne l’anima.
      </p>
    </div>
  </section>

  <section class="story-thread" aria-label="Cronologia della Penzana">
    <div class="story-thread__inner">
      <div class="story-thread__rail" aria-hidden="true"></div>

      {chapters.map((chapter, index) => {
        const side = index % 2 === 0 ? 'left' : 'right';
        return (
          <article class={`story-event story-event--${side} reveal`}>
            <div class="story-event__dot" aria-hidden="true"></div>
            <div class="story-event__card">
              <span class="story-event__year">{chapter.year}</span>
              <h2>{chapter.title}</h2>
              {chapter.image && (
                <figure class="story-event__figure">
                  <img src={chapter.image.src} alt={chapter.image.alt} loading="lazy" />
                  <figcaption>{chapter.image.caption}</figcaption>
                </figure>
              )}
              {chapter.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
              {chapter.quote && (
                <blockquote class="pullquote">{chapter.quote}</blockquote>
              )}
            </div>
          </article>
        );
      })}

      <div class="story-cta reveal">
        <p>La storia continua a tavola, una sera alla volta.</p>
        <div class="story-cta__actions">
          <a href={`${base}/famiglia/`} class="btn btn-green">La famiglia oggi</a>
          <a href={`${base}/menu/`} class="btn btn-outline story-cta__outline">Scopri il menù</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .story-hero {
      padding: clamp(5rem, 10vw, 7rem) 0 clamp(2rem, 5vw, 3rem);
      background:
        radial-gradient(circle at top, rgba(242, 123, 167, 0.16), transparent 46%),
        var(--bg);
    }

    .story-hero__inner {
      max-width: 760px;
      text-align: center;
    }

    .story-hero__kicker {
      display: inline-block;
      margin-bottom: 1rem;
      font-family: var(--font-subline);
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--blue-mid);
    }

    .story-hero h1 {
      margin-bottom: 1rem;
    }

    .story-hero p {
      color: var(--text-muted);
      max-width: 62ch;
      margin: 0 auto;
    }

    .story-thread {
      padding: 0 0 clamp(5rem, 10vw, 7rem);
      background: var(--bg);
    }

    .story-thread__inner {
      position: relative;
      max-width: min(1200px, calc(100vw - 2rem));
      margin: 0 auto;
      padding: 1rem clamp(1rem, 4vw, 3rem) 0;
    }

    .story-thread__rail {
      position: absolute;
      top: 0;
      bottom: 12rem;
      left: 50%;
      width: 4px;
      transform: translateX(-50%);
      background: linear-gradient(180deg, rgba(242, 123, 167, 0.2), rgba(194, 24, 79, 0.45));
    }

    .story-event {
      position: relative;
      width: calc(50% - 3rem);
      margin-top: clamp(2rem, 5vw, 4rem);
    }

    .story-event--left {
      margin-right: auto;
    }

    .story-event--right {
      margin-left: auto;
    }

    .story-event__dot {
      position: absolute;
      top: 1.2rem;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: var(--blue-mid);
      box-shadow: 0 0 0 8px rgba(255, 240, 243, 0.96);
    }

    .story-event--left .story-event__dot {
      right: -3.55rem;
    }

    .story-event--right .story-event__dot {
      left: -3.55rem;
    }

    .story-event__card {
      padding: clamp(1.2rem, 2.5vw, 1.8rem);
      background: rgba(255, 255, 255, 0.92);
      border: 2px solid rgba(194, 24, 79, 0.15);
      box-shadow: 8px 8px 0 rgba(242, 123, 167, 0.16);
    }

    .story-event__year {
      display: inline-block;
      margin-bottom: 0.65rem;
      font-family: var(--font-subline);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--blue-mid);
    }

    .story-event h2 {
      margin-bottom: 0.85rem;
      font-size: clamp(1.45rem, 3vw, 2.1rem);
    }

    .story-event__figure {
      margin: 0 0 1.1rem;
    }

    .story-event__figure img {
      width: 100%;
      border-radius: 10px;
      box-shadow: var(--shadow-sm);
    }

    .story-event__figure figcaption {
      margin-top: 0.5rem;
      font-size: 0.82rem;
      color: var(--text-muted);
      font-style: italic;
    }

    .story-cta {
      position: relative;
      max-width: 680px;
      margin: clamp(3rem, 8vw, 5rem) auto 0;
      padding: 1.5rem;
      text-align: center;
      border: 2px solid rgba(194, 24, 79, 0.18);
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 8px 8px 0 rgba(242, 123, 167, 0.16);
    }

    .story-cta p {
      font-family: var(--font-display);
      font-size: 1.35rem;
      color: var(--blue-deep);
      margin-bottom: 1rem;
    }

    .story-cta__actions {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .story-cta__outline {
      color: var(--blue-deep);
      border-color: rgba(194, 24, 79, 0.2);
      box-shadow: 4px 4px 0 rgba(194, 24, 79, 0.18);
    }

    .story-cta__outline:hover {
      color: var(--blue-deep);
      background: rgba(242, 123, 167, 0.12);
    }

    @media (max-width: 820px) {
      .story-thread__rail {
        left: 1.4rem;
        transform: none;
      }

      .story-event,
      .story-event--left,
      .story-event--right {
        width: calc(100% - 3.5rem);
        margin-left: auto;
      }

      .story-event__dot,
      .story-event--left .story-event__dot,
      .story-event--right .story-event__dot {
        left: -2.55rem;
        right: auto;
      }
    }
  </style>

</BaseLayout>
