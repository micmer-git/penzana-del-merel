---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';

const chapters = [
  {
    year: '1936',
    title: 'The Building',
    paragraphs: [
      "The building was acquired in 1936 by Alessandro Merelli. For years it remained a landmark of the hamlet of Orezzo, a concrete place before it was ever a symbol.",
      "That fixed point would become the foundation of everything else: family, hospitality, work done with patience.",
    ],
    image: {
      src: `${base}/img/trattoria_alpina_historical_photo.png`,
      alt: "Historical photo of Trattoria Alpina in Orezzo",
      caption: "Orezzo — Trattoria Alpina, the original building",
    },
  },
  {
    year: '31 December 1959',
    title: 'The Inn Opens',
    paragraphs: [
      "It is the last day of the year when Tarcisio, Alessandro's son, opens the inn under the name Trattoria Cima Verde.",
      "From the very start the place stands out for its genuine character: somewhere to stop, drink a glass of red at the counter, play bowls, and spend time under the shade of the century-old chestnut tree.",
    ],
    quote: "Glasses of red at the counter, bowls on the lawn, the shade of the old chestnut. Here time could still slow down.",
  },
  {
    year: '1968',
    title: 'The Ski Club Orezzo',
    paragraphs: [
      "Tarcisio does not stop at the kitchen. In 1968 he founds the Sci Club Orezzo, bringing a passion for the mountains and sport to the heart of the hamlet.",
      "What starts as a group of enthusiasts becomes a reference point for the whole valley. In 1983, Efrem Merelli wins the Italian Ski Championship: a result that speaks of the same determination that keeps the oven burning every evening.",
    ],
    quote: "From the snow to the oven: the same discipline, the same mountain, the same family.",
    image: {
      src: `${base}/img/50_anni_orezzo_tarcisio.jpg`,
      alt: 'Tarcisio Merelli — 50 years of Sci Club Orezzo',
      caption: 'Tarcisio and Sci Club Orezzo — 50 years of passion',
    },
    link: { href: 'https://www.scicluborezzo.com/', label: 'Sci Club Orezzo →' },
  },
  {
    year: '1989',
    title: 'A Passion for the Oven',
    paragraphs: [
      "Tarcisio develops a passion for building bread ovens and brings that care into every gesture of his daily work.",
      "In 1989 he reaches Naples as a finalist at the Centenary of the Margherita pizza: a rare achievement for a craftsman from Bergamo.",
    ],
  },
  {
    year: "1990s",
    title: 'La Penzana del Merel',
    paragraphs: [
      "With Efrem and Laura Merla, the inn transforms into a pizzeria. The chosen name evokes the small tin-roofed shelters where farmers used to store their rakes and pitchforks.",
      "It is a name that smells of soil, of hands that work, of Bergamo identity held tight without false nostalgia.",
    ],
    quote: "La Penzana del Merel: a name that smells of soil, weathered tin, and authentic Bergamo.",
    image: {
      src: `${base}/img/general_pizza_overview.png`,
      alt: 'Freshly baked pizzas from the wood-fired oven',
      caption: 'Penzana pizzas — crafted with care in every detail',
    },
  },
  {
    year: 'Today',
    title: 'Third Generation',
    paragraphs: [
      "Believing that the present is what tomorrow will call history, the family continues the story without losing the character built over the years.",
      "Change remains important, but only if it helps us recognise ourselves and stay close to the people who choose this place.",
    ],
    quote: "WE WANT TO CHANGE IN ORDER TO REMAIN OURSELVES, TO REMAIN WITH YOU.",
  },
];
---

<BaseLayout
  title="Our Story — La Penzana del Merel"
  description="The history of La Penzana del Merel: from the Trattoria Cima Verde in 1959 to today's family pizzeria. Bergamo roots and three generations."
  lang="en"
  pageType="website"
  currentPath={`${base}/en/history/`}
>
  <section class="story-hero">
    <div class="container story-hero__inner">
      <span class="story-hero__kicker">History</span>
      <h1>A thread that starts in Orezzo</h1>
      <p>
        From the Trattoria Cima Verde to today's family pizzeria: a story made of oven, hillside,
        honest work, and generations passing on the craft without losing its soul.
      </p>
    </div>
  </section>

  <section class="story-thread" aria-label="Penzana timeline">
    <div class="story-thread__inner">
      <div class="story-thread__rail" aria-hidden="true"></div>

      {chapters.map((chapter, index) => {
        const side = index % 2 === 0 ? 'left' : 'right';
        return (
          <article class={`story-event story-event--${side} reveal`}>
            <div class="story-event__dot" aria-hidden="true"></div>
            <div class="story-event__card">
              <span class="story-event__year">{chapter.year}</span>
              <h2>{chapter.title}</h2>
              {chapter.image && (
                <figure class="story-event__figure">
                  <img src={chapter.image.src} alt={chapter.image.alt} loading="lazy" />
                  <figcaption>{chapter.image.caption}</figcaption>
                </figure>
              )}
              {chapter.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
              {chapter.quote && (
                <blockquote class="pullquote">{chapter.quote}</blockquote>
              )}
              {chapter.link && (
                <a href={chapter.link.href} target="_blank" rel="noopener noreferrer" class="story-event__link">{chapter.link.label}</a>
              )}
            </div>
          </article>
        );
      })}

      <div class="story-cta reveal">
        <p>The story continues at the table, one evening at a time.</p>
        <div class="story-cta__actions">
          <a href={`${base}/en/family/`} class="btn btn-green">The family today</a>
          <a href={`${base}/en/menu/`} class="btn btn-outline story-cta__outline">See the menu</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .story-hero {
      padding: clamp(5rem, 10vw, 7rem) 0 clamp(2rem, 5vw, 3rem);
      background:
        radial-gradient(circle at top, rgba(242, 123, 167, 0.16), transparent 46%),
        var(--bg);
    }

    .story-hero__inner {
      max-width: 760px;
      text-align: center;
    }

    .story-hero__kicker {
      display: inline-block;
      margin-bottom: 1rem;
      font-family: var(--font-subline);
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--blue-mid);
    }

    .story-hero h1 {
      margin-bottom: 1rem;
    }

    .story-hero p {
      color: var(--text-muted);
      max-width: 62ch;
      margin: 0 auto;
    }

    .story-thread {
      padding: 0 0 clamp(5rem, 10vw, 7rem);
      background: var(--bg);
    }

    .story-thread__inner {
      position: relative;
      max-width: min(1200px, calc(100vw - 2rem));
      margin: 0 auto;
      padding: 1rem clamp(1rem, 4vw, 3rem) 0;
    }

    .story-thread__rail {
      position: absolute;
      top: 0;
      bottom: 12rem;
      left: 50%;
      width: 4px;
      transform: translateX(-50%);
      background: linear-gradient(180deg, rgba(242, 123, 167, 0.2), rgba(194, 24, 79, 0.45));
    }

    .story-event {
      position: relative;
      width: calc(50% - 3rem);
      margin-top: clamp(2rem, 5vw, 4rem);
    }

    .story-event--left {
      margin-right: auto;
    }

    .story-event--right {
      margin-left: auto;
    }

    .story-event__dot {
      position: absolute;
      top: 1.2rem;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: var(--blue-mid);
      box-shadow: 0 0 0 8px rgba(255, 240, 243, 0.96);
    }

    .story-event--left .story-event__dot {
      right: -3.55rem;
    }

    .story-event--right .story-event__dot {
      left: -3.55rem;
    }

    .story-event__card {
      padding: clamp(1.2rem, 2.5vw, 1.8rem);
      background: rgba(255, 255, 255, 0.92);
      border: 2px solid rgba(194, 24, 79, 0.15);
      box-shadow: 8px 8px 0 rgba(242, 123, 167, 0.16);
    }

    .story-event__year {
      display: inline-block;
      margin-bottom: 0.65rem;
      font-family: var(--font-subline);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--blue-mid);
    }

    .story-event h2 {
      margin-bottom: 0.85rem;
      font-size: clamp(1.45rem, 3vw, 2.1rem);
    }

    .story-event__figure {
      margin: 0 0 1.1rem;
    }

    .story-event__figure img {
      width: 100%;
      border-radius: 10px;
      box-shadow: var(--shadow-sm);
    }

    .story-event__figure figcaption {
      margin-top: 0.5rem;
      font-size: 0.82rem;
      color: var(--text-muted);
      font-style: italic;
    }

    .story-event__link {
      display: inline-block;
      margin-top: 0.5rem;
      font-family: var(--font-subline);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--blue-mid);
      border-bottom: 2px solid var(--accent-gold);
      padding-bottom: 0.15rem;
      transition: color var(--transition), border-color var(--transition);
    }
    .story-event__link:hover { color: var(--blue-deep); border-color: var(--blue-mid); }

    .story-cta {
      position: relative;
      max-width: 680px;
      margin: clamp(3rem, 8vw, 5rem) auto 0;
      padding: 1.5rem;
      text-align: center;
      border: 2px solid rgba(194, 24, 79, 0.18);
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 8px 8px 0 rgba(242, 123, 167, 0.16);
    }

    .story-cta p {
      font-family: var(--font-display);
      font-size: 1.35rem;
      color: var(--blue-deep);
      margin-bottom: 1rem;
    }

    .story-cta__actions {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .story-cta__outline {
      color: var(--blue-deep);
      border-color: rgba(194, 24, 79, 0.2);
      box-shadow: 4px 4px 0 rgba(194, 24, 79, 0.18);
    }

    .story-cta__outline:hover {
      color: var(--blue-deep);
      background: rgba(242, 123, 167, 0.12);
    }

    @media (max-width: 820px) {
      .story-thread__rail {
        left: 1.4rem;
        transform: none;
      }

      .story-event,
      .story-event--left,
      .story-event--right {
        width: calc(100% - 3.5rem);
        margin-left: auto;
      }

      .story-event__dot,
      .story-event--left .story-event__dot,
      .story-event--right .story-event__dot {
        left: -2.55rem;
        right: auto;
      }
    }
  </style>

</BaseLayout>
