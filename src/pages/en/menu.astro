---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MENU, SECTIONS, COPERTO, SECTION_QUOTES } from '../../data/menu.js';
import { WHATSAPP_NUMBER } from '../../data/site.js';
const base = '/penzana-del-merel';
const waNumber = WHATSAPP_NUMBER;

const menuDataJSON = JSON.stringify(
  SECTIONS.map(s => ({
    id: s.id,
    categories: s.categories.map(c => ({
      id: c.id,
      items: c.items.map(i => ({
        id: i.id,
        name: i.nameEN,
        price: i.price,
        desc: i.descEN || '',
        ingredients: (i.descEN || '').split(/,\s*| & /).map((x: string) => x.trim()).filter(Boolean),
      })),
    })),
  }))
);
---

<BaseLayout
  title="Menu 2026 — La Penzana del Merel"
  description="Full menu of La Penzana del Merel: pizzas, Bergamo cuisine, desserts and wine list. Order directly from your table via WhatsApp."
  lang="en"
  currentPath={`${base}/en/menu/`}
>

  <div id="table-banner" class="table-banner-new">
    <div class="container" style="display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap;">
      <div id="banner-text" style="font-size:0.9rem;">
        <span id="banner-no-table">Select your table to order via WhatsApp</span>
        <span id="banner-has-table" style="display:none;">Ordering from <strong id="table-name-display"></strong></span>
      </div>
      <div style="display:flex; gap:0.5rem; align-items:center;">
        <select id="table-select" style="padding:0.4rem 0.6rem; border-radius:var(--radius); border:2px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.15); color:white; font-size:0.85rem; font-weight:700; cursor:pointer;">
          <option value="" style="color:#333;">Table...</option>
          {Array.from({length: 20}, (_, i) => {
            const id = `table-${String(i+1).padStart(2,'0')}`;
            return <option value={id} style="color:#333;">Table {String(i+1).padStart(2,'0')}</option>;
          })}
        </select>
      </div>
    </div>
  </div>

  <section class="hero" style="padding-block:clamp(2rem,5vw,3rem);">
    <div class="container">
      <span class="hero-eyebrow">Menu 2026</span>
      <h1>Our Menu</h1>
      <p style="margin-bottom:0.5rem;">Wood-fired pizzas, Bergamo cuisine, wine list.</p>
    </div>
  </section>

  <div style="background:var(--bg-warm); padding:0.5rem 1rem; text-align:center; font-size:0.83rem; color:var(--text-muted); border-bottom:1px solid var(--stone-xlight);">
    Cover charge: &euro;{COPERTO.toFixed(2)} per person
  </div>

  <div class="menu-tabs-wrapper" style="background:var(--white); border-bottom:1px solid var(--stone-xlight); position:sticky; top:56px; z-index:50;">
    <div class="container">
      <div class="menu-tabs" role="tablist" aria-label="Menu sections">
        {SECTIONS.map((section, i) => (
          <button
            role="tab"
            class={`menu-tab ${i === 0 ? 'active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${section.id}`}
            data-section={section.id}
          >
            {section.labelEN}
          </button>
        ))}
      </div>
    </div>
  </div>

  <section class="section" style="padding-top:1.5rem; padding-bottom:6rem;">
    <div class="container" style="max-width:800px;">

      {SECTIONS.map((section, si) => (
        <div
          id={`panel-${section.id}`}
          role="tabpanel"
          class="menu-panel"
          style={si === 0 ? '' : 'display:none;'}
          data-section={section.id}
        >
          {SECTION_QUOTES[section.id] && (
            <blockquote class="pullquote" style="margin-bottom:2rem; font-size:0.95rem;">
              "{SECTION_QUOTES[section.id].text}"
              <span style="display:block; font-size:0.75rem; font-style:normal; color:var(--stone); margin-top:0.25rem;">— {SECTION_QUOTES[section.id].author}</span>
            </blockquote>
          )}

          {section.categories.map(category => (
            <div class="menu-section" id={`cat-${category.id}`}>
              <h2 class="menu-section-title">
                {category.labelEN}
                <span class="label-en">/ {category.labelIT}</span>
              </h2>
              {category.subtitleEN && (
                <p style="font-size:0.8rem; color:var(--text-muted); margin-top:-0.75rem; margin-bottom:1rem; font-style:italic;">{category.subtitleEN}</p>
              )}
              {category.items.map(item => (
                <div class="menu-card" data-item-id={item.id} data-item-name={item.nameEN} data-item-price={item.price} data-item-desc={item.descEN || ''}>
                  <div class="menu-card-main">
                    <div class="menu-card-info">
                      <div class="menu-card-name">{item.nameEN}</div>
                      {(item.descEN || '') !== '' && (
                        <div class="menu-card-desc">{item.descEN}</div>
                      )}
                    </div>
                    <div class="menu-card-right">
                      <div class="menu-card-price">
                        {item.priceRange ? '\u20AC' + item.priceRange.replace(/,/g, '.') : '\u20AC' + item.price.toFixed(2)}
                      </div>
                      <button class="add-btn" aria-label={`Add ${item.nameEN}`} data-id={item.id}>
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>
                  <div class="menu-card-expand" style="display:none;">
                    <div class="ingredient-chips"></div>
                    <div style="margin-top:0.5rem; display:flex; gap:0.5rem; align-items:center;">
                      <input type="text" class="add-ingredient-input" placeholder="+ add ingredient..." style="flex:1; padding:0.35rem 0.6rem; border:1px solid var(--stone-xlight); border-radius:var(--radius); font-size:0.8rem; background:var(--white);" />
                    </div>
                    <div style="margin-top:0.5rem;">
                      <input type="text" class="item-note-input" placeholder="Notes (e.g. well done, no lactose...)" style="width:100%; padding:0.35rem 0.6rem; border:1px solid var(--stone-xlight); border-radius:var(--radius); font-size:0.8rem; background:var(--white);" />
                    </div>
                    <div style="margin-top:0.6rem; display:flex; align-items:center; justify-content:space-between;">
                      <div class="qty-row">
                        <button class="qty-btn-new qty-dec" data-id={item.id} aria-label="Remove">&#8722;</button>
                        <span class="qty-val" data-id={item.id}>1</span>
                        <button class="qty-btn-new qty-inc" data-id={item.id} aria-label="Add">+</button>
                      </div>
                      <button class="confirm-add-btn" data-id={item.id}>Add to order</button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      ))}

      <div style="margin-top:2rem; padding:1rem; background:var(--bg-warm); border-radius:var(--radius); font-size:0.8rem; color:var(--text-muted);">
        <strong>Note:</strong> Prices may vary seasonally. Please inform staff of any allergies.
      </div>
    </div>
  </section>

  <div id="cart-fab" class="cart-fab" style="display:none;">
    <button id="cart-fab-btn" class="cart-fab-btn" aria-label="Open cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span id="cart-fab-count" class="cart-fab-count">0</span>
    </button>
  </div>

  <div id="cart-overlay" class="cart-overlay" style="display:none;"></div>
  <div id="cart-drawer" class="cart-drawer" aria-label="Cart">
    <div class="cart-drawer-header">
      <h3>Your Order</h3>
      <button id="cart-close" class="cart-close" aria-label="Close cart">&times;</button>
    </div>
    <div id="cart-items" class="cart-items">
      <div class="cart-empty">No items in your order</div>
    </div>
    <div class="cart-footer">
      <div style="margin-bottom:0.5rem;">
        <label for="order-notes-global" style="font-size:0.75rem; color:var(--text-muted); display:block; margin-bottom:0.2rem;">General notes:</label>
        <textarea id="order-notes-global" rows="2" placeholder="Allergies, special requests..." style="width:100%; padding:0.4rem 0.6rem; border:1px solid var(--stone-xlight); border-radius:var(--radius); font-size:0.8rem; resize:none;"></textarea>
      </div>
      <div class="cart-total">
        <span>Total</span>
        <strong id="cart-total-price">&euro;0.00</strong>
      </div>
      <button id="cart-send-btn" class="btn btn-wa" style="width:100%; justify-content:center;" disabled>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Send order via WhatsApp
      </button>
    </div>
  </div>

</BaseLayout>

<style>
.menu-card{background:var(--white);border-radius:var(--radius-lg);padding:.85rem 1rem;margin-bottom:.5rem;box-shadow:0 1px 3px rgba(30,26,22,.06);transition:box-shadow .2s,transform .2s;border-left:3px solid transparent}.menu-card:hover{box-shadow:var(--shadow-sm)}.menu-card.in-cart{border-left-color:#25d366;background:#f0fdf4}.menu-card-main{display:flex;align-items:flex-start;gap:.75rem;cursor:pointer}.menu-card-info{flex:1;min-width:0}.menu-card-name{font-weight:700;font-size:.95rem;color:var(--text)}.menu-card-desc{font-size:.78rem;color:var(--text-muted);line-height:1.35;margin-top:.15rem}.menu-card-right{display:flex;flex-direction:column;align-items:flex-end;gap:.4rem;flex-shrink:0}.menu-card-price{font-family:var(--font-display);font-weight:700;font-size:1rem;color:var(--green-deep);white-space:nowrap}.add-btn{width:36px;height:36px;border-radius:50%;border:none;background:var(--green-mid);color:white;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s,transform .15s;min-width:44px;min-height:44px}.add-btn:hover{background:var(--green-deep);transform:scale(1.08)}.add-btn:active{transform:scale(.95)}.menu-card-expand{margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--stone-xlight)}.ingredient-chips{display:flex;flex-wrap:wrap;gap:.35rem}.ing-chip{display:inline-flex;align-items:center;gap:.25rem;padding:.25rem .6rem;border-radius:999px;font-size:.75rem;font-weight:600;cursor:pointer;transition:all .15s;border:1.5px solid var(--stone-xlight);background:var(--bg-warm);color:var(--text);user-select:none;min-height:32px}.ing-chip.removed{background:#fef2f2;border-color:#fca5a5;color:#dc2626;text-decoration:line-through}.ing-chip.added{background:#f0fdf4;border-color:#86efac;color:#16a34a}.ing-chip .chip-x{font-size:.9rem;line-height:1;margin-left:.1rem}.qty-row{display:flex;align-items:center;gap:.5rem}.qty-btn-new{width:34px;height:34px;border-radius:50%;border:2px solid var(--stone-xlight);background:var(--white);color:var(--text);font-size:1.1rem;font-weight:700;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;min-width:44px;min-height:44px}.qty-btn-new:hover{border-color:var(--green-mid);color:var(--green-mid)}.qty-val{font-weight:700;font-size:1.05rem;min-width:24px;text-align:center}.confirm-add-btn{padding:.5rem 1rem;border-radius:var(--radius);border:none;background:var(--green-mid);color:white;font-weight:700;font-size:.85rem;cursor:pointer;transition:background .15s;min-height:44px}.confirm-add-btn:hover{background:var(--green-deep)}.table-banner-new{background:var(--green-deep);color:white;padding:.6rem 0}.table-banner-new select option{color:#333}.cart-fab{position:fixed;bottom:1.5rem;right:1.5rem;z-index:80}.cart-fab-btn{width:60px;height:60px;border-radius:50%;border:none;background:#25d366;color:white;box-shadow:0 4px 20px rgba(37,211,102,.4);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform .2s,box-shadow .2s;position:relative}.cart-fab-btn:hover{transform:scale(1.08);box-shadow:0 6px 28px rgba(37,211,102,.5)}.cart-fab-btn:active{transform:scale(.95)}.cart-fab-count{position:absolute;top:-4px;right:-4px;background:var(--accent-gold);color:var(--text);font-size:.7rem;font-weight:800;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center}.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;opacity:0;transition:opacity .3s}.cart-overlay.open{opacity:1}.cart-drawer{position:fixed;bottom:0;left:0;right:0;z-index:310;background:var(--white);border-radius:20px 20px 0 0;box-shadow:0 -4px 30px rgba(0,0,0,.15);max-height:85vh;display:flex;flex-direction:column;transform:translateY(100%);transition:transform .35s cubic-bezier(.32,.72,.37,1.02)}.cart-drawer.open{transform:translateY(0)}.cart-drawer-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem .5rem;border-bottom:1px solid var(--stone-xlight)}.cart-drawer-header h3{margin:0;font-size:1.1rem}.cart-close{width:36px;height:36px;border:none;background:var(--bg-warm);border-radius:50%;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);min-width:44px;min-height:44px}.cart-items{flex:1;overflow-y:auto;padding:.75rem 1.25rem;-webkit-overflow-scrolling:touch}.cart-empty{text-align:center;color:var(--stone);padding:2rem 0;font-size:.9rem}.cart-item{display:flex;gap:.75rem;padding:.75rem 0;border-bottom:1px solid var(--stone-xlight);align-items:flex-start}.cart-item:last-child{border-bottom:none}.cart-item-info{flex:1;min-width:0}.cart-item-name{font-weight:700;font-size:.9rem}.cart-item-mods{font-size:.75rem;color:var(--text-muted);margin-top:.15rem}.cart-item-mods .mod-remove{color:#dc2626}.cart-item-mods .mod-add{color:#16a34a}.cart-item-note{font-size:.72rem;color:var(--accent-violet);font-style:italic;margin-top:.1rem}.cart-item-actions{display:flex;flex-direction:column;align-items:flex-end;gap:.3rem}.cart-item-price{font-weight:700;font-size:.9rem;color:var(--green-deep);white-space:nowrap}.cart-item-qty{display:flex;align-items:center;gap:.3rem}.cart-item-qty button{width:28px;height:28px;border-radius:50%;border:1.5px solid var(--stone-xlight);background:var(--white);font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;min-width:36px;min-height:36px;transition:border-color .15s}.cart-item-qty button:hover{border-color:var(--green-mid)}.cart-item-qty button.cart-remove-btn{border-color:#fca5a5;color:#dc2626}.cart-item-qty button.cart-remove-btn:hover{background:#fef2f2}.cart-item-qty span{font-weight:700;min-width:18px;text-align:center;font-size:.85rem}.cart-footer{padding:.75rem 1.25rem 1rem;border-top:1px solid var(--stone-xlight);background:var(--bg-warm)}.cart-total{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;font-size:1rem}@media(min-width:600px){.cart-drawer{max-width:440px;left:auto}}
</style>

<script define:vars={{ waNumber, menuDataJSON }}>
  window.__WA_NUMBER = waNumber;
  window.__MENU_DATA = menuDataJSON;
</script>

<script>
const WHATSAPP_NUMBER = (window as any).__WA_NUMBER || '393487024985';
const MENU_DATA: Array<{id:string, categories:Array<{id:string, items:Array<{id:string, name:string, price:number, desc:string, ingredients:string[]}>}>}> = JSON.parse((window as any).__MENU_DATA || '[]');
const itemLookup = new Map<string, {name:string, price:number, ingredients:string[]}>();
MENU_DATA.forEach(s => s.categories.forEach(c => c.items.forEach(i => itemLookup.set(i.id, i))));

interface CartEntry { id:string; name:string; price:number; qty:number; removed:string[]; added:string[]; note:string; }
let cart: CartEntry[] = [];
let tableId: string | null = new URLSearchParams(window.location.search).get('table');

document.querySelectorAll('.menu-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const section = (tab as HTMLElement).dataset.section!;
    document.querySelectorAll('.menu-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
    document.querySelectorAll('.menu-panel').forEach(p => { (p as HTMLElement).style.display = (p as HTMLElement).dataset.section === section ? '' : 'none'; });
  });
});

const tableSelect = document.getElementById('table-select') as HTMLSelectElement;
const bannerNoTable = document.getElementById('banner-no-table')!;
const bannerHasTable = document.getElementById('banner-has-table')!;
const tableNameDisplay = document.getElementById('table-name-display')!;

function setTable(id: string | null) {
  tableId = id;
  if (id) {
    bannerNoTable.style.display = 'none'; bannerHasTable.style.display = '';
    tableNameDisplay.textContent = 'Table ' + id.replace('table-', '');
    tableSelect.value = id;
    const url = new URL(window.location.href); url.searchParams.set('table', id); window.history.replaceState({}, '', url.toString());
  } else { bannerNoTable.style.display = ''; bannerHasTable.style.display = 'none'; }
}
if (tableId) setTable(tableId);
tableSelect.addEventListener('change', () => setTable(tableSelect.value || null));

document.querySelectorAll('.menu-card').forEach(card => {
  const expandPanel = card.querySelector('.menu-card-expand') as HTMLElement;
  const addBtn = card.querySelector('.add-btn') as HTMLElement;
  const itemId = (card as HTMLElement).dataset.itemId!;
  const itemData = itemLookup.get(itemId);
  let tempQty = 1; let tempRemoved: Set<string> = new Set(); let tempAdded: string[] = [];

  function renderChips() {
    const container = expandPanel.querySelector('.ingredient-chips')!; container.innerHTML = '';
    (itemData?.ingredients || []).forEach(ing => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip' + (tempRemoved.has(ing) ? ' removed' : '');
      chip.innerHTML = `${ing} <span class="chip-x">${tempRemoved.has(ing) ? '+' : '\u00D7'}</span>`;
      chip.addEventListener('click', () => { if (tempRemoved.has(ing)) tempRemoved.delete(ing); else tempRemoved.add(ing); renderChips(); });
      container.appendChild(chip);
    });
    tempAdded.forEach((ing, idx) => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip added';
      chip.innerHTML = `+ ${ing} <span class="chip-x">\u00D7</span>`;
      chip.addEventListener('click', () => { tempAdded.splice(idx, 1); renderChips(); });
      container.appendChild(chip);
    });
  }

  function openExpand() {
    document.querySelectorAll('.menu-card-expand').forEach(p => (p as HTMLElement).style.display = 'none');
    document.querySelectorAll('.menu-card').forEach(c => c.classList.remove('expanding'));
    tempQty = 1; tempRemoved = new Set(); tempAdded = [];
    expandPanel.style.display = ''; card.classList.add('expanding'); renderChips();
    const qtyEl = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (qtyEl) qtyEl.textContent = '1';
    (expandPanel.querySelector('.item-note-input') as HTMLInputElement).value = '';
    (expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement).value = '';
    setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  }

  addBtn?.addEventListener('click', (e) => { e.stopPropagation(); openExpand(); });
  card.querySelector('.menu-card-main')?.addEventListener('click', () => openExpand());

  const addIngInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
  addIngInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter' && addIngInput.value.trim()) { tempAdded.push(addIngInput.value.trim()); addIngInput.value = ''; renderChips(); } });

  expandPanel.querySelector('.qty-dec')?.addEventListener('click', () => { if (tempQty > 1) { tempQty--; const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (el) el.textContent = String(tempQty); } });
  expandPanel.querySelector('.qty-inc')?.addEventListener('click', () => { tempQty++; const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (el) el.textContent = String(tempQty); });

  expandPanel.querySelector('.confirm-add-btn')?.addEventListener('click', () => {
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    cart.push({ id: itemId + '_' + Date.now(), name: itemData?.name || itemId, price: itemData?.price || 0, qty: tempQty, removed: Array.from(tempRemoved), added: [...tempAdded], note: noteInput?.value?.trim() || '' });
    expandPanel.style.display = 'none'; card.classList.remove('expanding'); card.classList.add('in-cart');
    card.animate([{transform:'scale(0.98)'},{transform:'scale(1)'}], {duration:200});
    updateCartUI();
  });
});

const cartFab = document.getElementById('cart-fab')!; const cartFabCount = document.getElementById('cart-fab-count')!;
const cartDrawer = document.getElementById('cart-drawer')!; const cartOverlay = document.getElementById('cart-overlay')!;
const cartItemsEl = document.getElementById('cart-items')!; const cartTotalPrice = document.getElementById('cart-total-price')!;
const cartSendBtn = document.getElementById('cart-send-btn') as HTMLButtonElement;

function formatPrice(n: number): string { return '\u20AC' + n.toFixed(2); }
function totalQty(): number { return cart.reduce((s, e) => s + e.qty, 0); }
function totalPrice(): number { return cart.reduce((s, e) => s + e.price * e.qty, 0); }

function updateCartUI() {
  const count = totalQty();
  if (count > 0) { cartFab.style.display = ''; cartFabCount.textContent = String(count); } else { cartFab.style.display = 'none'; }
  if (cart.length === 0) { cartItemsEl.innerHTML = '<div class="cart-empty">No items in your order</div>'; }
  else {
    cartItemsEl.innerHTML = cart.map((entry, idx) => {
      let modsHtml = '';
      if (entry.removed.length) modsHtml += entry.removed.map(r => `<span class="mod-remove">no ${r}</span>`).join(', ');
      if (entry.added.length) modsHtml += (modsHtml ? ', ' : '') + entry.added.map(a => `<span class="mod-add">+ ${a}</span>`).join(', ');
      return `<div class="cart-item" data-idx="${idx}"><div class="cart-item-info"><div class="cart-item-name">${entry.name}</div>${modsHtml ? `<div class="cart-item-mods">${modsHtml}</div>` : ''}${entry.note ? `<div class="cart-item-note">"${entry.note}"</div>` : ''}</div><div class="cart-item-actions"><div class="cart-item-price">${formatPrice(entry.price * entry.qty)}</div><div class="cart-item-qty"><button class="cart-remove-btn" data-idx="${idx}">\u{1F5D1}</button><button data-action="dec" data-idx="${idx}">\u2212</button><span>${entry.qty}</span><button data-action="inc" data-idx="${idx}">+</button></div></div></div>`;
    }).join('');
    cartItemsEl.querySelectorAll('[data-action="dec"]').forEach(btn => { btn.addEventListener('click', () => { const idx = parseInt((btn as HTMLElement).dataset.idx!); if (cart[idx].qty > 1) cart[idx].qty--; else cart.splice(idx, 1); updateCartUI(); }); });
    cartItemsEl.querySelectorAll('[data-action="inc"]').forEach(btn => { btn.addEventListener('click', () => { cart[parseInt((btn as HTMLElement).dataset.idx!)].qty++; updateCartUI(); }); });
    cartItemsEl.querySelectorAll('.cart-remove-btn').forEach(btn => { btn.addEventListener('click', () => { cart.splice(parseInt((btn as HTMLElement).dataset.idx!), 1); updateCartUI(); }); });
  }
  cartTotalPrice.textContent = formatPrice(totalPrice());
  cartSendBtn.disabled = cart.length === 0 || !tableId;
  document.querySelectorAll('.menu-card').forEach(c => { const id = (c as HTMLElement).dataset.itemId!; c.classList.toggle('in-cart', cart.some(e => e.id.startsWith(id + '_'))); });
}

function openCart() { cartOverlay.style.display = ''; cartDrawer.style.display = ''; requestAnimationFrame(() => { cartOverlay.classList.add('open'); cartDrawer.classList.add('open'); }); document.body.style.overflow = 'hidden'; }
function closeCart() { cartOverlay.classList.remove('open'); cartDrawer.classList.remove('open'); document.body.style.overflow = ''; setTimeout(() => { cartOverlay.style.display = 'none'; }, 350); }

document.getElementById('cart-fab-btn')?.addEventListener('click', openCart);
document.getElementById('cart-close')?.addEventListener('click', closeCart);
cartOverlay.addEventListener('click', closeCart);
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCart(); });

cartSendBtn.addEventListener('click', () => {
  if (!tableId || cart.length === 0) return;
  const label = 'Table ' + tableId.replace('table-', '');
  const ts = new Date().toLocaleString('en-GB', { dateStyle: 'short', timeStyle: 'short' });
  const globalNotes = (document.getElementById('order-notes-global') as HTMLTextAreaElement)?.value?.trim();
  let msg = `*ORDER \u2014 ${label}*\nDate: ${ts}\n\n*Items:*\n`;
  cart.forEach(entry => {
    msg += `\u2022 ${entry.name} x${entry.qty} \u2014 ${formatPrice(entry.price * entry.qty)}`;
    const mods: string[] = [];
    if (entry.removed.length) mods.push('WITHOUT: ' + entry.removed.join(', '));
    if (entry.added.length) mods.push('WITH: ' + entry.added.join(', '));
    if (mods.length) msg += `\n  _${mods.join(' | ')}_`;
    if (entry.note) msg += `\n  _Note: ${entry.note}_`;
    msg += '\n';
  });
  msg += `\n*ESTIMATED TOTAL: ${formatPrice(totalPrice())}*`;
  if (globalNotes) msg += `\n\n*General notes:* ${globalNotes}`;
  window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer');
});

updateCartUI();
</script>
