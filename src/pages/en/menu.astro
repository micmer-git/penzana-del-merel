---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MENU, SECTIONS, COPERTO, SECTION_QUOTES } from '../../data/menu.js';
import { WHATSAPP_NUMBER } from '../../data/site.js';
const base = '/penzana-del-merel';
const waNumber = WHATSAPP_NUMBER;

const menuDataJSON = JSON.stringify(
  SECTIONS.map(s => ({
    id: s.id,
    categories: s.categories.map(c => ({
      id: c.id,
      items: c.items.map(i => ({
        id: i.id,
        name: i.nameEN,
        price: i.price,
        desc: i.descEN || '',
        ingredients: (i.descEN || '').split(/,\s*| & /).map((x: string) => x.trim()).filter(Boolean),
        sizes: (i as any).sizes?.map((sz: any) => ({ label: sz.labelEN, price: sz.price })) || null,
      })),
    })),
  }))
);
---

<BaseLayout
  title="Menu 2026 — La Penzana del Merel"
  description="Full menu of La Penzana del Merel: pizzas, Bergamo cuisine, desserts and wine list. Order directly from your table via WhatsApp."
  lang="en"
  currentPath={`${base}/en/menu/`}
>

  <section class="hero hero-compact">
    <div class="container">
      <span class="hero-eyebrow">Menu 2026</span>
      <h1>Our Menu</h1>
      <p class="hero-sub">Wood-fired pizzas, Bergamo cuisine, wine list.</p>
    </div>
  </section>

  <div class="coperto-bar">
    Cover charge: &euro;{COPERTO.toFixed(2)} per person
  </div>

  <div class="menu-tabs-wrapper">
    <div class="container">
      <div class="menu-tabs" role="tablist" aria-label="Menu sections">
        {SECTIONS.map((section, i) => (
          <button
            role="tab"
            class={`menu-tab ${i === 0 ? 'active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${section.id}`}
            data-section={section.id}
          >
            {section.labelEN}
          </button>
        ))}
      </div>
    </div>
  </div>

  <section class="section menu-section-wrap">
    <div class="container menu-container">

      {SECTIONS.map((section, si) => (
        <div
          id={`panel-${section.id}`}
          role="tabpanel"
          class={`menu-panel ${si === 0 ? 'active' : ''}`}
          data-section={section.id}
        >
          {SECTION_QUOTES[section.id] && (
            <blockquote class="menu-quote">
              "{SECTION_QUOTES[section.id].text}"
              <span class="menu-quote-author">— {SECTION_QUOTES[section.id].author}</span>
            </blockquote>
          )}

          {section.categories.map(category => (
            <div class="menu-section" id={`cat-${category.id}`}>
              <h2 class="menu-section-title">
                {category.labelEN}
                <span class="label-en">/ {category.labelIT}</span>
              </h2>
              {category.subtitleEN && (
                <p class="menu-section-subtitle">{category.subtitleEN}</p>
              )}
              {category.items.map(item => {
                const sizes = (item as any).sizes;
                const priceDisplay = sizes && sizes.length > 1
                  ? `\u20AC${Math.min(...sizes.map(s => s.price)).toFixed(2)} – \u20AC${Math.max(...sizes.map(s => s.price)).toFixed(2)}`
                  : `\u20AC${item.price.toFixed(2)}`;
                return (
                <div class="menu-card" data-item-id={item.id} data-item-name={item.nameEN} data-item-price={item.price} data-item-desc={item.descEN || ''} data-has-sizes={sizes ? 'true' : undefined}>
                  <div class="menu-card-main">
                    <div class="menu-card-info">
                      <div class="menu-card-name">{item.nameEN}</div>
                      {(item.descEN || '') !== '' && (
                        <div class="menu-card-desc">{item.descEN}</div>
                      )}
                    </div>
                    <div class="menu-card-right">
                      <div class="menu-card-price">{priceDisplay}</div>
                      <button class="add-btn" aria-label={`Add ${item.nameEN}`} data-id={item.id}>
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>
                  <div class="menu-card-expand">
                    <div class="expand-inner">
                      {sizes && sizes.length > 1 && (
                        <div class="size-selector">
                          <div class="size-selector-label">Size:</div>
                          <div class="size-selector-options">
                            {sizes.map((sz, si) => (
                              <button class={`size-option ${si === 0 ? 'selected' : ''}`} data-size-idx={si} data-size-price={sz.price} data-size-label={(sz as any).labelEN}>
                                <span class="size-option-label">{(sz as any).labelEN}</span>
                                <span class="size-option-price">&euro;{sz.price.toFixed(2)}</span>
                              </button>
                            ))}
                          </div>
                        </div>
                      )}
                      <div class="ingredient-chips"></div>
                      <div class="expand-input-row">
                        <input type="text" class="add-ingredient-input expand-input" placeholder="+ add ingredient..." aria-label={`Add ingredient to ${item.nameEN}`} />
                      </div>
                      <div class="expand-input-row">
                        <input type="text" class="item-note-input expand-input expand-input-full" placeholder="Notes (e.g. well done, no lactose...)" aria-label={`Notes for ${item.nameEN}`} />
                      </div>
                      <div class="expand-actions">
                        <div class="qty-row">
                          <button class="qty-btn-new qty-dec" data-id={item.id} aria-label="Remove">&#8722;</button>
                          <span class="qty-val" data-id={item.id}>1</span>
                          <button class="qty-btn-new qty-inc" data-id={item.id} aria-label="Add">+</button>
                        </div>
                        <button class="confirm-add-btn" data-id={item.id}>Add to order</button>
                      </div>
                    </div>
                  </div>
                </div>
              );
              })}
            </div>
          ))}
        </div>
      ))}

      <div class="menu-note">
        <strong>Note:</strong> Prices may vary seasonally. Please inform staff of any allergies.
      </div>
    </div>
  </section>

  <!-- Persistent cart bar — always visible when items in cart -->
  <div id="cart-bar" class="cart-bar" aria-hidden="true">
    <div class="cart-bar-inner">
      <div class="cart-bar-info">
        <span id="cart-bar-count" class="cart-bar-count">0</span>
        <span class="cart-bar-label">items</span>
        <span class="cart-bar-dot">&middot;</span>
        <strong id="cart-bar-total">&euro;0.00</strong>
      </div>
      <button id="cart-bar-btn" class="cart-bar-btn" aria-label="Open cart">
        View order
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <!-- Order mode modal — shown on first item if no table selected -->
  <div id="order-mode-overlay" class="order-mode-overlay" aria-hidden="true"></div>
  <div id="order-mode-modal" class="order-mode-modal" role="dialog" aria-label="Order mode" aria-hidden="true">
    <h3>How would you like to order?</h3>
    <p class="order-mode-sub">Choose your order mode</p>
    <div class="order-mode-options">
      <button id="mode-table-btn" class="order-mode-option">
        <span class="order-mode-icon" aria-hidden="true"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue-deep)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M5 12V6a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v6"/><path d="M6 12v7"/><path d="M18 12v7"/><path d="M4 19h4"/><path d="M16 19h4"/></svg></span>
        <span class="order-mode-title">Dine in</span>
        <span class="order-mode-desc">Select your table</span>
      </button>
      <button id="mode-delivery-btn" class="order-mode-option">
        <span class="order-mode-icon" aria-hidden="true"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue-deep)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M5 18H3V11l2-4h4l3 5h4l2 3v3h-2"/><path d="M9 18h6"/><path d="M14 8V4h-4"/></svg></span>
        <span class="order-mode-title">Delivery</span>
        <span class="order-mode-desc">Enter address and time</span>
      </button>
    </div>
    <!-- Table sub-form -->
    <div id="mode-table-form" class="order-mode-form" style="display:none">
      <label class="order-mode-label">Select table</label>
      <select id="modal-table-select" class="order-mode-input">
        <option value="">Table...</option>
      </select>
      <button id="mode-table-confirm" class="order-mode-confirm" disabled>Confirm table</button>
    </div>
    <!-- Delivery sub-form -->
    <div id="mode-delivery-form" class="order-mode-form" style="display:none">
      <label class="order-mode-label">Name</label>
      <input id="delivery-name" type="text" class="order-mode-input" placeholder="Your name" />
      <label class="order-mode-label">Address</label>
      <input id="delivery-address" type="text" class="order-mode-input" placeholder="Street, number, city" />
      <label class="order-mode-label">Preferred time</label>
      <input id="delivery-time" type="time" class="order-mode-input" />
      <button id="mode-delivery-confirm" class="order-mode-confirm" disabled>Confirm delivery</button>
    </div>
  </div>

  <!-- Cart drawer -->
  <div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-label="Cart" aria-hidden="true">
    <div class="cart-drawer-header">
      <h3>Your Order</h3>
      <button id="cart-close" class="cart-close" aria-label="Close cart">&times;</button>
    </div>
    <div id="cart-items" class="cart-items">
      <div class="cart-empty">No items in your order</div>
    </div>
    <div class="cart-footer">
      <div class="cart-notes-wrap">
        <label for="order-notes-global" class="cart-notes-label">General notes:</label>
        <textarea id="order-notes-global" class="cart-notes-input" rows="2" placeholder="Allergies, special requests..."></textarea>
      </div>
      <div class="cart-total">
        <span>Total</span>
        <strong id="cart-total-price">&euro;0.00</strong>
      </div>
      <button id="cart-send-btn" class="btn btn-wa cart-send-btn" disabled>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Send order via WhatsApp
      </button>
    </div>
  </div>

</BaseLayout>

<style>
/* Hero compact */
.hero-compact { padding-block: clamp(2.5rem, 6vw, 4rem); }
.hero-sub { margin-bottom: 0.5rem; }

/* Coperto */
.coperto-bar { background: var(--bg-warm); padding: 0.55rem 1rem; text-align: center; font-size: 0.82rem; color: var(--text-muted); border-bottom: 1px solid var(--slate-xlight); font-weight: 500; }

/* Tabs */
.menu-tabs-wrapper { background: var(--white); border-bottom: 1px solid var(--slate-xlight); position: sticky; top: 56px; z-index: var(--z-sticky); }

/* Section wrap */
.menu-section-wrap { padding-top: 1.5rem; padding-bottom: 7rem; }
.menu-container { max-width: 800px; }

/* Panel visibility */
.menu-panel { display: none; }
.menu-panel.active { display: block; }

/* Quote */
.menu-quote { margin-bottom: 2rem; font-size: 0.95rem; border-left: 4px solid var(--blue-mid); padding: 1rem 1.5rem; font-family: var(--font-display); font-style: italic; color: var(--blue-deep); background: var(--blue-xlight); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; }
.menu-quote-author { display: block; font-size: 0.75rem; font-style: normal; color: var(--slate); margin-top: 0.25rem; }

/* Section subtitle */
.menu-section-subtitle { font-size: 0.8rem; color: var(--text-muted); margin-top: -0.75rem; margin-bottom: 1rem; font-style: italic; }

/* Menu Card */
.menu-card { background: var(--white); border-radius: var(--radius-lg); padding: 1rem 1.15rem; margin-bottom: 0.6rem; box-shadow: var(--shadow-xs); transition: box-shadow 0.25s var(--ease-out), border-color 0.25s var(--ease-out); border: 1px solid var(--slate-xlight); border-left: 3px solid transparent; -webkit-tap-highlight-color: transparent; }
.menu-card:hover { box-shadow: var(--shadow-sm); border-left-color: var(--blue-xlight); }
.menu-card.in-cart { border-left-color: var(--wa-green); background: var(--success-bg); border-color: var(--success-border); }
.menu-card.expanding { box-shadow: var(--shadow-md); border-left-color: var(--blue-mid); }
.menu-card-main { display: flex; align-items: flex-start; gap: 0.85rem; cursor: pointer; -webkit-tap-highlight-color: transparent; }
.menu-card-info { flex: 1; min-width: 0; }
.menu-card-name { font-weight: 700; font-size: 0.97rem; color: var(--text); line-height: 1.3; }
.menu-card-desc { font-size: 0.82rem; color: var(--text-muted); line-height: 1.45; margin-top: 0.2rem; }
.menu-card-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0; }
.menu-card-price { font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; color: var(--blue-deep); white-space: nowrap; }

/* Add button */
.add-btn { width: 38px; height: 38px; border-radius: 50%; border: 2px solid var(--blue-mid); background: transparent; color: var(--blue-mid); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s var(--ease-out); min-width: 44px; min-height: 44px; -webkit-tap-highlight-color: transparent; }
.add-btn:hover { background: var(--blue-mid); color: white; transform: scale(1.08); box-shadow: 0 2px 8px rgba(59,125,216,0.3); }
.add-btn:active { transform: scale(0.92); }

/* Expand panel — CSS grid collapse */
.menu-card-expand { display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows 0.35s var(--ease-out), opacity 0.25s var(--ease-out); }
.menu-card-expand.open { grid-template-rows: 1fr; opacity: 1; }
.expand-inner { overflow: hidden; }
.menu-card-expand.open .expand-inner { padding-top: 0.85rem; margin-top: 0.85rem; border-top: 1px solid var(--slate-xlight); }

/* Size selector */
.size-selector { margin-bottom: 0.75rem; }
.size-selector-label { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }
.size-selector-options { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.size-option { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; padding: 0.45rem 0.85rem; border: 2px solid var(--slate-xlight); border-radius: var(--radius); background: var(--white); cursor: pointer; transition: all 0.15s var(--ease-out); min-height: 44px; min-width: 44px; -webkit-tap-highlight-color: transparent; }
.size-option:hover { border-color: var(--blue-mid); background: var(--blue-xlight); }
.size-option.selected { border-color: var(--blue-mid); background: var(--blue-xlight); box-shadow: 0 0 0 3px rgba(59,125,216,0.12); }
.size-option:active { transform: scale(0.96); }
.size-option-label { font-weight: 700; font-size: 0.8rem; color: var(--text); }
.size-option-price { font-size: 0.75rem; color: var(--blue-deep); font-weight: 600; }

.ingredient-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.ing-chip { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 0.77rem; font-weight: 600; cursor: pointer; transition: all 0.15s var(--ease-out); border: 1.5px solid var(--slate-xlight); background: var(--bg-warm); color: var(--text); user-select: none; min-height: 36px; -webkit-tap-highlight-color: transparent; }
.ing-chip:hover { border-color: var(--slate-light); }
.ing-chip:active { transform: scale(0.95); }
.ing-chip.removed { background: var(--error-bg); border-color: var(--error-border); color: var(--error); text-decoration: line-through; }
.ing-chip.added { background: var(--success-bg); border-color: var(--success-border); color: var(--success); }
.ing-chip .chip-x { font-size: 0.92rem; line-height: 1; margin-left: 0.15rem; }

/* Expand inputs */
.expand-input-row { margin-top: 0.55rem; display: flex; gap: 0.5rem; align-items: center; }
.expand-input { flex: 1; padding: 0.4rem 0.7rem; border: 1.5px solid var(--slate-xlight); border-radius: var(--radius); font-size: 16px; font-family: var(--font-body); background: var(--white); transition: border-color var(--transition); min-height: 40px; }
.expand-input:focus { border-color: var(--blue-mid); outline: none; box-shadow: 0 0 0 3px rgba(59,125,216,0.1); }
.expand-input-full { width: 100%; }
.expand-actions { margin-top: 0.7rem; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }

/* Qty */
.qty-row { display: flex; align-items: center; gap: 0.6rem; }
.qty-btn-new { width: 36px; height: 36px; border-radius: 50%; border: 2px solid var(--slate-xlight); background: var(--white); color: var(--text); font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s var(--ease-out); min-width: 44px; min-height: 44px; -webkit-tap-highlight-color: transparent; }
.qty-btn-new:hover { border-color: var(--blue-mid); color: var(--blue-mid); }
.qty-btn-new:active { transform: scale(0.92); }
.qty-val { font-weight: 700; font-size: 1.1rem; min-width: 28px; text-align: center; }

.confirm-add-btn { padding: 0.55rem 1.25rem; border-radius: var(--radius); border: none; background: var(--blue-mid); color: white; font-weight: 700; font-size: 0.85rem; font-family: var(--font-body); cursor: pointer; transition: all 0.2s var(--ease-out); min-height: 44px; -webkit-tap-highlight-color: transparent; }
.confirm-add-btn:hover { background: var(--blue-deep); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
.confirm-add-btn:active { transform: scale(0.97); }

/* Bottom note */
.menu-note { margin-top: 2rem; padding: 1rem; background: var(--bg-warm); border-radius: var(--radius); font-size: 0.8rem; color: var(--text-muted); }

/* ---- Persistent Cart Bar — always visible when items in cart ---- */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-fab);
  transform: translateY(100%);
  opacity: 0;
  visibility: hidden;
  transition: transform 0.35s var(--ease-out), opacity 0.3s var(--ease-out), visibility 0.3s;
  pointer-events: none;
}
.cart-bar.visible {
  transform: translateY(0);
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.cart-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding: 0.75rem 1.25rem;
  padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
  background: var(--blue-deep);
  color: white;
  box-shadow: 0 -4px 24px rgba(0,0,0,0.18);
}
.cart-bar-info {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.92rem;
  font-weight: 500;
}
.cart-bar-count {
  background: white;
  color: var(--blue-deep);
  font-weight: 800;
  font-size: 0.78rem;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.cart-bar-dot { opacity: 0.5; }
.cart-bar-label { font-weight: 400; opacity: 0.85; }
.cart-bar-btn {
  padding: 0.55rem 1.1rem;
  border-radius: var(--radius);
  border: none;
  background: var(--wa-green);
  color: white;
  font-weight: 700;
  font-size: 0.85rem;
  font-family: var(--font-body);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.3rem;
  transition: all 0.2s var(--ease-out);
  min-height: 44px;
  -webkit-tap-highlight-color: transparent;
}
.cart-bar-btn:hover { filter: brightness(1.1); transform: scale(1.03); }
.cart-bar-btn:active { transform: scale(0.96); }

/* ---- Order Mode Modal ---- */
.order-mode-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.65);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 400;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s var(--ease-out), visibility 0.3s;
  pointer-events: none;
}
.order-mode-overlay.open {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.order-mode-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 410;
  background: var(--white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  box-shadow: var(--shadow-xl);
  padding: 1.5rem 1.5rem calc(1.5rem + env(safe-area-inset-bottom, 0px));
  transform: translateY(100%);
  visibility: hidden;
  transition: transform 0.4s var(--ease-out), visibility 0.4s;
  pointer-events: none;
  max-width: 460px;
  margin: 0 auto;
}
.order-mode-modal.open {
  transform: translateY(0);
  visibility: visible;
  pointer-events: auto;
}
.order-mode-modal h3 {
  margin: 0 0 0.25rem;
  font-size: 1.2rem;
  color: var(--text);
}
.order-mode-sub {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin: 0 0 1rem;
}
.order-mode-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 1rem;
}
.order-mode-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  padding: 1.25rem 0.75rem;
  border: 2px solid var(--slate-xlight);
  border-radius: var(--radius-lg);
  background: var(--white);
  cursor: pointer;
  transition: all 0.2s var(--ease-out);
  -webkit-tap-highlight-color: transparent;
}
.order-mode-option:hover { border-color: var(--blue-mid); background: var(--blue-xlight); }
.order-mode-option.selected { border-color: var(--blue-mid); background: var(--blue-xlight); box-shadow: 0 0 0 3px rgba(59,125,216,0.15); }
.order-mode-option:active { transform: scale(0.97); }
.order-mode-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--blue-xlight);
  border-radius: var(--radius-lg);
  margin-bottom: 0.25rem;
}
.order-mode-title { font-weight: 700; font-size: 0.95rem; color: var(--text); }
.order-mode-desc { font-size: 0.75rem; color: var(--text-muted); text-align: center; }
.order-mode-form { margin-top: 0.5rem; }
.order-mode-label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 0.3rem;
  margin-top: 0.6rem;
}
.order-mode-label:first-child { margin-top: 0; }
.order-mode-input {
  width: 100%;
  padding: 0.55rem 0.75rem;
  border: 1.5px solid var(--slate-xlight);
  border-radius: var(--radius);
  font-size: 16px;
  font-family: var(--font-body);
  background: var(--white);
  transition: border-color var(--transition);
  min-height: 44px;
  box-sizing: border-box;
}
.order-mode-input:focus {
  border-color: var(--blue-mid);
  outline: none;
  box-shadow: 0 0 0 3px rgba(59,125,216,0.1);
}
.order-mode-confirm {
  margin-top: 0.85rem;
  width: 100%;
  padding: 0.65rem;
  border: none;
  border-radius: var(--radius);
  background: var(--blue-mid);
  color: white;
  font-weight: 700;
  font-size: 0.9rem;
  font-family: var(--font-body);
  cursor: pointer;
  min-height: 48px;
  transition: all 0.2s var(--ease-out);
  -webkit-tap-highlight-color: transparent;
}
.order-mode-confirm:hover:not(:disabled) { background: var(--blue-deep); }
.order-mode-confirm:disabled { opacity: 0.4; cursor: not-allowed; }

/* ---- Cart Drawer — visibility + transform ---- */
.cart-overlay { position: fixed; inset: 0; background: rgba(15,23,42,0.65); z-index: var(--z-cart-overlay); opacity: 0; visibility: hidden; transition: opacity 0.3s var(--ease-out), visibility 0.3s; pointer-events: none; backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
.cart-overlay.open { opacity: 1; visibility: visible; pointer-events: auto; }

.cart-drawer { position: fixed; bottom: 0; left: 0; right: 0; z-index: var(--z-cart-drawer); background: var(--white); border-radius: var(--radius-xl) var(--radius-xl) 0 0; box-shadow: var(--shadow-xl); max-height: 85vh; max-height: 85dvh; display: flex; flex-direction: column; transform: translateY(100%); visibility: hidden; transition: transform 0.4s var(--ease-out), visibility 0.4s; pointer-events: none; }
.cart-drawer.open { transform: translateY(0); visibility: visible; pointer-events: auto; }
.cart-drawer-header { display: flex; align-items: center; justify-content: space-between; padding: 1.15rem 1.5rem 0.65rem; border-bottom: 1px solid var(--slate-xlight); flex-shrink: 0; }
.cart-drawer-header h3 { margin: 0; font-size: 1.15rem; }
.cart-close { width: 38px; height: 38px; border: none; background: var(--bg-warm); border-radius: 50%; font-size: 1.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted); min-width: 44px; min-height: 44px; transition: all var(--transition); -webkit-tap-highlight-color: transparent; }
.cart-close:hover { background: var(--slate-xlight); color: var(--text); }
.cart-close:active { transform: scale(0.92); }

.cart-items { flex: 1; overflow-y: auto; overscroll-behavior: contain; padding: 0.85rem 1.5rem; -webkit-overflow-scrolling: touch; }
.cart-empty { text-align: center; color: var(--slate); padding: 2.5rem 0; font-size: 0.9rem; }
.cart-item { display: flex; gap: 0.85rem; padding: 0.85rem 0; border-bottom: 1px solid var(--slate-xlight); align-items: flex-start; }
.cart-item:last-child { border-bottom: none; }
.cart-item-info { flex: 1; min-width: 0; }
.cart-item-name { font-weight: 700; font-size: 0.92rem; }
.cart-item-mods { font-size: 0.77rem; color: var(--text-muted); margin-top: 0.2rem; }
.cart-item-mods .mod-remove { color: var(--error); }
.cart-item-mods .mod-add { color: var(--success); }
.cart-item-note { font-size: 0.75rem; color: var(--blue-mid); font-style: italic; margin-top: 0.15rem; }
.cart-item-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; }
.cart-item-price { font-weight: 700; font-size: 0.92rem; color: var(--blue-deep); white-space: nowrap; }
.cart-item-qty { display: flex; align-items: center; gap: 0.35rem; }
.cart-item-qty button { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid var(--slate-xlight); background: var(--white); font-size: 0.9rem; cursor: pointer; display: flex; align-items: center; justify-content: center; min-width: 38px; min-height: 38px; transition: all 0.15s var(--ease-out); -webkit-tap-highlight-color: transparent; }
.cart-item-qty button:hover { border-color: var(--blue-mid); color: var(--blue-mid); }
.cart-item-qty button:active { transform: scale(0.9); }
.cart-item-qty button.cart-remove-btn { border-color: var(--error-border); color: var(--error); }
.cart-item-qty button.cart-remove-btn:hover { background: var(--error-bg); }
.cart-item-qty span { font-weight: 700; min-width: 20px; text-align: center; font-size: 0.88rem; }

.cart-footer { padding: 0.85rem 1.5rem; padding-bottom: calc(0.85rem + env(safe-area-inset-bottom, 0px)); border-top: 1px solid var(--slate-xlight); background: var(--bg-warm); flex-shrink: 0; }
.cart-notes-wrap { margin-bottom: 0.5rem; }
.cart-notes-label { font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.2rem; }
.cart-notes-input { width: 100%; padding: 0.4rem 0.6rem; border: 1px solid var(--slate-xlight); border-radius: var(--radius); font-size: 16px; font-family: var(--font-body); resize: none; transition: border-color var(--transition); }
.cart-notes-input:focus { border-color: var(--blue-mid); outline: none; box-shadow: 0 0 0 3px rgba(59,125,216,0.1); }
.cart-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.85rem; font-size: 1.05rem; }
.cart-send-btn { width: 100%; justify-content: center; }

@media (min-width: 600px) {
  .cart-drawer { max-width: 460px; left: auto; right: 0; }
}
</style>

<script define:vars={{ waNumber, menuDataJSON }}>
  window.__WA_NUMBER = waNumber;
  window.__MENU_DATA = menuDataJSON;
</script>

<script>
const WHATSAPP_NUMBER = (window as any).__WA_NUMBER || '393487024985';
interface ItemSize { label: string; price: number; }
interface ItemData { id: string; name: string; price: number; desc: string; ingredients: string[]; sizes: ItemSize[] | null; }
const MENU_DATA: Array<{id:string, categories:Array<{id:string, items:ItemData[]}>}> = JSON.parse((window as any).__MENU_DATA || '[]');

// Build lookup
const itemLookup = new Map<string, ItemData>();
MENU_DATA.forEach(s => s.categories.forEach(c => c.items.forEach(i => itemLookup.set(i.id, i))));

// ---- State ----
interface CartEntry {
  id: string;
  name: string;
  price: number;
  qty: number;
  removed: string[];
  added: string[];
  note: string;
  sizeLabel: string;
}

let cart: CartEntry[] = [];
let tableId: string | null = new URLSearchParams(window.location.search).get('table');
let orderMode: 'table' | 'delivery' | null = tableId ? 'table' : null;
let deliveryInfo: { name: string; address: string; time: string } | null = null;

// ---- Tab switching ----
const allTabs = document.querySelectorAll<HTMLElement>('.menu-tab');
const allPanels = document.querySelectorAll<HTMLElement>('.menu-panel');

allTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const section = tab.dataset.section!;
    allTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');
    allPanels.forEach(p => p.classList.toggle('active', p.dataset.section === section));
  });
});

// ---- Table selection ----
function setTable(id: string | null) {
  tableId = id;
  if (id) {
    const url = new URL(window.location.href);
    url.searchParams.set('table', id);
    window.history.replaceState({}, '', url.toString());
  }
  updateCartUI();
}

if (tableId) setTable(tableId);

// ---- Menu card expand ----
document.querySelectorAll<HTMLElement>('.menu-card').forEach(card => {
  const expandPanel = card.querySelector('.menu-card-expand') as HTMLElement;
  const addBtn = card.querySelector('.add-btn') as HTMLElement;
  const itemId = card.dataset.itemId!;
  const itemData = itemLookup.get(itemId);
  let tempQty = 1;
  let tempRemoved: Set<string> = new Set();
  let tempAdded: string[] = [];
  let tempSizeIdx = 0;

  function renderChips() {
    const container = expandPanel.querySelector('.ingredient-chips')!;
    container.innerHTML = '';
    (itemData?.ingredients || []).forEach(ing => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip' + (tempRemoved.has(ing) ? ' removed' : '');
      chip.innerHTML = `${ing} <span class="chip-x">${tempRemoved.has(ing) ? '+' : '\u00D7'}</span>`;
      chip.addEventListener('click', () => {
        if (tempRemoved.has(ing)) tempRemoved.delete(ing);
        else tempRemoved.add(ing);
        renderChips();
      });
      container.appendChild(chip);
    });
    tempAdded.forEach((ing, idx) => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip added';
      chip.innerHTML = `+ ${ing} <span class="chip-x">\u00D7</span>`;
      chip.addEventListener('click', () => {
        tempAdded.splice(idx, 1);
        renderChips();
      });
      container.appendChild(chip);
    });
  }

  function closeAllExpands() {
    document.querySelectorAll('.menu-card-expand.open').forEach(p => p.classList.remove('open'));
    document.querySelectorAll('.menu-card.expanding').forEach(c => c.classList.remove('expanding'));
  }

  function openExpand() {
    closeAllExpands();
    tempQty = 1;
    tempRemoved = new Set();
    tempAdded = [];
    tempSizeIdx = 0;
    expandPanel.classList.add('open');
    card.classList.add('expanding');
    renderChips();
    // Reset size selector
    expandPanel.querySelectorAll('.size-option').forEach((btn, i) => {
      btn.classList.toggle('selected', i === 0);
    });
    const qtyEl = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
    if (qtyEl) qtyEl.textContent = '1';
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    if (noteInput) noteInput.value = '';
    const addInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
    if (addInput) addInput.value = '';
    requestAnimationFrame(() => {
      setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 150);
    });
  }

  // Size option click handlers
  expandPanel.querySelectorAll<HTMLElement>('.size-option').forEach(btn => {
    btn.addEventListener('click', () => {
      tempSizeIdx = parseInt(btn.dataset.sizeIdx || '0');
      expandPanel.querySelectorAll('.size-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
    });
  });

  addBtn?.addEventListener('click', (e) => { e.stopPropagation(); openExpand(); });
  card.querySelector('.menu-card-main')?.addEventListener('click', () => openExpand());

  const addIngInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
  addIngInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && addIngInput.value.trim()) {
      e.preventDefault();
      tempAdded.push(addIngInput.value.trim());
      addIngInput.value = '';
      renderChips();
    }
  });

  expandPanel.querySelector('.qty-dec')?.addEventListener('click', () => {
    if (tempQty > 1) {
      tempQty--;
      const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
      if (el) el.textContent = String(tempQty);
    }
  });
  expandPanel.querySelector('.qty-inc')?.addEventListener('click', () => {
    tempQty++;
    const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
    if (el) el.textContent = String(tempQty);
  });

  expandPanel.querySelector('.confirm-add-btn')?.addEventListener('click', () => {
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    const hasSizes = itemData?.sizes && itemData.sizes.length > 1;
    const selectedSize = hasSizes ? itemData!.sizes![tempSizeIdx] : null;
    const entry: CartEntry = {
      id: itemId + '_' + Date.now(),
      name: itemData?.name || itemId,
      price: selectedSize ? selectedSize.price : (itemData?.price || 0),
      qty: tempQty,
      removed: Array.from(tempRemoved),
      added: [...tempAdded],
      note: noteInput?.value?.trim() || '',
      sizeLabel: selectedSize ? selectedSize.label : '',
    };

    // On first item, if no order mode set, ask table or delivery
    if (cart.length === 0 && !orderMode) {
      pendingEntry = entry;
      pendingCard = card;
      pendingExpandPanel = expandPanel;
      showOrderModeModal();
      return;
    }

    cart.push(entry);
    expandPanel.classList.remove('open');
    card.classList.remove('expanding');
    card.classList.add('in-cart');
    card.animate([{transform:'scale(0.97)'},{transform:'scale(1)'}], {duration:200, easing:'ease-out'});
    updateCartUI();
  });
});

// ---- Pending entry (for order mode modal flow) ----
let pendingEntry: CartEntry | null = null;
let pendingCard: HTMLElement | null = null;
let pendingExpandPanel: HTMLElement | null = null;

// ---- Cart UI ----
const cartBar = document.getElementById('cart-bar')!;
const cartBarCount = document.getElementById('cart-bar-count')!;
const cartBarTotal = document.getElementById('cart-bar-total')!;
const cartDrawer = document.getElementById('cart-drawer')!;
const cartOverlay = document.getElementById('cart-overlay')!;
const cartItemsEl = document.getElementById('cart-items')!;
const cartTotalPrice = document.getElementById('cart-total-price')!;
const cartSendBtn = document.getElementById('cart-send-btn') as HTMLButtonElement;

function formatPrice(n: number): string { return '\u20AC' + n.toFixed(2); }
function totalQty(): number { return cart.reduce((s, e) => s + e.qty, 0); }
function totalPrice(): number { return cart.reduce((s, e) => s + e.price * e.qty, 0); }

function updateCartUI() {
  const count = totalQty();

  // Persistent cart bar visibility
  if (count > 0) {
    cartBar.classList.add('visible');
    cartBar.setAttribute('aria-hidden', 'false');
    cartBarCount.textContent = String(count);
    cartBarTotal.textContent = formatPrice(totalPrice());
  } else {
    cartBar.classList.remove('visible');
    cartBar.setAttribute('aria-hidden', 'true');
  }

  // Drawer items
  if (cart.length === 0) {
    cartItemsEl.innerHTML = '<div class="cart-empty">No items in your order</div>';
  } else {
    cartItemsEl.innerHTML = cart.map((entry, idx) => {
      let modsHtml = '';
      if (entry.removed.length) modsHtml += entry.removed.map(r => `<span class="mod-remove">no ${r}</span>`).join(', ');
      if (entry.added.length) modsHtml += (modsHtml ? ', ' : '') + entry.added.map(a => `<span class="mod-add">+ ${a}</span>`).join(', ');
      return `<div class="cart-item" data-idx="${idx}">
        <div class="cart-item-info">
          <div class="cart-item-name">${entry.name}${entry.sizeLabel ? ` <span style="font-weight:500;color:var(--text-muted);font-size:0.82rem;">(${entry.sizeLabel})</span>` : ''}</div>
          ${modsHtml ? `<div class="cart-item-mods">${modsHtml}</div>` : ''}
          ${entry.note ? `<div class="cart-item-note">"${entry.note}"</div>` : ''}
        </div>
        <div class="cart-item-actions">
          <div class="cart-item-price">${formatPrice(entry.price * entry.qty)}</div>
          <div class="cart-item-qty">
            <button class="cart-remove-btn" data-idx="${idx}" aria-label="Remove item">\u{1F5D1}</button>
            <button data-action="dec" data-idx="${idx}" aria-label="Decrease quantity">\u2212</button>
            <span>${entry.qty}</span>
            <button data-action="inc" data-idx="${idx}" aria-label="Increase quantity">+</button>
          </div>
        </div>
      </div>`;
    }).join('');

    cartItemsEl.querySelectorAll('[data-action="dec"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        if (cart[idx].qty > 1) cart[idx].qty--;
        else cart.splice(idx, 1);
        updateCartUI();
      });
    });
    cartItemsEl.querySelectorAll('[data-action="inc"]').forEach(btn => {
      btn.addEventListener('click', () => {
        cart[parseInt((btn as HTMLElement).dataset.idx!)].qty++;
        updateCartUI();
      });
    });
    cartItemsEl.querySelectorAll('.cart-remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        cart.splice(parseInt((btn as HTMLElement).dataset.idx!), 1);
        updateCartUI();
      });
    });
  }

  cartTotalPrice.textContent = formatPrice(totalPrice());
  cartSendBtn.disabled = cart.length === 0 || (!tableId && !deliveryInfo);

  // Update in-cart marks
  document.querySelectorAll<HTMLElement>('.menu-card').forEach(c => {
    const id = c.dataset.itemId!;
    const inCart = cart.some(e => e.id.startsWith(id + '_'));
    c.classList.toggle('in-cart', inCart);
  });
}

// Cart open/close
function openCart() {
  cartOverlay.classList.add('open');
  cartDrawer.classList.add('open');
  cartDrawer.setAttribute('aria-hidden', 'false');
  cartOverlay.setAttribute('aria-hidden', 'false');
  document.body.classList.add('scroll-locked');
  requestAnimationFrame(() => {
    (document.getElementById('cart-close') as HTMLElement)?.focus();
  });
}

function closeCart() {
  cartOverlay.classList.remove('open');
  cartDrawer.classList.remove('open');
  cartDrawer.setAttribute('aria-hidden', 'true');
  cartOverlay.setAttribute('aria-hidden', 'true');
  document.body.classList.remove('scroll-locked');
}

document.getElementById('cart-bar-btn')?.addEventListener('click', openCart);
document.getElementById('cart-close')?.addEventListener('click', closeCart);
cartOverlay.addEventListener('click', closeCart);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && cartDrawer.classList.contains('open')) closeCart();
});

// ---- Send order via WhatsApp ----
cartSendBtn.addEventListener('click', () => {
  if (cart.length === 0 || (!tableId && !deliveryInfo)) return;

  const ts = new Date().toLocaleString('en-GB', { dateStyle: 'short', timeStyle: 'short' });
  const globalNotes = (document.getElementById('order-notes-global') as HTMLTextAreaElement)?.value?.trim();

  let header = '';
  if (orderMode === 'delivery' && deliveryInfo) {
    header = `*ORDER — Delivery*\nName: ${deliveryInfo.name}\nAddress: ${deliveryInfo.address}\nTime: ${deliveryInfo.time || 'As soon as possible'}\nDate: ${ts}`;
  } else {
    const label = tableId ? 'Table ' + tableId.replace('table-', '') : 'Not specified';
    header = `*ORDER \u2014 ${label}*\nDate: ${ts}`;
  }

  let msg = `${header}\n\n*Items:*\n`;
  cart.forEach(entry => {
    const sizeInfo = entry.sizeLabel ? ` (${entry.sizeLabel})` : '';
    msg += `\u2022 ${entry.name}${sizeInfo} x${entry.qty} \u2014 ${formatPrice(entry.price * entry.qty)}`;
    const mods: string[] = [];
    if (entry.removed.length) mods.push('WITHOUT: ' + entry.removed.join(', '));
    if (entry.added.length) mods.push('WITH: ' + entry.added.join(', '));
    if (mods.length) msg += `\n  _${mods.join(' | ')}_`;
    if (entry.note) msg += `\n  _Note: ${entry.note}_`;
    msg += '\n';
  });
  msg += `\n*ESTIMATED TOTAL: ${formatPrice(totalPrice())}*`;
  if (globalNotes) msg += `\n\n*General notes:* ${globalNotes}`;

  const waUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;

  // Must append to DOM for mobile Safari/Chrome to follow the click
  const a = document.createElement('a');
  a.href = waUrl;
  a.target = '_blank';
  a.rel = 'noopener noreferrer';
  a.style.position = 'fixed';
  a.style.opacity = '0';
  a.style.pointerEvents = 'none';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => a.remove(), 200);
});

// ---- Order Mode Modal ----
const orderModeOverlay = document.getElementById('order-mode-overlay')!;
const orderModeModal = document.getElementById('order-mode-modal')!;
const modeTableBtn = document.getElementById('mode-table-btn')!;
const modeDeliveryBtn = document.getElementById('mode-delivery-btn')!;
const modeTableForm = document.getElementById('mode-table-form')!;
const modeDeliveryForm = document.getElementById('mode-delivery-form')!;
const modalTableSelect = document.getElementById('modal-table-select') as HTMLSelectElement;
const modeTableConfirm = document.getElementById('mode-table-confirm') as HTMLButtonElement;
const deliveryNameInput = document.getElementById('delivery-name') as HTMLInputElement;
const deliveryAddressInput = document.getElementById('delivery-address') as HTMLInputElement;
const deliveryTimeInput = document.getElementById('delivery-time') as HTMLInputElement;
const modeDeliveryConfirm = document.getElementById('mode-delivery-confirm') as HTMLButtonElement;

// Populate modal table select with same options
for (let i = 1; i <= 20; i++) {
  const opt = document.createElement('option');
  opt.value = `table-${String(i).padStart(2, '0')}`;
  opt.textContent = `Table ${String(i).padStart(2, '0')}`;
  modalTableSelect.appendChild(opt);
}

function showOrderModeModal() {
  orderModeOverlay.classList.add('open');
  orderModeModal.classList.add('open');
  orderModeOverlay.setAttribute('aria-hidden', 'false');
  orderModeModal.setAttribute('aria-hidden', 'false');
  document.body.classList.add('scroll-locked');
  // Reset forms
  modeTableForm.style.display = 'none';
  modeDeliveryForm.style.display = 'none';
  modeTableBtn.classList.remove('selected');
  modeDeliveryBtn.classList.remove('selected');
}

function closeOrderModeModal() {
  orderModeOverlay.classList.remove('open');
  orderModeModal.classList.remove('open');
  orderModeOverlay.setAttribute('aria-hidden', 'true');
  orderModeModal.setAttribute('aria-hidden', 'true');
  document.body.classList.remove('scroll-locked');
}

function finalizePendingEntry() {
  if (pendingEntry && pendingCard && pendingExpandPanel) {
    cart.push(pendingEntry);
    pendingExpandPanel.classList.remove('open');
    pendingCard.classList.remove('expanding');
    pendingCard.classList.add('in-cart');
    pendingCard.animate([{transform:'scale(0.97)'},{transform:'scale(1)'}], {duration:200, easing:'ease-out'});
    pendingEntry = null;
    pendingCard = null;
    pendingExpandPanel = null;
    updateCartUI();
  }
  closeOrderModeModal();
}

modeTableBtn.addEventListener('click', () => {
  modeTableBtn.classList.add('selected');
  modeDeliveryBtn.classList.remove('selected');
  modeTableForm.style.display = 'block';
  modeDeliveryForm.style.display = 'none';
});

modeDeliveryBtn.addEventListener('click', () => {
  modeDeliveryBtn.classList.add('selected');
  modeTableBtn.classList.remove('selected');
  modeDeliveryForm.style.display = 'block';
  modeTableForm.style.display = 'none';
});

modalTableSelect.addEventListener('change', () => {
  modeTableConfirm.disabled = !modalTableSelect.value;
});

modeTableConfirm.addEventListener('click', () => {
  if (!modalTableSelect.value) return;
  orderMode = 'table';
  setTable(modalTableSelect.value);
  finalizePendingEntry();
});

function validateDelivery() {
  modeDeliveryConfirm.disabled = !deliveryNameInput.value.trim() || !deliveryAddressInput.value.trim();
}
deliveryNameInput.addEventListener('input', validateDelivery);
deliveryAddressInput.addEventListener('input', validateDelivery);

modeDeliveryConfirm.addEventListener('click', () => {
  if (!deliveryNameInput.value.trim() || !deliveryAddressInput.value.trim()) return;
  orderMode = 'delivery';
  deliveryInfo = {
    name: deliveryNameInput.value.trim(),
    address: deliveryAddressInput.value.trim(),
    time: deliveryTimeInput.value || '',
  };
  finalizePendingEntry();
});

orderModeOverlay.addEventListener('click', () => {
  pendingEntry = null;
  pendingCard = null;
  pendingExpandPanel = null;
  closeOrderModeModal();
});

// Initial render
updateCartUI();
</script>
