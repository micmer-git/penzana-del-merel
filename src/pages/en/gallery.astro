---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Gallery — La Penzana del Merel"
  description="Photo gallery of La Penzana del Merel: pizzas, the restaurant, the century-old chestnut tree. A genuine and rustic place in the heart of Valle Seriana."
  lang="en"
  currentPath={`${base}/en/gallery/`}
>
  <section class="hero" style="padding-block:clamp(3rem,8vw,5rem);">
    <div class="container">
      <span class="hero-eyebrow">Gallery</span>
      <h1>Photos</h1>
      <p>Our pizzas, the restaurant, the century-old chestnut tree. A genuine place, every season.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="gallery-placeholder" role="img" aria-label="Photo gallery coming soon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="margin:0 auto 1rem; color:var(--stone-light);">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
        <h2 style="color:var(--stone); font-size:1.3rem; margin-bottom:0.5rem;">Photos coming soon</h2>
        <p style="max-width:400px; margin:0 auto;">
          <!-- TODO: Add real photos from the restaurant -->
          The photo gallery will be updated soon. In the meantime, visit our Facebook page to see the latest photos.
        </p>
        <div style="margin-top:1.5rem;">
          <a href="https://www.facebook.com/LaPenzanaDelMerel/" target="_blank" rel="noopener noreferrer" class="btn btn-green">View photos on Facebook</a>
        </div>
      </div>

      <div class="grid-3" style="margin-top:3rem; opacity:0.3; pointer-events:none;" aria-hidden="true">
        {Array.from({ length: 6 }, (_, i) => (
          <div style="background:var(--stone-xlight); border-radius:var(--radius-lg); aspect-ratio:4/3; display:flex; align-items:center; justify-content:center; color:var(--stone);">
            <span style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;">Photo {i+1}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
