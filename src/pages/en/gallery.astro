---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Gallery — La Penzana del Merel"
  description="Photo gallery of La Penzana del Merel: pizzas, the restaurant, the century-old chestnut tree. A genuine and rustic place in the heart of Valle Seriana."
  lang="en"
  currentPath={`${base}/en/gallery/`}
>
  <section class="hero" style="padding-block:clamp(3rem,8vw,5rem);">
    <div class="container">
      <span class="hero-eyebrow">Gallery</span>
      <h1>Photos</h1>
      <p>Our pizzas, the restaurant, the century-old chestnut tree. A genuine place, every season.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="gallery-grid">

        <figure class="gallery-item gallery-item-wide reveal">
          <img src={`${base}/img/trattoria_alpina_historical_photo.png`} alt="Historical photo of the Trattoria Alpina in Orezzo, the original building with water reflection" loading="lazy" />
          <figcaption>The Trattoria Alpina of Orezzo — the original building, before becoming La Penzana del Merel</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/general_pizza_overview.png`} alt="Two freshly baked pizzas being served, staff wearing Penzana t-shirt" loading="lazy" />
          <figcaption>Freshly baked from our wood-fired oven</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/cucina_tipica.png`} alt="Kitchen scene: cooking traditional Bergamo dishes in large pots" loading="lazy" />
          <figcaption>In the kitchen — polenta, casoncelli and traditional Bergamo cuisine</figcaption>
        </figure>

        <figure class="gallery-item gallery-item-wide reveal">
          <img src={`${base}/img/team_2020.png`} alt="Family and staff group photo with Santa hats, Christmas celebration" loading="lazy" />
          <figcaption>The family and staff — Christmas celebration</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/la_penzana_logo.jpg`} alt="La Penzana del Merel logo with blue, teal and gold geometric shapes" loading="lazy" />
          <figcaption>The Penzana del Merel logo</figcaption>
        </figure>

      </div>

      <div style="margin-top:2.5rem; text-align:center;">
        <a href="https://www.facebook.com/LaPenzanaDelMerel/" target="_blank" rel="noopener noreferrer" class="btn btn-green">More photos on Facebook</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.gallery-item {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--bg-warm);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s var(--ease-out), transform 0.3s var(--ease-out);
}
.gallery-item:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.gallery-item-wide { grid-column: 1 / -1; }
.gallery-item img { width: 100%; height: auto; display: block; object-fit: cover; }
.gallery-item-wide img { max-height: 420px; }
.gallery-item figcaption {
  padding: 0.85rem 1rem;
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.4;
}
@media (max-width: 600px) {
  .gallery-grid { grid-template-columns: 1fr; }
  .gallery-item-wide img { max-height: 280px; }
}
</style>
