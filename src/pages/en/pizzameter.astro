---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 200;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const milestones = [
  { km: 10, label: 'Around Orezzo' },
  { km: 50, label: 'Bergamo plain' },
  { km: 100, label: 'Milan-Brianza area' },
  { km: 250, label: 'Emilia (projection)' },
  { km: 500, label: 'Central Italy (projection)' },
  { km: 800, label: 'Naples (symbolic target)' },
  { km: 1000, label: 'Beyond Naples' },
];

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 1000;
const progressPct = Math.min((totalKm / trackMaxKm) * 100, 100);
---

<BaseLayout
  title="Pizzameter — La Penzana del Merel"
  description="Since 1989: how far would all pizzas from La Penzana go if aligned in a row? A symbolic ride from Orezzo to Naples and beyond."
  lang="en"
  pageType="article"
  currentPath={`${base}/en/pizzameter/`}
>
  <section class="hero" style="padding-block:clamp(3rem,9vw,6rem);">
    <div class="container pizzometro-hero">
      <span class="hero-eyebrow">Pizzameter</span>
      <h1>How far did La Penzana pizzas travel?</h1>
      <p>
        Tarcisio often said that, with all delivered pizzas, they could have reached Naples.
        We made the math with one clear assumption: <strong>since 1989, about 200 pizzas per week</strong>,
        with natural seasonal variation.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container pizzometro-shell">
      <div class="pizzometro-stats">
        <article class="card stat-card"><p>Period</p><strong>{startYear} → {currentYear}</strong></article>
        <article class="card stat-card"><p>Estimated pizzas delivered</p><strong>{pizzasDelivered.toLocaleString('en-US')}</strong></article>
        <article class="card stat-card"><p>Total path (33 cm diameter)</p><strong>{totalKm.toFixed(1)} km</strong></article>
      </div>
      <div class="path-card card">
        <h2>Symbolic path: from Orezzo to Naples (and beyond)</h2>
        <div class="pizza-track" style={`--progress:${progressPct}%;`}>
          {milestones.map((m) => (
            <div class="milestone" style={`left:${(m.km / trackMaxKm) * 100}%;`}>
              <span class="dot"></span><span class="label">{m.km} km · {m.label}</span>
            </div>
          ))}
          <div class="pizza-runner" aria-hidden="true"><span>🍕</span></div>
          <div class="current-marker" style={`left:${progressPct}%;`}><span>Today: {totalKm.toFixed(1)} km</span></div>
        </div>
        <p class="path-foot">At this average pace ({annualKm.toFixed(2)} km/year), the symbolic <strong>Naples threshold (800 km)</strong> would be reached around <strong>{etaNapoli}</strong>.</p>
      </div>
    </div>
  </section>

  <style>
    .pizzometro-hero{max-width:820px}.pizzometro-shell{display:grid;gap:1.2rem}.pizzometro-stats{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.9rem}.stat-card{padding:1rem;border-radius:var(--radius-lg)}.stat-card p{margin:0;font-size:.82rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted)}.stat-card strong{display:block;margin-top:.35rem;color:var(--blue-deep);font-size:clamp(1.1rem,2vw,1.5rem)}.path-card{padding:clamp(1rem,2.5vw,1.5rem);border-radius:var(--radius-lg)}.pizza-track{--track:#d9dee8;position:relative;margin-top:1.25rem;height:240px;border:1px solid var(--slate-xlight);border-radius:var(--radius-lg);background:linear-gradient(to bottom,#fff 0%,#f7f8fb 100%);overflow:hidden}.pizza-track::before{content:'';position:absolute;left:3%;right:3%;top:52%;height:4px;border-radius:999px;background:var(--track)}.pizza-track::after{content:'';position:absolute;left:3%;width:calc((var(--progress)*.94));max-width:94%;top:52%;height:4px;border-radius:999px;background:var(--accent-gold)}.milestone{position:absolute;top:34%;transform:translateX(-50%);text-align:center;width:120px}.milestone .dot{width:10px;height:10px;border-radius:50%;background:var(--blue-deep);display:inline-block;margin-bottom:.45rem}.milestone .label{display:block;color:var(--blue-deep);font-size:.68rem;line-height:1.3;font-weight:600}.pizza-runner{position:absolute;top:57%;left:3%;transform:translate(-50%,-50%);animation:runPizza 14s ease-in-out infinite alternate}.pizza-runner span{display:block;font-size:clamp(1.9rem,4vw,2.6rem);filter:drop-shadow(0 4px 6px rgba(15,23,42,.2))}.current-marker{position:absolute;bottom:18px;transform:translateX(-50%);background:var(--blue-deep);color:var(--white);border-radius:999px;padding:.3rem .7rem;font-size:.72rem;font-weight:700;white-space:nowrap}.path-foot{margin-top:1rem;margin-bottom:0}@keyframes runPizza{from{left:3%}to{left:calc(3% + (var(--progress)*.94))}}@media (max-width:840px){.pizzometro-stats{grid-template-columns:1fr}.pizza-track{height:300px}.milestone{width:90px}.milestone .label{font-size:.62rem}}
  </style>
</BaseLayout>
