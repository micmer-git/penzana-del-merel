  <script is:inline define:vars={{ startYear, annualKm, trackMaxKm, posKmMapJSON: JSON.stringify(posKmMap) }}>
    document.addEventListener('DOMContentLoaded', () => {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const kmCounter = document.getElementById('km-counter');
      const pizzaCounter = document.getElementById('pizza-counter');
      const statAnnual = document.getElementById('stat-annual');
      const etaYear = document.getElementById('eta-year');
      const etaTitleYear = document.getElementById('eta-title-year');
      const etaRemaining = document.getElementById('eta-remaining');
      const formatKm = (value) => Number(value).toFixed(1);
      const formatPizzas = (value) => Math.round(value).toLocaleString('en-US');
      let currentAnnualKm = annualKm;

      // Position-to-km interpolation map
      const posKmMap = JSON.parse(posKmMapJSON);

      function interpolateKm(progressPct) {
        if (posKmMap.length === 0) return progressPct * trackMaxKm / 100;
        if (progressPct <= posKmMap[0].pct) return posKmMap[0].km * (progressPct / Math.max(posKmMap[0].pct, 0.001));
        if (progressPct >= posKmMap[posKmMap.length - 1].pct) return posKmMap[posKmMap.length - 1].km;
        for (let i = 1; i < posKmMap.length; i++) {
          if (progressPct <= posKmMap[i].pct) {
            const prev = posKmMap[i - 1];
            const curr = posKmMap[i];
            const t = (progressPct - prev.pct) / (curr.pct - prev.pct);
            return prev.km + t * (curr.km - prev.km);
          }
        }
        return trackMaxKm;
      }

      const animateNumber = (element, target, duration, formatter) => {
        if (!element) return;
        if (reducedMotion) { element.textContent = formatter(target); return; }
        const start = performance.now();
        const step = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          element.textContent = formatter(target * eased);
          if (progress < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };

      animateNumber(kmCounter, parseFloat(kmCounter?.dataset.target || '0'), 2600, formatKm);
      animateNumber(pizzaCounter, parseFloat(pizzaCounter?.dataset.target || '0'), 2600, formatPizzas);

      // ---- DRIVER TOGGLE ----
      const driverBtns = document.querySelectorAll('.pz-driver__btn');
      const infoBtn = document.getElementById('filometro-info-btn');
      const popup = document.getElementById('filometro-popup');
      const popupClose = document.getElementById('filometro-popup-close');

      function applyMode(mode) {
        if (!kmCounter) return;
        const km = parseFloat(kmCounter.dataset[mode] || kmCounter.dataset.target || '0');
        const pizzas = parseInt(pizzaCounter?.dataset[mode] || '0', 10);
        const annual = parseFloat(statAnnual?.dataset[mode] || '0');
        const eta = parseInt(etaYear?.dataset[mode] || '0', 10);
        const rem = parseFloat(etaRemaining?.dataset[mode] || '0');

        kmCounter.dataset.target = km.toFixed(1);
        kmCounter.textContent = formatKm(km);
        if (pizzaCounter) { pizzaCounter.dataset.target = String(pizzas); pizzaCounter.textContent = formatPizzas(pizzas); }
        if (statAnnual) statAnnual.textContent = formatKm(annual);
        if (etaYear) etaYear.textContent = String(eta);
        if (etaTitleYear) etaTitleYear.textContent = String(eta);
        if (etaRemaining) etaRemaining.textContent = formatKm(rem);
        currentAnnualKm = annual;

        driverBtns.forEach(btn => btn.classList.toggle('is-active', btn.dataset.mode === mode));

        // Update reached/ahead badges
        document.querySelectorAll('.pz-marker[data-km]').forEach(marker => {
          const mkm = parseFloat(marker.dataset.km);
          const reached = marker.querySelector('.pz-marker__badge--reached');
          const future = marker.querySelector('.pz-marker__badge--future');
          if (reached && future) {
            if (mkm <= km) { reached.style.display = ''; future.style.display = 'none'; }
            else { reached.style.display = 'none'; future.style.display = ''; }
          }
        });
      }

      driverBtns.forEach(btn => btn.addEventListener('click', () => applyMode(btn.dataset.mode)));

      if (infoBtn && popup) infoBtn.addEventListener('click', () => popup.toggleAttribute('hidden'));
      if (popupClose && popup) popupClose.addEventListener('click', () => popup.setAttribute('hidden', ''));

      // Reveal markers on scroll
      const markers = Array.from(document.querySelectorAll('.pz-marker:not(.pz-marker--dream)'));
      if (reducedMotion || !('IntersectionObserver' in window)) {
        markers.forEach(m => m.classList.add('is-visible'));
      } else {
        const obs = new IntersectionObserver(entries => {
          entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        markers.forEach(m => obs.observe(m));
      }

      // Reveal dream markers too
      const dreamMarkers = document.querySelectorAll('.pz-beyond__block');
      if (!reducedMotion && 'IntersectionObserver' in window) {
        const dObs = new IntersectionObserver(entries => {
          entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; dObs.unobserve(e.target); } });
        }, { threshold: 0.1 });
        dreamMarkers.forEach(m => { m.style.opacity = '0'; m.style.transform = 'translateY(2rem)'; m.style.transition = 'opacity 0.8s ease, transform 0.8s ease'; dObs.observe(m); });
      }

      // ---- Scroll animation ----
      const journeySection = document.querySelector('.pz-journey');
      const railFill = document.getElementById('journey-line-fill');
      const pizzaBody = document.getElementById('journey-pizza-body');
      const journeyKm = document.getElementById('journey-km-value');
      const journeyUnitLabel = document.getElementById('journey-unit-label');
      const journeyYear = document.getElementById('journey-year-value');
      let ticking = false;

      const formatJourneyDistance = (km) => {
        if (km < 1) { const m = Math.round((km * 1000) / 10) * 10; return { value: m + ' m', label: 'metres travelled' }; }
        return { value: formatKm(km) + ' km', label: 'km travelled' };
      };

      const updateJourney = () => {
        ticking = false;
        if (!journeySection || !railFill || !journeyKm || !journeyYear || !journeyUnitLabel) return;
        const rect = journeySection.getBoundingClientRect();
        const travel = Math.max(rect.height - window.innerHeight, 1);
        const progress = Math.min(Math.max(-rect.top / travel, 0), 1);
        const progressPct = progress * 100;
        const currentKm = interpolateKm(progressPct);
        const distance = formatJourneyDistance(currentKm);
        railFill.style.height = progress * 100 + '%';
        journeyKm.textContent = distance.value;
        journeyUnitLabel.textContent = distance.label;
        journeyYear.textContent = '' + Math.round(startYear + currentKm / currentAnnualKm);
        if (pizzaBody) pizzaBody.style.transform = 'rotate(' + (progress * 1080) + 'deg)';
      };

      const requestJourneyUpdate = () => { if (!ticking) { ticking = true; requestAnimationFrame(updateJourney); } };
      updateJourney();
      window.addEventListener('scroll', requestJourneyUpdate, { passive: true });
      window.addEventListener('resize', requestJourneyUpdate);

      // ---- Toast for added pizzas ----
      const params = new URLSearchParams(window.location.search);
      const addedPizzas = parseInt(params.get('addedPizzas') || '0', 10);
      if (addedPizzas > 0) {
        const toast = document.getElementById('pz-toast');
        const toastText = document.getElementById('pz-toast-text');
        if (toast && toastText) {
          const addedMeters = (addedPizzas * 33 / 100).toFixed(1);
          toastText.textContent = '+' + addedPizzas + ' pizzas ordered! The golden thread grows by ' + addedMeters + ' m';
          toast.removeAttribute('hidden');
          requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('is-visible'); }); });
          setTimeout(() => {
            toast.classList.remove('is-visible');
            setTimeout(() => {
              toast.setAttribute('hidden', '');
              const storedWaUrl = sessionStorage.getItem('pz_wa_url');
              if (storedWaUrl) {
                sessionStorage.removeItem('pz_wa_url');
                const link = document.createElement('a');
                link.href = storedWaUrl; link.target = '_blank'; link.rel = 'noopener noreferrer';
                link.style.position = 'fixed'; link.style.opacity = '0';
                document.body.appendChild(link); link.click();
                setTimeout(() => link.remove(), 200);
              }
            }, 500);
          }, 4600);
        }
      }
    });
  </script>

</BaseLayout>
