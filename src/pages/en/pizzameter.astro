---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 300;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 900;

// --- Driver models ---
const familyEntries = [
  { name: 'Michele', year: 1994 + 4 },
  { name: 'Luca', year: 1995 + 4 },
  { name: 'Alessandro', year: 1998 + 4 },
  { name: 'Giacomo', year: 2004 + 4 },
  { name: 'Chiara', year: 2007 + 4 },
];

function weeksBetween(from: Date, to: Date) {
  return Math.max(0, Math.floor((to.getTime() - from.getTime()) / (1000 * 60 * 60 * 24 * 7)));
}

function computeBrunoModel(nowDate: Date) {
  const perWeek = 5;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeFamilyModel(nowDate: Date) {
  let pizzas = 0;
  let last = new Date(startYear, 0, 1);
  let people = 3;
  const perPerson = 3;
  const sorted = [...familyEntries].sort((a, b) => a.year - b.year);

  for (const e of sorted) {
    const eventDate = new Date(e.year, 0, 1);
    if (eventDate > nowDate) break;
    pizzas += weeksBetween(last, eventDate) * people * perPerson;
    people += 1;
    last = eventDate;
  }

  pizzas += weeksBetween(last, nowDate) * people * perPerson;
  const perWeekNow = people * perPerson;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeekNow * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeekNow, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

const brunoModel = computeBrunoModel(now);
const familyModel = computeFamilyModel(now);

const milestones = [
  { km: 0, label: 'La Penzana (Orezzo)', desc: 'Where it all began: oven lit, dough ready, the journey begins.', icon: '🏠', year: 1989, fun: 'Pizza number one: probably burnt. But made with love.' },
  { km: 3, label: 'Gazzaniga', desc: 'Three kilometres of pizza. The aroma reaches the next town.', icon: '⛰️', year: Math.round(startYear + 3 / annualKm), fun: 'The whole valley knows it\'s pizza night.' },
  { km: 12, label: 'Bergamo — Città Alta', desc: 'The Venetian walls conquered, dough by dough.', icon: '🏰', year: Math.round(startYear + 12 / annualKm), fun: 'A pizza as wide as Piazza Vecchia? Almost there.' },
  { km: 42.2, label: 'The Pizza Marathon', desc: '42,195 km of rolled-out dough. A marathon without shoes, just flour.', icon: '🏃', year: Math.round(startYear + 42.2 / annualKm), fun: 'Kipchoge runs 42 km in 2 hours. We took a few years.' },
  { km: 60, label: 'Milan — The Duomo', desc: 'Under the gaze of the Madonnina, the golden thread shines.', icon: '🏛️', year: Math.round(startYear + 60 / annualKm), fun: 'Milan asks: "Is it gourmet?" Us: "It\'s good."' },
  { km: 130, label: 'Piacenza', desc: 'Where Emilia begins. Land of cured meats, tortelli, and dough respect.', icon: '🧀', year: Math.round(startYear + 130 / annualKm), fun: 'Piacenza approves: pizza with stracchino works.' },
  { km: 180, label: 'Parma', desc: 'Parmigiano and prosciutto: ingredients that speak for themselves.', icon: '🍖', year: Math.round(startYear + 180 / annualKm), fun: 'Verdi composed operas. We compose pizzas. Same passion.' },
  { km: 260, label: 'Bologna — The Two Towers', desc: 'La dotta, la grassa, la rossa. The golden thread crosses Italy\'s heart.', icon: '🏗️', year: Math.round(startYear + 260 / annualKm), fun: 'Bologna has tortellini. We have Diavola. Peace made.' },
  { km: 360, label: 'Florence — Ponte Vecchio', desc: 'Renaissance and pizza: two Italian excellences that never go out of style.', icon: '🎨', year: Math.round(startYear + 360 / annualKm), fun: 'Leonardo would have invented a dough-rolling machine.' },
  { km: 430, label: 'Siena — Piazza del Campo', desc: 'Halfway through the Palio, the golden thread crosses the contrade.', icon: '🐎', year: Math.round(startYear + 430 / annualKm), fun: 'The Palio lasts 90 seconds. A pizza rises for 24 hours. Who wins?' },
  { km: 500, label: 'Orvieto', desc: 'Half a thousand kilometres. The cathedral watches from above.', icon: '⛪', year: Math.round(startYear + 500 / annualKm), fun: '500 km = 1,515,151 pizzas. Give or take.' },
  { km: 560, label: 'Rome — The Colosseum', desc: 'All threads lead to Rome. The Colosseum saw gladiators; we bake pizzas.', icon: '🏟️', year: Math.round(startYear + 560 / annualKm), fun: '"Thumbs up" said the crowd. Also for our Margherita.' },
  { km: 650, label: 'Cassino — Abbey of Montecassino', desc: 'Between history and spirituality, the golden thread continues south.', icon: '📿', year: Math.round(startYear + 650 / annualKm), fun: 'The monks made bread. We make pizza. Evolution.' },
  { km: 720, label: 'Caserta — The Royal Palace', desc: 'The palace of kings. Pizza is democratic: the same for everyone.', icon: '👑', year: Math.round(startYear + 720 / annualKm), fun: 'The Palace has 1,200 rooms. We have 1 oven. Enough.' },
  { km: 780, label: 'Aversa', desc: 'The last stop before Naples. Tension rises, dough rises too.', icon: '🔥', year: Math.round(startYear + 780 / annualKm), fun: 'You can already smell Vesuvius. Or is that our oven?' },
  { km: 800, label: 'Naples — Via dei Tribunali', desc: 'The homeland of pizza. The golden thread has reached home.', icon: '🌋', isTarget: true, year: Math.round(startYear + 800 / annualKm), fun: 'Tarcisio was right. We made it.' },
];
---

<BaseLayout
  title="Pizzameter — The Golden Thread"
  description="Since 1989: how far would all pizzas from La Penzana go if aligned in a row? A scrollytelling journey from Orezzo to Naples."
  lang="en"
  pageType="website"
  currentPath={`${base}/en/pizzameter/`}
>

  <!-- Hero: animated km counter -->
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">The Golden Thread</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzameter</span>
      </h1>
      <p class="pz-hero__subtitle">
        Since {startYear}, every pizza baked adds 33 cm to our golden thread.<br />
        Tarcisio used to say: <em>"We'll make it all the way to Naples."</em>
      </p>
      <div class="pz-driver" aria-label="Filometro driver selector">
        <span class="pz-driver__label">Who drives the filometro?</span>
        <div class="pz-driver__controls">
          <button type="button" class="pz-driver__btn is-active" data-mode="bruno" id="driver-btn-bruno">Bruno</button>
          <button type="button" class="pz-driver__btn" data-mode="family" id="driver-btn-family">Merelli Family</button>
          <button type="button" class="pz-driver__info" id="filometro-info-btn" aria-label="Formula info">i</button>
        </div>
        <div class="pz-driver__popup" id="filometro-popup" hidden>
          <button type="button" class="pz-driver__close" id="filometro-popup-close" aria-label="Close">&times;</button>
          <strong>Bruno</strong> — loyal customer, 5 pizzas per week since 1989.<br/>
          <strong>Merelli Family</strong> — 3 people &times; 3 pizzas/week, then +1 person (and +3 pizzas/week) for each child after age 4: Michele (1998), Luca (1999), Alessandro (2002), Giacomo (2008), Chiara (2011).
        </div>
      </div>

      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter"
          data-target={brunoModel.totalKm.toFixed(1)}
          data-bruno={brunoModel.totalKm.toFixed(1)}
          data-family={familyModel.totalKm.toFixed(1)}>0</span>
        <span class="pz-hero__unit">km travelled</span>
      </div>
      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value"><span id="stat-pizzas"
            data-bruno={brunoModel.pizzasDelivered}
            data-family={familyModel.pizzasDelivered}>{brunoModel.pizzasDelivered.toLocaleString('en-US')}</span></span>
          <span class="pz-hero__stat-label">pizzas baked</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} &mdash; {currentYear}</span>
          <span class="pz-hero__stat-label">years of tradition</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value"><span id="stat-annual"
            data-bruno={brunoModel.annualKm.toFixed(1)}
            data-family={familyModel.annualKm.toFixed(1)}>{brunoModel.annualKm.toFixed(1)}</span> km</span>
          <span class="pz-hero__stat-label">every year</span>
        </div>
      </div>
      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scroll to travel</span>
      </div>
    </div>
  </section>

  <!-- Scrollytelling: CENTERED timeline with proportional milestones -->
  <section class="pz-journey" aria-label="Symbolic journey from Orezzo to Naples">
    <div class="pz-journey__container">
      <div class="pz-journey__timeline">
        <div class="pz-journey__rail">
          <div class="pz-journey__rail-fill" id="journey-line-fill"></div>
        </div>
        <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
          <svg viewBox="0 0 56 56" width="56" height="56" xmlns="http://www.w3.org/2000/svg">
            <path d="M28 4 L50 46 Q28 52 6 46 Z" fill="#f6d400" stroke="var(--blue-deep)" stroke-width="2" stroke-linejoin="round"/>
            <path d="M6 46 Q28 52 50 46" fill="#e2be00" stroke="var(--blue-deep)" stroke-width="2"/>
            <circle cx="24" cy="22" r="3.5" fill="#dc2626" opacity="0.9"/>
            <circle cx="33" cy="28" r="3" fill="#dc2626" opacity="0.85"/>
            <circle cx="22" cy="34" r="2.8" fill="#dc2626" opacity="0.85"/>
            <circle cx="28" cy="16" r="2" fill="#16a34a" opacity="0.7"/>
            <circle cx="18" cy="28" r="1.8" fill="#16a34a" opacity="0.7"/>
            <circle cx="34" cy="38" r="2.2" fill="#f5f5dc" opacity="0.6"/>
          </svg>
        </div>
        <div class="pz-journey__counter-float" id="journey-counter-float">
          <span class="pz-journey__counter-km" id="journey-km-value">0</span>
          <span class="pz-journey__counter-label">km</span>
          <span class="pz-journey__counter-year" id="journey-year-value">{startYear}</span>
        </div>

        {milestones.map((m, i) => {
          const pct = (m.km / trackMaxKm) * 100;
          const side = i % 2 === 0 ? 'left' : 'right';
          return (
            <div
              class={`pz-marker pz-marker--${side} ${m.isTarget ? 'pz-marker--target' : ''}`}
              style={`top: ${pct}%`}
              data-km={m.km}
              data-year={m.year}
              data-index={i}
            >
              <div class="pz-marker__dot">
                <span class="pz-marker__icon">{m.icon}</span>
              </div>
              <div class="pz-marker__card">
                <div class="pz-marker__meta">
                  <span class="pz-marker__km-tag">{m.km} km</span>
                  <span class="pz-marker__year-tag">~{m.year}</span>
                  {m.km <= totalKm ? (
                    <span class="pz-marker__badge pz-marker__badge--reached">✓</span>
                  ) : (
                    <span class="pz-marker__badge pz-marker__badge--future">…</span>
                  )}
                </div>
                <h3 class="pz-marker__title">{m.label}</h3>
                <p class="pz-marker__desc">{m.desc}</p>
                <p class="pz-marker__fun">{m.fun}</p>
              </div>
            </div>
          );
        })}

        <div class="pz-marker pz-marker--left pz-marker--eta" style={`top: 100%`} data-km={trackMaxKm} data-year={etaNapoli} data-index={milestones.length}>
          <div class="pz-marker__dot"><span class="pz-marker__icon">🎯</span></div>
          <div class="pz-marker__card">
            <div class="pz-marker__meta">
              <span class="pz-marker__km-tag">Estimated arrival</span>
              <span class="pz-marker__year-tag">~<span id="eta-year"
                data-bruno={brunoModel.etaNapoli}
                data-family={familyModel.etaNapoli}>{etaNapoli}</span></span>
            </div>
            <h3 class="pz-marker__title">Naples — Year <span id="eta-title-year">{etaNapoli}</span></h3>
            <p class="pz-marker__desc">
              <span id="eta-remaining"
                data-bruno={Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1)}
                data-family={Math.max(0, (napoliDistanceKm - familyModel.totalKm)).toFixed(1)}>{Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1)}</span> km remain. Every pizza shortens the journey by 33 cm.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Post-order toast -->
  <div class="pz-toast" id="pz-toast" role="alert" aria-live="assertive" hidden>
    <span class="pz-toast__icon">🍕</span>
    <span class="pz-toast__text" id="pz-toast-text"></span>
  </div>

  <style>
    /* ============================================
       PIZZOMETER — THE GOLDEN THREAD
       Scrollytelling experience
       ============================================ */

    /* -- Hero -- */
    .pz-hero {
      min-height: 100svh;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      color: var(--text);
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .pz-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 20%, rgba(220,38,38,0.04) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 80%, rgba(220,38,38,0.06) 0%, transparent 50%);
      pointer-events: none;
    }
    /* Grain */
    .pz-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 150px;
      pointer-events: none;
      opacity: 0.15;
    }

    .pz-hero__inner {
      position: relative;
      z-index: 2;
      padding: 2rem clamp(1.25rem, 5vw, 3rem);
      max-width: 800px;
    }

    .pz-hero__kicker {
      display: inline-block;
      font-family: var(--font-subline);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #dc2626;
      margin-bottom: 1rem;
    }

    .pz-hero__title {
      color: #991b1b;
      margin-bottom: 1.5rem;
    }
    .pz-hero__script {
      font-family: var(--font-script);
      font-weight: 400;
      font-size: clamp(3.5rem, 10vw, 7rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      color: #991b1b;
    }

    .pz-hero__subtitle {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }
    .pz-hero__subtitle em {
      color: #dc2626;
      font-family: var(--font-display);
    }

    /* Counter */
    .pz-hero__counter {
      margin-bottom: 2.5rem;
    }
    .pz-hero__number {
      display: block;
      font-family: var(--font-display);
      font-size: clamp(4rem, 12vw, 8rem);
      font-weight: 800;
      color: #dc2626;
      line-height: 1;
      letter-spacing: -0.03em;
      text-shadow: 0 0 60px rgba(220,38,38,0.15);
    }
    .pz-hero__unit {
      display: block;
      font-family: var(--font-subline);
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    /* Stats row — always inline */
    .pz-hero__stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .pz-hero__stat {
      text-align: center;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.68);
      border: 2px solid rgba(220,38,38,0.15);
    }
    .pz-hero__stat-value {
      display: block;
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 700;
      color: #991b1b;
    }
    .pz-hero__stat-label {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 0.2rem;
    }

    /* Driver toggle */
    .pz-driver { margin: 0 auto 1.5rem; max-width: 680px; text-align: center; }
    .pz-driver__label { display: block; margin-bottom: 0.5rem; font-family: var(--font-subline, sans-serif); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #991b1b; }
    .pz-driver__controls { display: flex; align-items: center; gap: 0.5rem; justify-content: center; position: relative; }
    .pz-driver__btn { padding: 0.55rem 1.1rem; border: 2px solid rgba(220,38,38,0.25); background: rgba(255, 255, 255, 0.7); font-family: var(--font-subline, sans-serif); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); cursor: pointer; transition: all 0.25s ease; }
    .pz-driver__btn:hover { border-color: #dc2626; color: #dc2626; }
    .pz-driver__btn.is-active { background: #dc2626; border-color: #dc2626; color: #fff; }
    .pz-driver__info { width: 30px; height: 30px; border-radius: 50%; border: 2px solid #dc2626; background: rgba(255, 255, 255, 0.7); color: #dc2626; font-weight: 800; font-size: 0.85rem; cursor: pointer; flex-shrink: 0; }
    .pz-driver__popup { position: absolute; top: 42px; right: 0; max-width: 480px; text-align: left; padding: 0.85rem 1rem; border: 2px solid #dc2626; background: rgba(255, 255, 255, 0.96); color: #991b1b; font-size: 0.82rem; line-height: 1.55; box-shadow: 4px 4px 0 rgba(220,38,38,0.2); z-index: 20; }
    .pz-driver__close { position: absolute; right: 6px; top: 2px; border: 0; background: transparent; color: #991b1b; font-size: 1.15rem; cursor: pointer; }

    /* Scroll hint */
    .pz-hero__scroll-hint {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: rgba(220,38,38,0.35);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      animation: pzBounce 2s ease-in-out infinite;
    }
    .pz-hero__scroll-hint svg {
      stroke: #dc2626;
      opacity: 0.4;
    }
    @keyframes pzBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(8px); }
    }

    /* ============================================
       JOURNEY — Centered Timeline
       ============================================ */
    .pz-journey {
      background: var(--bg);
      position: relative;
      padding-block: clamp(4rem, 10vw, 8rem) clamp(6rem, 15vw, 12rem);
    }

    .pz-journey__container {
      max-width: var(--max-width);
      margin-inline: auto;
      padding-inline: clamp(1.25rem, 5vw, 3rem);
    }

    /* Central timeline rail */
    .pz-journey__timeline {
      position: relative;
      min-height: 6000px;
    }

    .pz-journey__rail {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 4px;
      background: rgba(220,38,38,0.12);
      transform: translateX(-50%);
      border-radius: 999px;
    }
    .pz-journey__rail-fill {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 0%;
      background: linear-gradient(to bottom, #dc2626, #991b1b);
      border-radius: 999px;
      transition: height 0.1s linear;
    }

    /* Pizza slice driver */
    .pz-journey__pizza {
      position: sticky;
      top: 50vh;
      left: 50%;
      width: 56px;
      height: 56px;
      margin-left: -28px;
      z-index: 10;
      filter: drop-shadow(0 4px 16px rgba(220,38,38,0.25));
      transition: transform 0.1s linear;
      pointer-events: none;
    }

    /* Floating km/year counter */
    .pz-journey__counter-float {
      position: sticky;
      top: calc(50vh + 70px);
      left: 50%;
      transform: translateX(-50%);
      width: max-content;
      text-align: center;
      z-index: 10;
      pointer-events: none;
      background: var(--bg);
      padding: 0.35rem 0.75rem;
      border-radius: 999px;
      border: 2px solid #dc2626;
    }
    .pz-journey__counter-km {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 800;
      color: #dc2626;
    }
    .pz-journey__counter-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-right: 0.5rem;
    }
    .pz-journey__counter-year {
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--text-muted);
    }

    /* Milestone markers */
    .pz-marker {
      position: absolute;
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      width: 50%;
      opacity: 0;
      transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
    }

    /* Left-side milestones */
    .pz-marker--left {
      right: 50%;
      padding-right: 2rem;
      flex-direction: row-reverse;
      text-align: right;
      transform: translateX(-30px);
    }
    .pz-marker--left.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Right-side milestones */
    .pz-marker--right {
      left: 50%;
      padding-left: 2rem;
      transform: translateX(30px);
    }
    .pz-marker--right.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Dot on the rail */
    .pz-marker__dot {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--bg);
      border: 3px solid #dc2626;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      z-index: 5;
      transition: background 0.3s, transform 0.3s var(--ease-spring);
    }
    .pz-marker.is-visible .pz-marker__dot {
      background: #fef2f2;
      transform: scale(1.1);
    }
    .pz-marker__icon {
      line-height: 1;
    }

    /* Card */
    .pz-marker__card {
      background: var(--white);
      border: 2px solid rgba(220,38,38,0.15);
      padding: clamp(0.75rem, 2vw, 1.25rem);
      border-radius: 0;
      max-width: 380px;
      transition: border-color 0.4s, box-shadow 0.4s;
    }
    .pz-marker.is-visible .pz-marker__card {
      border-color: #dc2626;
      box-shadow: 4px 4px 0 rgba(220,38,38,0.15);
    }

    .pz-marker__meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
      flex-wrap: wrap;
    }
    .pz-marker--left .pz-marker__meta {
      justify-content: flex-end;
    }
    .pz-marker__km-tag {
      font-family: var(--font-subline);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #dc2626;
    }
    .pz-marker__year-tag {
      font-family: var(--font-display);
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--text-muted);
    }
    .pz-marker__badge {
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.1rem 0.4rem;
      border-radius: 0;
      font-family: var(--font-subline);
    }
    .pz-marker__badge--reached {
      background: rgba(22,163,74,0.12);
      color: #16a34a;
      border: 1px solid rgba(22,163,74,0.25);
    }
    .pz-marker__badge--future {
      background: rgba(220,38,38,0.08);
      color: #dc2626;
      border: 1px solid rgba(220,38,38,0.15);
    }

    .pz-marker__title {
      font-family: var(--font-display);
      font-size: clamp(1rem, 2vw, 1.35rem);
      font-weight: 700;
      color: #991b1b;
      margin-bottom: 0.3rem;
      line-height: 1.2;
    }
    .pz-marker__desc {
      font-size: 0.85rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-bottom: 0.25rem;
    }
    .pz-marker__fun {
      font-family: var(--font-script);
      font-size: 1.1rem;
      color: #dc2626;
      line-height: 1.3;
      opacity: 0.8;
    }

    /* Target milestone (Napoli) */
    .pz-marker--target.is-visible .pz-marker__card {
      box-shadow: 0 0 30px rgba(220,38,38,0.12), 4px 4px 0 rgba(220,38,38,0.2);
      border-color: #991b1b;
    }
    .pz-marker--target .pz-marker__title {
      color: #dc2626;
    }
    .pz-marker--target.is-visible .pz-marker__dot {
      background: #dc2626;
      border-color: #991b1b;
    }
    .pz-marker--target.is-visible .pz-marker__icon {
      filter: grayscale(0);
    }

    /* ETA card */
    .pz-marker--eta.is-visible .pz-marker__card {
      background: #fef2f2;
      border-color: rgba(220,38,38,0.3);
    }

    /* ============================================
       POST-ORDER TOAST
       ============================================ */
    .pz-toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(120%);
      background: #dc2626;
      color: var(--white);
      padding: 0.8rem 1.5rem;
      border: 2px solid #991b1b;
      font-size: 0.9rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      z-index: var(--z-modal);
      box-shadow: 6px 6px 0 #991b1b;
      transition: transform 0.5s var(--ease-spring);
      white-space: nowrap;
    }
    .pz-toast.is-visible {
      transform: translateX(-50%) translateY(0);
    }
    .pz-toast__icon {
      font-size: 1.3rem;
    }

    /* ============================================
       MOBILE RESPONSIVE
       ============================================ */
    @media (max-width: 768px) {
      .pz-journey__timeline {
        min-height: 4000px;
      }
      .pz-journey__rail {
        left: 24px;
        transform: none;
      }
      .pz-journey__pizza {
        left: 24px;
        margin-left: -28px;
      }
      .pz-journey__counter-float {
        left: 24px;
        transform: none;
        margin-left: 40px;
        font-size: 0.8rem;
      }
      /* All markers go right on mobile */
      .pz-marker,
      .pz-marker--left,
      .pz-marker--right {
        left: 24px;
        right: auto;
        width: calc(100% - 24px);
        padding-left: 2.5rem;
        padding-right: 0;
        flex-direction: row;
        text-align: left;
        transform: translateX(30px);
      }
      .pz-marker--left.is-visible,
      .pz-marker--right.is-visible {
        transform: translateX(0);
      }
      .pz-marker--left .pz-marker__meta {
        justify-content: flex-start;
      }
      .pz-marker__card {
        max-width: none;
      }
      .pz-marker__dot {
        width: 36px;
        height: 36px;
        font-size: 1.1rem;
      }
      .pz-hero__stat { padding: 0.65rem 0.5rem; }
      .pz-hero__stat-value { font-size: 1rem; }
      .pz-hero__stat-label { font-size: 0.62rem; }
      .pz-driver__btn { padding: 0.45rem 0.7rem; font-size: 0.68rem; }
      .pz-driver__popup { max-width: calc(100vw - 3rem); left: 0; right: 0; }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .pz-marker {
        opacity: 1;
        transform: none !important;
      }
      .pz-hero__scroll-hint {
        animation: none;
      }
      .pz-journey__pizza,
      .pz-journey__rail-fill {
        transition: none;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var kmCounter = document.getElementById('km-counter');
      var statPizzas = document.getElementById('stat-pizzas');
      var statAnnual = document.getElementById('stat-annual');
      var etaYear = document.getElementById('eta-year');
      var etaTitleYear = document.getElementById('eta-title-year');
      var etaRemaining = document.getElementById('eta-remaining');
      var startYr = 1989;
      var maxKm = 900;
      var currentAnnualKm = (52 * 300 * 33) / 100000;

      var formatKm = function(v) { return Number(v).toFixed(1); };
      var formatPizzas = function(v) { return Math.round(v).toLocaleString('en-US'); };

      // ---- HERO COUNTER ANIMATION ----
      if (kmCounter) {
        var target = parseFloat(kmCounter.dataset.target);
        if (reducedMotion) {
          kmCounter.textContent = formatKm(target);
        } else {
          var duration = 2500;
          var animStart = performance.now();
          function animateCounter(now) {
            var elapsed = now - animStart;
            var progress = Math.min(elapsed / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            kmCounter.textContent = formatKm(eased * target);
            if (progress < 1) requestAnimationFrame(animateCounter);
          }
          requestAnimationFrame(animateCounter);
        }
      }

      // ---- DRIVER TOGGLE ----
      var driverBtns = document.querySelectorAll('.pz-driver__btn');
      var infoBtn = document.getElementById('filometro-info-btn');
      var popup = document.getElementById('filometro-popup');
      var popupClose = document.getElementById('filometro-popup-close');

      function applyMode(mode) {
        if (!kmCounter) return;
        var km = parseFloat(kmCounter.dataset[mode] || kmCounter.dataset.target || '0');
        var pizzas = parseInt((statPizzas && statPizzas.dataset[mode]) || '0', 10);
        var annual = parseFloat((statAnnual && statAnnual.dataset[mode]) || '0');
        var eta = parseInt((etaYear && etaYear.dataset[mode]) || '0', 10);
        var rem = parseFloat((etaRemaining && etaRemaining.dataset[mode]) || '0');

        kmCounter.dataset.target = km.toFixed(1);
        kmCounter.textContent = formatKm(km);
        if (statPizzas) statPizzas.textContent = formatPizzas(pizzas);
        if (statAnnual) statAnnual.textContent = formatKm(annual);
        if (etaYear) etaYear.textContent = String(eta);
        if (etaTitleYear) etaTitleYear.textContent = String(eta);
        if (etaRemaining) etaRemaining.textContent = rem.toFixed(1);
        currentAnnualKm = annual;

        driverBtns.forEach(function(btn) {
          btn.classList.toggle('is-active', btn.dataset.mode === mode);
        });
      }

      driverBtns.forEach(function(btn) {
        btn.addEventListener('click', function() { applyMode(btn.dataset.mode); });
      });

      if (infoBtn && popup) {
        infoBtn.addEventListener('click', function() { popup.toggleAttribute('hidden'); });
      }
      if (popupClose && popup) {
        popupClose.addEventListener('click', function() { popup.setAttribute('hidden', ''); });
      }

      // ---- SCROLL: MARKERS + JOURNEY ----
      var markers = document.querySelectorAll('.pz-marker');
      if (reducedMotion) {
        markers.forEach(function(el) { el.classList.add('is-visible'); });
      } else {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        markers.forEach(function(el) { observer.observe(el); });
      }

      var journeySection = document.querySelector('.pz-journey');
      var railFill = document.getElementById('journey-line-fill');
      var pizza = document.getElementById('journey-pizza');
      var kmValue = document.getElementById('journey-km-value');
      var yearValue = document.getElementById('journey-year-value');
      var ticking = false;

      function updateJourney() {
        ticking = false;
        if (!journeySection || !railFill || !kmValue) return;
        var rect = journeySection.getBoundingClientRect();
        var travel = Math.max(rect.height - window.innerHeight, 1);
        var progress = Math.min(Math.max(-rect.top / travel, 0), 1);
        var currentKm = progress * maxKm;
        railFill.style.height = (progress * 100) + '%';
        kmValue.textContent = Math.round(currentKm);
        if (yearValue) yearValue.textContent = Math.round(startYr + currentKm / currentAnnualKm);
        if (pizza) pizza.style.transform = 'rotate(' + (progress * 1080) + 'deg)';
      }

      function requestUpdate() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateJourney);
      }

      updateJourney();
      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);

      // ---- POST-ORDER TOAST ----
      var params = new URLSearchParams(window.location.search);
      var addedPizzas = parseInt(params.get('addedPizzas') || '0', 10);
      if (addedPizzas > 0) {
        var toast = document.getElementById('pz-toast');
        var toastText = document.getElementById('pz-toast-text');
        if (toast && toastText) {
          var addedMeters = (addedPizzas * 33 / 100).toFixed(1);
          toastText.textContent = '+' + addedPizzas + ' pizzas ordered! The golden thread grows by ' + addedMeters + ' m';
          toast.removeAttribute('hidden');
          requestAnimationFrame(function() { requestAnimationFrame(function() { toast.classList.add('is-visible'); }); });
          setTimeout(function() {
            toast.classList.remove('is-visible');
            setTimeout(function() { toast.setAttribute('hidden', ''); }, 500);
          }, 4600);
        }
      }
    });
  </script>

</BaseLayout>
