---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 300;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 900;

const milestones = [
  { km: 0, label: 'La Penzana (Orezzo)', desc: 'Where it all began: oven lit, dough ready, the journey begins.', icon: '🏠', year: 1989, fun: 'Pizza number one: probably burnt. But made with love.' },
  { km: 3, label: 'Gazzaniga', desc: 'Three kilometres of pizza. The aroma reaches the next town.', icon: '⛰️', year: Math.round(startYear + 3 / annualKm), fun: 'The whole valley knows it\'s pizza night.' },
  { km: 12, label: 'Bergamo — Città Alta', desc: 'The Venetian walls conquered, dough by dough.', icon: '🏰', year: Math.round(startYear + 12 / annualKm), fun: 'A pizza as wide as Piazza Vecchia? Almost there.' },
  { km: 42.2, label: 'The Pizza Marathon', desc: '42,195 km of rolled-out dough. A marathon without shoes, just flour.', icon: '🏃', year: Math.round(startYear + 42.2 / annualKm), fun: 'Kipchoge runs 42 km in 2 hours. We took a few years.' },
  { km: 60, label: 'Milan — The Duomo', desc: 'Under the gaze of the Madonnina, the golden thread shines.', icon: '🏛️', year: Math.round(startYear + 60 / annualKm), fun: 'Milan asks: "Is it gourmet?" Us: "It\'s good."' },
  { km: 130, label: 'Piacenza', desc: 'Where Emilia begins. Land of cured meats, tortelli, and dough respect.', icon: '🧀', year: Math.round(startYear + 130 / annualKm), fun: 'Piacenza approves: pizza with stracchino works.' },
  { km: 180, label: 'Parma', desc: 'Parmigiano and prosciutto: ingredients that speak for themselves.', icon: '🍖', year: Math.round(startYear + 180 / annualKm), fun: 'Verdi composed operas. We compose pizzas. Same passion.' },
  { km: 260, label: 'Bologna — The Two Towers', desc: 'La dotta, la grassa, la rossa. The golden thread crosses Italy\'s heart.', icon: '🏗️', year: Math.round(startYear + 260 / annualKm), fun: 'Bologna has tortellini. We have Diavola. Peace made.' },
  { km: 360, label: 'Florence — Ponte Vecchio', desc: 'Renaissance and pizza: two Italian excellences that never go out of style.', icon: '🎨', year: Math.round(startYear + 360 / annualKm), fun: 'Leonardo would have invented a dough-rolling machine.' },
  { km: 430, label: 'Siena — Piazza del Campo', desc: 'Halfway through the Palio, the golden thread crosses the contrade.', icon: '🐎', year: Math.round(startYear + 430 / annualKm), fun: 'The Palio lasts 90 seconds. A pizza rises for 24 hours. Who wins?' },
  { km: 500, label: 'Orvieto', desc: 'Half a thousand kilometres. The cathedral watches from above.', icon: '⛪', year: Math.round(startYear + 500 / annualKm), fun: '500 km = 1,515,151 pizzas. Give or take.' },
  { km: 560, label: 'Rome — The Colosseum', desc: 'All threads lead to Rome. The Colosseum saw gladiators; we bake pizzas.', icon: '🏟️', year: Math.round(startYear + 560 / annualKm), fun: '"Thumbs up" said the crowd. Also for our Margherita.' },
  { km: 650, label: 'Cassino — Abbey of Montecassino', desc: 'Between history and spirituality, the golden thread continues south.', icon: '📿', year: Math.round(startYear + 650 / annualKm), fun: 'The monks made bread. We make pizza. Evolution.' },
  { km: 720, label: 'Caserta — The Royal Palace', desc: 'The palace of kings. Pizza is democratic: the same for everyone.', icon: '👑', year: Math.round(startYear + 720 / annualKm), fun: 'The Palace has 1,200 rooms. We have 1 oven. Enough.' },
  { km: 780, label: 'Aversa', desc: 'The last stop before Naples. Tension rises, dough rises too.', icon: '🔥', year: Math.round(startYear + 780 / annualKm), fun: 'You can already smell Vesuvius. Or is that our oven?' },
  { km: 800, label: 'Naples — Via dei Tribunali', desc: 'The homeland of pizza. The golden thread has reached home.', icon: '🌋', isTarget: true, year: Math.round(startYear + 800 / annualKm), fun: 'Tarcisio was right. We made it.' },
];
---

<BaseLayout
  title="Pizzameter — The Golden Thread"
  description="Since 1989: how far would all pizzas from La Penzana go if aligned in a row? A scrollytelling journey from Orezzo to Naples."
  lang="en"
  pageType="website"
  currentPath={`${base}/en/pizzameter/`}
>

  <!-- Hero: animated km counter -->
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">The Golden Thread</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzameter</span>
      </h1>
      <p class="pz-hero__subtitle">
        Since {startYear}, every pizza baked adds 33 cm to our golden thread.<br />
        Tarcisio used to say: <em>"We'll make it all the way to Naples."</em>
      </p>
      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter" data-target={totalKm.toFixed(1)}>0</span>
        <span class="pz-hero__unit">km travelled</span>
      </div>
      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{pizzasDelivered.toLocaleString('en-US')}</span>
          <span class="pz-hero__stat-label">pizzas baked</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} — {currentYear}</span>
          <span class="pz-hero__stat-label">years of tradition</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{annualKm.toFixed(1)} km</span>
          <span class="pz-hero__stat-label">every year</span>
        </div>
      </div>
      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scroll to travel</span>
      </div>
    </div>
  </section>

  <!-- Scrollytelling: sticky tracker + milestone cards -->
  <section class="pz-journey" aria-label="Symbolic journey from Orezzo to Naples">
    <div class="pz-journey__container">

      <!-- Sticky left tracker -->
      <div class="pz-journey__tracker">
        <div class="pz-journey__line">
          <div class="pz-journey__line-fill" id="journey-line-fill"></div>
          <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
            <svg viewBox="0 0 48 48" width="48" height="48" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" fill="#f6d400" stroke="#101e8f" stroke-width="2"/>
              <circle cx="16" cy="18" r="3" fill="#dc2626" opacity="0.85"/>
              <circle cx="28" cy="14" r="2.5" fill="#dc2626" opacity="0.85"/>
              <circle cx="20" cy="28" r="2.8" fill="#dc2626" opacity="0.85"/>
              <circle cx="32" cy="26" r="2" fill="#dc2626" opacity="0.85"/>
              <circle cx="24" cy="22" r="2.2" fill="#16a34a" opacity="0.7"/>
              <circle cx="14" cy="26" r="1.5" fill="#16a34a" opacity="0.7"/>
              <circle cx="30" cy="32" r="1.8" fill="#16a34a" opacity="0.7"/>
            </svg>
          </div>
        </div>
        <div class="pz-journey__km-display" id="journey-km-display">
          <span class="pz-journey__km-value" id="journey-km-value">0</span>
          <span class="pz-journey__km-label">km</span>
        </div>
      </div>

      <!-- Milestone cards -->
      <div class="pz-journey__milestones">
        {milestones.map((m, i) => (
          <article
            class={`pz-milestone ${m.isTarget ? 'pz-milestone--target' : ''}`}
            data-km={m.km}
            data-year={m.year}
            data-index={i}
          >
            <div class="pz-milestone__icon">{m.icon}</div>
            <div class="pz-milestone__content">
              <div class="pz-milestone__meta">
                <span class="pz-milestone__km">{m.km} km</span>
                <span class="pz-milestone__year-tag">~{m.year}</span>
              </div>
              <h3 class="pz-milestone__title">{m.label}</h3>
              <p class="pz-milestone__desc">{m.desc}</p>
              <p class="pz-milestone__fun">{m.fun}</p>
              {m.km <= totalKm ? (
                <span class="pz-milestone__badge pz-milestone__badge--reached">✓ Reached</span>
              ) : (
                <span class="pz-milestone__badge pz-milestone__badge--future">Coming up</span>
              )}
            </div>
          </article>
        ))}

        <!-- ETA card -->
        <article class="pz-milestone pz-milestone--eta" data-km={trackMaxKm} data-year={etaNapoli} data-index={milestones.length}>
          <div class="pz-milestone__icon">🎯</div>
          <div class="pz-milestone__content">
            <span class="pz-milestone__km">Estimated arrival in Naples</span>
            <h3 class="pz-milestone__title">Year {etaNapoli}</h3>
            <p class="pz-milestone__desc">
              At {annualKm.toFixed(2)} km/year, {Math.max(0, (napoliDistanceKm - totalKm)).toFixed(1)} km remain.
              The golden thread keeps unrolling.
            </p>
            <p class="pz-milestone__fun">Every pizza you order shortens the journey by 33 cm. Do your part.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Post-order toast -->
  <div class="pz-toast" id="pz-toast" role="alert" aria-live="assertive" hidden>
    <span class="pz-toast__icon">🍕</span>
    <span class="pz-toast__text" id="pz-toast-text"></span>
  </div>

  <style>
    .pz-hero{min-height:100svh;min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--blue-deep);color:var(--white);position:relative;overflow:hidden;text-align:center}.pz-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 20%,rgba(246,212,0,0.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 80%,rgba(25,51,197,0.15) 0%,transparent 50%);pointer-events:none}.pz-hero::after{content:'';position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");background-size:150px;pointer-events:none;opacity:0.25}.pz-hero__inner{position:relative;z-index:2;padding:2rem clamp(1.25rem,5vw,3rem);max-width:800px}.pz-hero__kicker{display:inline-block;font-family:var(--font-subline);font-size:0.72rem;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:var(--accent-gold);margin-bottom:1rem}.pz-hero__title{color:var(--white);margin-bottom:1.5rem}.pz-hero__script{font-family:var(--font-script);font-weight:400;font-size:clamp(3.5rem,10vw,7rem);line-height:0.95;letter-spacing:0.02em}.pz-hero__subtitle{font-size:1.1rem;color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto 2.5rem;line-height:1.7}.pz-hero__subtitle em{color:var(--accent-gold);font-family:var(--font-display)}.pz-hero__counter{margin-bottom:2.5rem}.pz-hero__number{display:block;font-family:var(--font-display);font-size:clamp(4rem,12vw,8rem);font-weight:800;color:var(--accent-gold);line-height:1;letter-spacing:-0.03em;text-shadow:0 0 60px rgba(246,212,0,0.3)}.pz-hero__unit{display:block;font-family:var(--font-subline);font-size:0.9rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-top:0.5rem}.pz-hero__stats{display:flex;justify-content:center;gap:clamp(1.5rem,4vw,3rem);margin-bottom:3rem;flex-wrap:wrap}.pz-hero__stat{text-align:center}.pz-hero__stat-value{display:block;font-family:var(--font-display);font-size:1.15rem;font-weight:700;color:var(--white)}.pz-hero__stat-label{display:block;font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:0.2rem}.pz-hero__scroll-hint{display:flex;flex-direction:column;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.35);font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;animation:pzBounce 2s ease-in-out infinite}@keyframes pzBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(8px)}}.pz-journey{background:var(--blue-deep);position:relative;padding-block:clamp(4rem,10vw,8rem) clamp(6rem,15vw,12rem)}.pz-journey__container{max-width:var(--max-width);margin-inline:auto;padding-inline:clamp(1.25rem,5vw,3rem);display:grid;grid-template-columns:80px 1fr;gap:clamp(1.5rem,4vw,3rem)}.pz-journey__tracker{position:sticky;top:50%;transform:translateY(-50%);height:300px;display:flex;flex-direction:column;align-items:center;z-index:10;align-self:start}.pz-journey__line{position:relative;width:4px;height:200px;background:rgba(255,255,255,0.12);border-radius:999px;overflow:hidden}.pz-journey__line-fill{position:absolute;top:0;left:0;width:100%;height:0%;background:var(--accent-gold);border-radius:999px;transition:height 0.1s linear}.pz-journey__pizza{position:absolute;top:0;left:50%;transform:translate(-50%,-50%);transition:top 0.1s linear;filter:drop-shadow(0 0 12px rgba(246,212,0,0.4))}.pz-journey__km-display{margin-top:1rem;text-align:center}.pz-journey__km-value{display:block;font-family:var(--font-display);font-size:1.3rem;font-weight:800;color:var(--accent-gold)}.pz-journey__km-label{font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.4)}.pz-journey__milestones{display:flex;flex-direction:column;gap:clamp(2rem,5vw,4rem)}.pz-milestone{display:flex;gap:1.25rem;padding:clamp(1.25rem,3vw,2rem);border-radius:var(--radius-lg);border-left:4px solid transparent;background:rgba(255,255,255,0.03);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);opacity:0;transform:translateY(40px) translateX(20px);transition:opacity 0.6s var(--ease-out),transform 0.6s var(--ease-out),border-color 0.4s var(--ease-out),box-shadow 0.4s var(--ease-out)}.pz-milestone.is-active{opacity:1;transform:translateY(0) translateX(0);border-left-color:var(--accent-gold);background:rgba(255,255,255,0.06)}.pz-milestone__icon{font-size:2rem;flex-shrink:0;width:48px;height:48px;display:flex;align-items:center;justify-content:center}.pz-milestone__content{flex:1;min-width:0}.pz-milestone__meta{display:flex;align-items:center;gap:0.75rem;margin-bottom:0.3rem}.pz-milestone__km{display:inline-block;font-family:var(--font-subline);font-size:0.68rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent-gold)}.pz-milestone__year-tag{font-family:var(--font-display);font-size:0.75rem;font-weight:600;color:rgba(255,255,255,0.35);letter-spacing:0.05em}.pz-milestone__fun{font-family:var(--font-subline);font-size:1.2rem;color:var(--accent-gold);line-height:1.3;margin-bottom:0.6rem;opacity:0.85}.pz-milestone__title{font-family:var(--font-display);font-size:clamp(1.2rem,2.5vw,1.6rem);font-weight:700;color:var(--white);margin-bottom:0.4rem;line-height:1.2}.pz-milestone__desc{font-family:var(--font-subline);font-size:0.95rem;color:rgba(255,255,255,0.6);line-height:1.6;margin-bottom:0.6rem}.pz-milestone__badge{display:inline-block;font-size:0.68rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.2rem 0.6rem;border-radius:999px}.pz-milestone__badge--reached{background:rgba(22,163,74,0.2);color:#4ade80}.pz-milestone__badge--future{background:rgba(246,212,0,0.1);color:var(--accent-gold)}.pz-milestone--target.is-active{box-shadow:0 0 40px rgba(246,212,0,0.15),inset 0 0 30px rgba(246,212,0,0.03);border-left-color:var(--accent-gold)}.pz-milestone--target .pz-milestone__title{color:var(--accent-gold)}.pz-milestone--eta.is-active{background:rgba(246,212,0,0.06);border-left-color:rgba(255,255,255,0.3)}.pz-toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(120%);background:var(--accent-gold);color:var(--blue-deep);padding:0.8rem 1.5rem;border-radius:999px;font-size:0.9rem;font-weight:700;display:flex;align-items:center;gap:0.5rem;z-index:var(--z-modal);box-shadow:0 8px 32px rgba(0,0,0,0.3);transition:transform 0.5s var(--ease-spring);white-space:nowrap}.pz-toast.is-visible{transform:translateX(-50%) translateY(0)}.pz-toast__icon{font-size:1.3rem}@media (max-width:768px){.pz-journey__container{grid-template-columns:40px 1fr;gap:1rem}.pz-journey__tracker{height:200px}.pz-journey__line{width:3px;height:140px}.pz-journey__pizza svg{width:32px;height:32px}.pz-journey__km-display{display:none}.pz-milestone{flex-direction:column;gap:0.75rem;padding:1rem}.pz-milestone__icon{width:36px;height:36px;font-size:1.5rem}.pz-hero__stats{gap:1rem}}@media (prefers-reduced-motion:reduce){.pz-milestone{opacity:1;transform:none}.pz-hero__scroll-hint{animation:none}.pz-journey__pizza,.pz-journey__line-fill{transition:none}}
  </style>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      var counterEl = document.getElementById('km-counter');
      if (counterEl) {
        var target = parseFloat(counterEl.dataset.target);
        var duration = 2500;
        var start = performance.now();
        function animateCounter(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          counterEl.textContent = (eased * target).toFixed(1);
          if (progress < 1) requestAnimationFrame(animateCounter);
        }
        requestAnimationFrame(animateCounter);
      }

      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);
        document.querySelectorAll('.pz-milestone').forEach(function(el) {
          ScrollTrigger.create({ trigger: el, start: 'top 80%', onEnter: function() { el.classList.add('is-active'); } });
        });
        var journeySection = document.querySelector('.pz-journey');
        var lineFill = document.getElementById('journey-line-fill');
        var pizza = document.getElementById('journey-pizza');
        var kmValue = document.getElementById('journey-km-value');
        if (journeySection && lineFill && pizza && kmValue) {
          ScrollTrigger.create({
            trigger: journeySection, start: 'top top', end: 'bottom bottom', scrub: 1,
            onUpdate: function(self) {
              var pct = self.progress * 100;
              lineFill.style.height = pct + '%';
              pizza.style.top = pct + '%';
              kmValue.textContent = Math.round(self.progress * 1000);
            }
          });
        }
      }

      var params = new URLSearchParams(window.location.search);
      var addedPizzas = parseInt(params.get('addedPizzas'), 10);
      if (addedPizzas > 0) {
        var toast = document.getElementById('pz-toast');
        var toastText = document.getElementById('pz-toast-text');
        if (toast && toastText) {
          var addedMeters = (addedPizzas * 33 / 100).toFixed(1);
          toastText.textContent = '+' + addedPizzas + ' pizzas ordered! The golden thread grows by ' + addedMeters + ' m';
          toast.removeAttribute('hidden');
          requestAnimationFrame(function() { requestAnimationFrame(function() { toast.classList.add('is-visible'); }); });
          setTimeout(function() { toast.classList.remove('is-visible'); setTimeout(function() { toast.setAttribute('hidden', ''); }, 600); }, 8000);
        }
      }
    });
  </script>

</BaseLayout>
