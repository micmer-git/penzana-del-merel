---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 300;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const trackMaxKm = 800;

// --- Driver models ---
const familyEntries = [
  { name: 'Michele', year: 1994 + 4 },
  { name: 'Luca', year: 1995 + 4 },
  { name: 'Alessandro', year: 1998 + 4 },
  { name: 'Giacomo', year: 2004 + 4 },
  { name: 'Chiara', year: 2007 + 4 },
];

function weeksBetween(from: Date, to: Date) {
  return Math.max(0, Math.floor((to.getTime() - from.getTime()) / (1000 * 60 * 60 * 24 * 7)));
}

function computeBrunoModel(nowDate: Date) {
  const perWeek = 5;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeFamilyModel(nowDate: Date) {
  let pizzas = 0;
  let last = new Date(startYear, 0, 1);
  let people = 3;
  const perPerson = 3;
  const sorted = [...familyEntries].sort((a, b) => a.year - b.year);
  for (const e of sorted) {
    const eventDate = new Date(e.year, 0, 1);
    if (eventDate > nowDate) break;
    pizzas += weeksBetween(last, eventDate) * people * perPerson;
    people += 1;
    last = eventDate;
  }
  pizzas += weeksBetween(last, nowDate) * people * perPerson;
  const perWeekNow = people * perPerson;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeekNow * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeekNow, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeAllClientsModel(nowDate: Date) {
  const perWeek = pizzasPerWeek;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

const brunoModel = computeBrunoModel(now);
const familyModel = computeFamilyModel(now);
const allClientsModel = computeAllClientsModel(now);

// Birth years of the Merelli children
const births = [
  { name: 'Michele', birthYear: 1994 },
  { name: 'Luca', birthYear: 1995 },
  { name: 'Alessandro', birthYear: 1998 },
  { name: 'Giacomo', birthYear: 2004 },
  { name: 'Chiara', birthYear: 2007 },
];

// --- Build milestones (main journey 0–800 km) ---
interface Milestone {
  km: number;
  label: string;
  body: string;
  icon: string;
  fun: string;
  year: number;
  type: 'geo' | 'fun' | 'birth';
  isTarget?: boolean;
  isOrigin?: boolean;
}

const geoMilestones: Milestone[] = [
  { km: 0, label: 'La Penzana (Orezzo)', body: 'Where it all began: floured hands, live embers, the scent of home.', icon: '🏠', year: 1989, fun: 'Pizza number one: probably lopsided. Definitely memorable.', type: 'geo', isOrigin: true },
  { km: 3, label: 'Gazzaniga', body: 'Three kilometres of pizza lined up: enough to get noticed in the valley.', icon: '⛰️', year: Math.round(startYear + 3 / annualKm), fun: 'Only one question here: are you bringing more?', type: 'geo' },
  { km: 12, label: 'Bergamo — Città Alta', body: 'The thread reaches the upper town and climbs quietly between stone and flour.', icon: '🏰', year: Math.round(startYear + 12 / annualKm), fun: 'A roundabout of pizza in Piazza Vecchia? Almost.', type: 'geo' },
  { km: 42.2, label: 'The Pizza Marathon', body: 'A symbolic marathon made of stretched dough and evenings that end late.', icon: '🏃', year: Math.round(startYear + 42.2 / annualKm), fun: 'No running shoes needed: just a peel, an oven, and persistence.', type: 'geo' },
  { km: 60, label: 'Milan — The Duomo', body: 'Under the Madonnina the thread stays simple: good pizza, no pretence.', icon: '🏛️', year: Math.round(startYear + 60 / annualKm), fun: 'In Milan they ask if it\'s gourmet. In Orezzo it just has to be delicious.', type: 'geo' },
  { km: 130, label: 'Piacenza', body: 'The road stretches on and the journey begins to speak different cuisines.', icon: '🧀', year: Math.round(startYear + 130 / annualKm), fun: 'Between cured meats and pizza, the connection is instant.', type: 'geo' },
  { km: 180, label: 'Parma', body: 'The golden thread continues without changing accent: artisanal, direct, sincere.', icon: '🍖', year: Math.round(startYear + 180 / annualKm), fun: 'Verdi composed operas. We compose successful evenings.', type: 'geo' },
  { km: 260, label: 'Bologna — The Two Towers', body: 'It crosses the heart of Italy, holding tradition and real hunger together.', icon: '🏗️', year: Math.round(startYear + 260 / annualKm), fun: 'Bologna has tortellini. We bring the Diavola. Even.', type: 'geo' },
  { km: 360, label: 'Florence — Ponte Vecchio', body: 'Renaissance and pizza share one gift: they never get old.', icon: '🎨', year: Math.round(startYear + 360 / annualKm), fun: 'Leonardo would have designed a dough-rolling machine.', type: 'geo' },
  { km: 430, label: 'Siena — Piazza del Campo', body: 'Every pizza keeps the journey\'s rhythm: slow, precise, relentless.', icon: '🐎', year: Math.round(startYear + 430 / annualKm), fun: 'The Palio is lightning fast. Rising dough is not, and that\'s fine.', type: 'geo' },
  { km: 500, label: 'Orvieto', body: 'At this point the journey seems impossible only to those who don\'t know persistence.', icon: '⛪', year: Math.round(startYear + 500 / annualKm), fun: 'Five hundred kilometres of pizza is a measure that deserves respect.', type: 'geo' },
  { km: 560, label: 'Rome — The Colosseum', body: 'The capital watches, the oven continues, the course doesn\'t change.', icon: '🏟️', year: Math.round(startYear + 560 / annualKm), fun: 'The crowd gives the thumbs up: Margherita saves the day.', type: 'geo' },
  { km: 650, label: 'Cassino — Montecassino', body: 'Between memory and silence the golden thread stays lit and moves forward.', icon: '🕍', year: Math.round(startYear + 650 / annualKm), fun: 'Bread, pizza, patience: some things always go well together.', type: 'geo' },
  { km: 720, label: 'Caserta — The Royal Palace', body: 'A palace fit for kings and a pizza for everyone: perfect balance.', icon: '👑', year: Math.round(startYear + 720 / annualKm), fun: 'The Palace has a thousand rooms. We just need the right oven.', type: 'geo' },
  { km: 780, label: 'Aversa', body: 'The last emotional climb before the symbolic homeland of pizza.', icon: '🔥', year: Math.round(startYear + 780 / annualKm), fun: 'Here the tension rises like well-made dough.', type: 'geo' },
  { km: 800, label: 'Naples — Via dei Tribunali', body: 'The homeland of pizza is right there: Tarcisio saw it coming.', icon: '🌋', isTarget: true, year: Math.round(startYear + 800 / annualKm), fun: 'Getting there with a thread of pizzas is practical poetry.', type: 'geo' },
];

const funMilestones: Milestone[] = [
  { km: (1000 * 33) / 100000, label: '1,000 Pizzas', body: 'The first thousand. A thousand times the dough took shape, a thousand times the oven did its duty.', icon: '🎯', fun: 'Line them up: 330 metres of pizza. Almost a lap of the track.', year: Math.round(startYear + ((1000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (10000 * 33) / 100000, label: '10,000 Pizzas', body: 'Ten thousand pizzas mean ten thousand evenings, ten thousand tables, ten thousand different stories.', icon: '🎪', fun: 'At this point you can smell it from Gazzaniga.', year: Math.round(startYear + ((10000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (50000 * 33) / 100000, label: '1 Elephant of Mozzarella', body: 'Fifty thousand pizzas with 100g of mozzarella each. Total: 5 tonnes. The weight of an African elephant.', icon: '🐘', fun: 'Jumbo would approve.', year: Math.round(startYear + ((50000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (100000 * 33) / 100000, label: '100,000 Pizzas', body: 'A number you can\'t visualise, you feel it: in the heat of the oven, in the family\'s hands.', icon: '🏆', fun: 'Enough to feed all of Bergamo. Twice.', year: Math.round(startYear + ((100000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (1000000 * 33) / 100000, label: '1,000,000 Pizzas', body: 'A million pizzas. At that point the golden thread is no longer a thread, it\'s a highway.', icon: '💎', fun: 'A million reasons to come back to Orezzo.', year: Math.round(startYear + ((1000000 * 33) / 100000) / annualKm), type: 'fun' },
];

const birthComments: Record<string, { body: string; fun: string }> = {
  Michele: { body: 'Here comes the firstborn.', fun: 'The first Merelli of the new generation. The oven has an heir.' },
  Luca: { body: 'That was quick...', fun: 'Two in two years. The family doesn\'t waste time.' },
  Alessandro: { body: 'Good things come in threes. He\'ll be the singer.', fun: 'Three brothers, three personalities, one favourite pizza: Margherita.' },
  Giacomo: { body: 'Four — almost enough for five-a-side. They never stop... baking pizzas.', fun: 'Number four arrives and the table gets longer.' },
  Chiara: { body: 'Finally, the princess!', fun: 'Five Merellis. The squad is complete.' },
};

const birthMilestones: Milestone[] = births.map(b => ({
  km: (b.birthYear - startYear) * annualKm,
  label: `${b.name} is born`,
  body: birthComments[b.name]?.body || `${b.birthYear} — one more Merelli at the table.`,
  icon: '👶',
  fun: birthComments[b.name]?.fun || 'The family grows, the thread gets longer.',
  year: b.birthYear,
  type: 'birth' as const,
}));

// Merge and sort all main milestones by km
const allMainMilestones = [...geoMilestones, ...funMilestones, ...birthMilestones].sort((a, b) => a.km - b.km);

// --- Compute positions with min-gap enforcement ---
const milestoneCount = allMainMilestones.length;
const minGapPct = 100 / (milestoneCount + 1);

let positions = allMainMilestones.map(m => ({
  ...m,
  pct: (m.km / trackMaxKm) * 100,
}));

// Enforce minimum gap
for (let i = 1; i < positions.length; i++) {
  if (positions[i].pct - positions[i - 1].pct < minGapPct) {
    positions[i].pct = positions[i - 1].pct + minGapPct;
  }
}

// Normalize so last milestone is at ~95% (leaving room for ETA)
const maxPct = positions[positions.length - 1].pct;
if (maxPct > 0) {
  positions = positions.map(p => ({ ...p, pct: (p.pct / maxPct) * 95 }));
}

// Build position-to-km mapping for JS interpolation
const posKmMap = positions.map(p => ({ pct: p.pct, km: p.km }));

// --- Post-Napoli dream milestones (separate section) ---
const dreamMilestones = [
  { label: 'Pizza Tour of Italy', body: 'The entire boot, covered in dough. From Orezzo to Lampedusa and back.', icon: '🇮🇹', fun: 'The boot has never been this tasty.', km: 1500 },
  { label: 'Equator of Mozzarella', body: 'Enough mozzarella to circle the equator. The weight? Don\'t ask.', icon: '🧭', fun: 'The equator is hot. Just like the oven.', km: 3500 },
  { label: '1 Olympic Pool of Tomato Sauce', body: `${Math.round(2500000000 / 150).toLocaleString('en-US')} pizzas with 150ml of sauce each. An entire Olympic swimming pool.`, icon: '🏊', fun: 'Diving into tomato sauce: as kids we all dreamed of it.', km: 5500 },
  { label: 'From Orezzo to Tokyo', body: 'Ten thousand kilometres of golden thread. The oven knows no time zone.', icon: '🗾', fun: 'In Japan pizza is art. In Orezzo too.', km: 10000 },
  { label: 'Around the World', body: '40,075 km. The golden thread wraps around the planet. At that point, we\'re legend.', icon: '🌍', fun: 'Tarcisio didn\'t stop at borders. Neither do we.', km: 40075 },
];

// Funny interstitial comments for post-Napoli scrolling
const dreamComments = [
  'The oven never goes out.',
  'At this point, the yeast deserves a passport.',
  'Tarcisio knew it: there\'s no limit to the dough.',
  'Pizza knows no borders. Only frontiers to cross.',
  'Every pizza brings us closer. To what? To everything.',
  'The golden thread is never in a hurry. It has persistence.',
];

// Timeline height: main = milestoneCount * 120vh, post-Napoli has its own section
---

<BaseLayout
  title="Pizzameter — The Golden (Tomato) Thread"
  description="Since 1989: how far would all pizzas from La Penzana go if lined up? A vertical journey from Orezzo to Naples, through Val Seriana and all of Italy."
  lang="en"
  pageType="website"
  currentPath={`${base}/en/pizzameter/`}
>
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">The Golden (Tomato) Thread</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzameter</span>
      </h1>
      <p class="pz-hero__subtitle">
        Since {startYear}, every pizza baked adds 33 cm to our golden (tomato) thread.<br />
        Tarcisio used to say: <em>"We'll make it all the way to Naples."</em>
      </p>

      <div class="pz-driver" aria-label="Filometro driver selector">
        <span class="pz-driver__label">Who's eating?</span>
        <div class="pz-driver__controls">
          <button type="button" class="pz-driver__btn is-active" data-mode="all" id="driver-btn-all">All Clients</button>
          <button type="button" class="pz-driver__btn" data-mode="bruno" id="driver-btn-bruno">Bruno</button>
          <button type="button" class="pz-driver__btn" data-mode="family" id="driver-btn-family">Merelli Family</button>
          <button type="button" class="pz-driver__info" id="filometro-info-btn" aria-label="Formula info">i</button>
        </div>
        <div class="pz-driver__popup" id="filometro-popup" hidden>
          <button type="button" class="pz-driver__close" id="filometro-popup-close" aria-label="Close">&times;</button>
          <strong>All Clients</strong> — 300 pizzas per week, the whole oven since 1989.<br/>
          <strong>Bruno</strong> — loyal customer, 5 pizzas per week since 1989.<br/>
          <strong>Merelli Family</strong> — 3 people &times; 3 pizzas/week, then +1 person for each child after age 4.
        </div>
      </div>

      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter"
          data-target={allClientsModel.totalKm.toFixed(1)}
          data-bruno={brunoModel.totalKm.toFixed(1)}
          data-family={familyModel.totalKm.toFixed(1)}
          data-all={allClientsModel.totalKm.toFixed(1)}>0.0</span>
        <span class="pz-hero__unit">km travelled</span>
        <span class="pz-hero__subcount">
          <strong id="pizza-counter"
            data-target={allClientsModel.pizzasDelivered}
            data-bruno={brunoModel.pizzasDelivered}
            data-family={familyModel.pizzasDelivered}
            data-all={allClientsModel.pizzasDelivered}>{allClientsModel.pizzasDelivered.toLocaleString('en-US')}</strong>
          pizzas baked in total
        </span>
      </div>

      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} &rarr; {currentYear}</span>
          <span class="pz-hero__stat-label">years of tradition</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value"><span id="stat-annual"
            data-bruno={brunoModel.annualKm.toFixed(1)}
            data-family={familyModel.annualKm.toFixed(1)}
            data-all={allClientsModel.annualKm.toFixed(1)}>{allClientsModel.annualKm.toFixed(1)}</span> km</span>
          <span class="pz-hero__stat-label">every year</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">33 cm</span>
          <span class="pz-hero__stat-label">per pizza</span>
        </div>
      </div>

      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scroll to travel</span>
      </div>
    </div>
  </section>

  <!-- Main journey: 0–800 km -->
  <section class="pz-journey" aria-label="Symbolic journey from Orezzo to Naples">
    <div class="pz-journey__container">
      <div class="pz-journey__timeline" id="journey-timeline" style={`--mc: ${milestoneCount};`}>
        <div class="pz-journey__rail">
          <div class="pz-journey__rail-fill" id="journey-line-fill"></div>
        </div>

        <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
          <div class="pz-journey__pizza-body" id="journey-pizza-body">
            <svg viewBox="0 0 56 56" width="56" height="56" xmlns="http://www.w3.org/2000/svg">
              <path d="M28 4 L50 46 Q28 52 6 46 Z" fill="#f6d400" stroke="var(--blue-deep)" stroke-width="2" stroke-linejoin="round"/>
              <path d="M6 46 Q28 52 50 46" fill="#e2be00" stroke="var(--blue-deep)" stroke-width="2"/>
              <circle cx="24" cy="22" r="3.5" fill="#dc2626" opacity="0.9"/>
              <circle cx="33" cy="28" r="3" fill="#dc2626" opacity="0.85"/>
              <circle cx="22" cy="34" r="2.8" fill="#dc2626" opacity="0.85"/>
              <circle cx="28" cy="16" r="2" fill="#16a34a" opacity="0.7"/>
              <circle cx="18" cy="28" r="1.8" fill="#16a34a" opacity="0.7"/>
              <circle cx="34" cy="38" r="2.2" fill="#f5f5dc" opacity="0.6"/>
            </svg>
          </div>
          <div class="pz-journey__pizza-stats">
            <span class="pz-journey__counter-km" id="journey-km-value">0.0</span>
            <span class="pz-journey__counter-label" id="journey-unit-label">metres travelled</span>
            <span class="pz-journey__counter-year" id="journey-year-value">{startYear}</span>
          </div>
        </div>

        {positions.map((ms, index) => {
          const side = index % 2 === 0 ? 'left' : 'right';
          const showQuoteOutside = ms.isOrigin || ms.type === 'fun';
          return (
            <article
              class={`pz-marker pz-marker--${side} ${ms.isTarget ? 'pz-marker--target' : ''} ${ms.type === 'fun' ? 'pz-marker--fun' : ''} ${ms.type === 'birth' ? 'pz-marker--birth' : ''}`}
              style={`top: ${ms.pct}%;`}
              data-km={ms.km}
              data-year={ms.year}
            >
              {showQuoteOutside && (
                <p class="pz-typo-quote" set:html={ms.body.replace(/\.\s*/g, '.<br/>')} />
              )}
              <div class="pz-marker__body">
                <div class="pz-marker__dot">
                  <span class="pz-marker__icon">{ms.icon}</span>
                </div>
                <div class="pz-marker__card">
                  <div class="pz-marker__meta">
                    <span class="pz-marker__km-tag">{ms.km < 1 ? `${Math.round(ms.km * 1000)} m` : `${Math.round(ms.km * 10) / 10} km`}</span>
                    <span class="pz-marker__year-tag">~{ms.year}</span>
                    {ms.km <= totalKm ? (
                      <span class="pz-marker__badge pz-marker__badge--reached">reached</span>
                    ) : (
                      <span class="pz-marker__badge pz-marker__badge--future">ahead</span>
                    )}
                  </div>
                  <h2 class="pz-marker__title">{ms.label}</h2>
                  {!showQuoteOutside && <p class="pz-marker__bodycopy">{ms.body}</p>}
                  <p class="pz-marker__fun">{ms.fun}</p>
                </div>
              </div>
            </article>
          );
        })}

        <article
          class="pz-marker pz-marker--left pz-marker--eta"
          style="top: 98%;"
          data-km={trackMaxKm}
        >
          <div class="pz-marker__body">
            <div class="pz-marker__dot"><span class="pz-marker__icon">🎯</span></div>
            <div class="pz-marker__card">
              <div class="pz-marker__meta">
                <span class="pz-marker__km-tag">estimated arrival</span>
                <span class="pz-marker__year-tag">~<span id="eta-year"
                  data-bruno={brunoModel.etaNapoli}
                  data-family={familyModel.etaNapoli}
                  data-all={allClientsModel.etaNapoli}>{allClientsModel.etaNapoli}</span></span>
              </div>
              <h2 class="pz-marker__title">Naples — Year <span id="eta-title-year">{allClientsModel.etaNapoli}</span></h2>
              <p class="pz-marker__bodycopy">
                <span id="eta-remaining"
                  data-bruno={Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1)}
                  data-family={Math.max(0, (napoliDistanceKm - familyModel.totalKm)).toFixed(1)}
                  data-all={Math.max(0, (napoliDistanceKm - allClientsModel.totalKm)).toFixed(1)}>{Math.max(0, (napoliDistanceKm - allClientsModel.totalKm)).toFixed(1)}</span> km to go. Every pizza shortens the journey by 33 cm.
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Post-Napoli dream section -->
  <section class="pz-beyond" aria-label="And after Naples?">
    <div class="pz-beyond__intro">
      <h2 class="pz-beyond__title">And after Naples?</h2>
      <p class="pz-beyond__subtitle">The oven stays on. The thread continues.</p>
    </div>

    <div class="pz-beyond__timeline">
      {dreamMilestones.map((dm, i) => (
        <div class="pz-beyond__block">
          {i > 0 && (
            <p class="pz-beyond__comment">{dreamComments[i % dreamComments.length]}</p>
          )}
          <article class="pz-marker pz-marker--dream is-visible">
            <p class="pz-typo-quote" set:html={dm.body.replace(/\.\s*/g, '.<br/>')} />
            <div class="pz-marker__body">
              <div class="pz-marker__dot">
                <span class="pz-marker__icon">{dm.icon}</span>
              </div>
              <div class="pz-marker__card">
                <div class="pz-marker__meta">
                  <span class="pz-marker__km-tag">{dm.km.toLocaleString('en-US')} km</span>
                  <span class="pz-marker__badge pz-marker__badge--future">dream</span>
                </div>
                <h2 class="pz-marker__title">{dm.label}</h2>
                <p class="pz-marker__fun">{dm.fun}</p>
              </div>
            </div>
          </article>
        </div>
      ))}

      <div class="pz-beyond__block">
        <p class="pz-beyond__comment">Tarcisio didn't stop at borders. Neither do we.</p>
      </div>

      <div class="pz-beyond__end">
        <span class="pz-beyond__end-icon">🍕</span>
        <p>The golden (tomato) thread never ends. Every pizza adds 33 cm.</p>
      </div>
    </div>
  </section>

  <div class="pz-toast" id="pz-toast" role="alert" aria-live="assertive" hidden>
    <span class="pz-toast__icon">🍕</span>
    <span class="pz-toast__text" id="pz-toast-text"></span>
  </div>

  <style>
