---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Contact and directions — La Penzana del Merel"
  description="Contact details and directions for La Penzana del Merel in Orezzo, Bergamo hills. Via alla Chiesa 4, phone 035 712021."
  lang="en"
  currentPath={`${base}/en/contact/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">Contact</span>
      <h1 class="page-hero__title">Where we are, how to get there, how to reach us quickly.</h1>
      <p class="page-hero__lead">We are in Orezzo, Valle Seriana, about 18 km from Bergamo. A hillside stop for wood-fired pizza, Bergamo dishes and a slower evening atmosphere.</p>
      <div class="page-hero__facts">
        <span>Via alla Chiesa, 4</span>
        <span>+39 035 712021</span>
        <span>QR + WhatsApp table ordering</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid; gap:1.25rem;">
      <div class="contact-grid">
        <div class="contact-item reveal">
          <div class="contact-item-icon" aria-hidden="true">📍</div>
          <div class="contact-item-label">Address</div>
          <div class="contact-item-value">Via alla Chiesa, 4</div>
          <div class="contact-item-note">24025 Orezzo (Gazzaniga), Bergamo, Italy</div>
        </div>
        <div class="contact-item reveal">
          <div class="contact-item-icon" aria-hidden="true">☎️</div>
          <div class="contact-item-label">Phone</div>
          <div class="contact-item-value"><a href="tel:+390357121021">+39 035 712021</a></div>
          <div class="contact-item-note">For reservations and information</div>
        </div>
        <div class="contact-item reveal">
          <div class="contact-item-icon" aria-hidden="true">🕰️</div>
          <div class="contact-item-label">Opening hours</div>
          <div class="contact-item-value">Please call for hours</div>
          <div class="contact-item-note">Hours can vary by season, so a quick phone call is the safest option.</div>
        </div>
        <div class="contact-item reveal">
          <div class="contact-item-icon" aria-hidden="true">📲</div>
          <div class="contact-item-label">Order from table</div>
          <div class="contact-item-value">QR code + WhatsApp</div>
          <div class="contact-item-note">Scan the QR on your table to build and send the order quickly.</div>
        </div>
      </div>

      <div class="travel-grid">
        <article class="travel-card reveal">
          <span class="travel-card__eyebrow">By car</span>
          <h3>The easiest route</h3>
          <p>A4 motorway (Milan–Venice), exit Seriate or Nembro, then follow the SP35 towards Gazzaniga–Orezzo. About 25–30 minutes from the motorway.</p>
          <div class="cta-row">
            <a href="https://www.google.com/maps/dir//Via+alla+Chiesa,+4,+24025+Orezzo+BG" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Open Google Maps</a>
          </div>
        </article>
        <article class="travel-card reveal">
          <span class="travel-card__eyebrow">Public transport</span>
          <h3>Bergamo → Valle Seriana</h3>
          <p>Check the latest connections from Bergamo on bergamotrasporti.it. The valley is served by SAB bus lines.</p>
          <div class="cta-row">
            <a href="https://www.bergamotrasporti.it" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Check connections</a>
          </div>
        </article>
      </div>

      <div class="map-shell reveal">
        <iframe
          title="La Penzana del Merel location on the map"
          src="https://www.openstreetmap.org/export/embed.html?bbox=9.79%2C45.78%2C9.86%2C45.83&layer=mapnik&marker=45.806%2C9.823"
          width="100%"
          height="420"
          style="border:0; display:block;"
          loading="lazy"
          aria-label="Map of Orezzo, BG"
        ></iframe>
      </div>
      <p class="text-small">Map: OpenStreetMap contributors. Approximate location — coordinates: 45.806, 9.823.</p>
    </div>
  </section>
</BaseLayout>
