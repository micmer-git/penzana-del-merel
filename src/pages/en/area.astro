---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
const stats = [
  { strong: '~380 m', label: 'altitude' },
  { strong: '~18 km', label: 'from Bergamo' },
  { strong: 'Valle Seriana', label: 'setting' },
  { strong: 'SP35', label: 'road access' },
];
---

<BaseLayout
  title="The area — Orezzo and Valle Seriana"
  description="Orezzo, Gazzaniga, Valle Seriana: the setting of La Penzana del Merel among hills, woods, villages and Bergamo cuisine."
  lang="en"
  currentPath={`${base}/en/area/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">The area</span>
      <h1 class="page-hero__title">Orezzo: hillside air, woods and a detour worth your evening.</h1>
      <p class="page-hero__lead">Small, quiet and overlooking the Serio valley, Orezzo is the kind of place people seek when they want to slow down without travelling too far from Bergamo.</p>
      <div class="stat-ribbon">
        {stats.map((item) => (
          <div class="stat-ribbon__item">
            <strong>{item.strong}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container travel-grid" style="max-width:1040px;">
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">The village</span>
        <h3>A different pace</h3>
        <p>Orezzo is a hamlet of Gazzaniga on the right side of the Serio. Meadows, woods, open views and the feeling of leaving the city without going far away.</p>
      </article>
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">How to reach it</span>
        <h3>Between motorway and valley road</h3>
        <p>From the A4 motorway, exit at Seriate or Nembro and continue towards Gazzaniga–Orezzo. Parking is available near the restaurant.</p>
        <div class="cta-row">
          <a href="https://www.google.com/maps/dir//Via+alla+Chiesa,+4,+24025+Orezzo+BG" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Open in Google Maps</a>
        </div>
      </article>
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">Alpine context</span>
        <h3>Valle Seriana</h3>
        <p>A valley stretching more than 70 km, with both industrial history and natural beauty: forests, trails, historic villages and a cuisine that blends mountain and plain.</p>
      </article>
    </div>
  </section>
</BaseLayout>
