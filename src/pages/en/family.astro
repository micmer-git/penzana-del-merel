---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
const family = [
  {
    name: 'Alessandro Merelli',
    role: 'The founder',
    text: 'In 1936 he acquires the building, laying the first stone of what becomes a local landmark in Orezzo.',
  },
  {
    name: 'Tarcisio Merelli',
    role: 'Master pizza maker',
    text: 'He opens the inn in 1959, builds ovens, becomes a finalist in Naples in 1989 and later turns the inn into a pizzeria.',
  },
  {
    name: 'Efrem Merelli',
    role: 'Second generation',
    text: 'He supports his father in shaping the pizzeria and carries the tradition forward with care for ingredients and guests.',
  },
  {
    name: 'Laura Merla',
    role: 'The heart of hospitality',
    text: 'Present since the early years of the pizzeria, she helps create the genuine warmth customers still remember.',
  },
];
---

<BaseLayout
  title="The family — La Penzana del Merel"
  description="Three generations of the Merelli family: the founder, the pizza maker, the people who grew the place and still keep it alive today."
  lang="en"
  currentPath={`${base}/en/family/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">Family</span>
      <h1 class="page-hero__title">Three generations, one oven, the same way of welcoming people.</h1>
      <p class="page-hero__lead">La Penzana del Merel is not just a venue. It is continuity: different people, one shared idea of care, memory and place.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid; gap:1.2rem; max-width:980px;">
      <div class="profile-grid">
        {family.map((member) => (
          <article class="profile-card reveal">
            <span class="profile-card__role">{member.role}</span>
            <h2>{member.name}</h2>
            <p>{member.text}</p>
          </article>
        ))}
      </div>

      <div class="story-quote reveal">
        <p>The Merelli family never stopped believing that the place mattered as much as the pizza. That may be one reason people keep coming back.</p>
        <span class="story-quote__cite">Editorial note</span>
      </div>

      <div class="cta-row reveal">
        <a href={`${base}/en/history/`} class="btn btn-primary">Full history</a>
        <a href={`${base}/en/contact/`} class="btn btn-outline">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
