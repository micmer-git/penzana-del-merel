---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="La Penzana del Merel — Family pizzeria in Orezzo, Valle Seriana"
  description="Family pizzeria in Orezzo, Bergamo hills. Wood-fired oven, Bergamo tradition and a warm hillside atmosphere since 1959."
  lang="en"
  currentPath={`${base}/en/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">Orezzo · Valle Seriana · Bergamo</span>
      <h1 class="page-hero__title">A family pizzeria shaped by hillside evenings.</h1>
      <p class="page-hero__lead">Wood-fired pizza, Bergamo dishes, fresh summer air and a place that still feels intimate. Since 1959, La Penzana del Merel has been part of the rhythm of Orezzo.</p>
      <div class="page-hero__facts">
        <span>Wood-fired oven</span>
        <span>Since 1959</span>
        <span>QR + WhatsApp table ordering</span>
      </div>
      <div class="cta-row">
        <a href={`${base}/en/menu/`} class="btn btn-primary">See the menu</a>
        <a href={`${base}/en/history/`} class="btn btn-outline">Read the story</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-3">
      <article class="feature-card reveal">
        <div class="feature-icon" aria-hidden="true">🍕</div>
        <h3>Wood-fired craft</h3>
        <p>Pizzas baked in the oven hand-built by Tarcisio Merelli, with a style that feels genuine rather than polished for effect.</p>
      </article>
      <article class="feature-card reveal">
        <div class="feature-icon" aria-hidden="true">⛰️</div>
        <h3>Hillside setting</h3>
        <p>Orezzo sits above the Serio valley: cooler in summer, rustic in atmosphere, and close enough for an easy evening escape from Bergamo.</p>
      </article>
      <article class="feature-card reveal">
        <div class="feature-icon" aria-hidden="true">👨‍👩‍👦</div>
        <h3>Family memory</h3>
        <p>Three generations, one story: the building, the inn, the pizzeria, and the idea that the place matters as much as the pizza.</p>
      </article>
    </div>
  </section>
</BaseLayout>
