---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="La Penzana del Merel — Family Pizzeria in Orezzo, Valle Seriana"
  description="La Penzana del Merel is a family-run pizzeria in Orezzo (BG), in the heart of Valle Seriana near Bergamo. Tradition, wood-fired oven, genuine flavours since 1959."
  lang="en"
  pageType="restaurant"
  currentPath={`${base}/en/`}
>

  <section class="hero hero-full">
    <div class="hero-bg" style={`background-image:url('${base}/img/general_pizza_overview.png');`}></div>
    <div class="container">
      <span class="hero-eyebrow">Orezzo · Valle Seriana · Bergamo, Italy</span>
      <h1><span class="hero-script">La Penzana</span><span class="hero-subline">del Merel</span></h1>
      <p>A family pizzeria in the Bergamo hills. Cool in summer, rustic on festive days, genuine every evening. Since 1959.</p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center;">
        <a href={`${base}/en/menu/`} class="btn btn-primary">See the Menu</a>
        <a href={`${base}/en/history/`} class="btn btn-outline">Our Story</a>
      </div>
    </div>
    <div class="hero-mountains"></div>
  </section>

  <div class="info-strip">
    <div class="container">
      <div class="grid">
        <div><div class="item-label">Since</div><div class="item-value">1959</div></div>
        <div><div class="item-label">Location</div><div class="item-value">Orezzo (BG)</div></div>
        <div><div class="item-label">Phone</div><div class="item-value"><a href="tel:+39035712021" style="color:inherit;">035 712021</a></div></div>
        <div><div class="item-label">Speciality</div><div class="item-value">Wood-fired pizza</div></div>
      </div>
    </div>
  </div>


  <section class="section-sm" style="background:var(--bg-warm);">
    <div class="container">
      <div class="grid-3">
        <div class="feature-card reveal">
          <div class="feature-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12c-2-2.67-2-6 0-8 2 2 2 5.33 0 8z"/><path d="M12 12c2-2.67 2-6 0-8-2 2-2 5.33 0 8z"/><path d="M12 12c-3.5 0-6 2-7 5h14c-1-3-3.5-5-7-5z"/><path d="M5 17c0 1 1 3 7 3s7-2 7-3"/></svg></div>
          <h3 style="font-size:1.1rem; margin-bottom:0.5rem;">Wood-fired oven</h3>
          <p style="font-size:0.875rem; color:var(--text-muted);">Pizzas baked in the oven hand-built by master pizzaiolo Tarcisio Merelli.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg></div>
          <h3 style="font-size:1.1rem; margin-bottom:0.5rem;">Selected ingredients</h3>
          <p style="font-size:0.875rem; color:var(--text-muted);">From mozzarella to porcini mushrooms, every ingredient is carefully chosen.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 style="font-size:1.1rem; margin-bottom:0.5rem;">Family since 1959</h3>
          <p style="font-size:0.875rem; color:var(--text-muted);">Three generations of Bergamo passion for pizza and genuine hospitality.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <div class="grid-2" style="align-items:center; gap:3rem;">
        <div>
          <span class="kicker" style="color:var(--accent-gold);">The Story</span>
          <h2 style="margin-top:0.5rem;">A place where time slows down</h2>
          <hr class="divider" style="margin:1rem 0;" />
          <p>Under the century-old chestnut tree in Orezzo, the Merelli family built something rare: a place of genuine authenticity. Glasses of red wine, bowls, pizzas crafted with care.</p>
          <p>What was once the "Trattoria Cima Verde" became La Penzana del Merel — the name echoes the simple tin-roofed shelters where farmers kept their rakes and pitchforks. A sign of roots.</p>
          <a href={`${base}/en/history/`} class="btn btn-green mt-2">Read the full story</a>
        </div>
        <div>
          <img src={`${base}/img/cucina_tipica.png`} alt="In the kitchen — traditional Bergamo cuisine" loading="lazy" style="width:100%; border-radius:var(--radius-lg); box-shadow:var(--shadow-md); margin-bottom:1rem;" />
          <blockquote class="pullquote" style="margin:0;">
            "We want to change in order to remain ourselves, to remain with you."
          </blockquote>
          <p style="margin-top:0.5rem; color:var(--text-muted); font-size:0.875rem;">— The Merel family</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark reveal">
    <div class="container">
      <div class="section-header">
        <span class="kicker" style="color:var(--accent-gold);">Menu 2026</span>
        <h2>Our menu</h2>
        <hr class="divider" />
        <p>Pizzas, Bergamo cuisine, desserts and wine list. Every dish is crafted with selected ingredients.</p>
      </div>
      <div class="grid-3">
        {[
          { label: 'The Pizzeria', desc: 'Classic, special, fun pizzas and focaccia — 31 wood-fired pizzas.', from: 'from \u20AC5.50' },
          { label: 'The Kitchen', desc: 'Casoncelli, risottos, beechwood grills and homemade desserts.', from: 'from \u20AC4.50' },
          { label: 'The Bar', desc: 'Draught beers, coffee, selected red and white wines.', from: 'from \u20AC1.40' },
        ].map(cat => (
          <div class="card card-body">
            <div class="card-label">{cat.label}</div>
            <p style="font-size:0.875rem; color:var(--text-muted); margin-bottom:0.5rem;">{cat.desc}</p>
            <div style="font-family:var(--font-display); font-weight:700; color:var(--accent-gold); font-size:1.1rem;">{cat.from}</div>
          </div>
        ))}
      </div>
      <div class="text-center mt-3">
        <a href={`${base}/en/menu/`} class="btn btn-primary">Full menu + Order from table</a>
      </div>
    </div>
  </section>

  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:0;">
    <div style="overflow:hidden; aspect-ratio:1;"><img src={`${base}/img/general_pizza_overview.png`} alt="" loading="lazy" style="width:100%; height:100%; object-fit:cover;" /></div>
    <div style="overflow:hidden; aspect-ratio:1;"><img src={`${base}/img/cucina_tipica.png`} alt="" loading="lazy" style="width:100%; height:100%; object-fit:cover;" /></div>
    <div style="overflow:hidden; aspect-ratio:1;"><img src={`${base}/img/team_2020.png`} alt="" loading="lazy" style="width:100%; height:100%; object-fit:cover;" /></div>
    <div style="overflow:hidden; aspect-ratio:1;"><img src={`${base}/img/trattoria_alpina_historical_photo.png`} alt="" loading="lazy" style="width:100%; height:100%; object-fit:cover;" /></div>
  </div>

  <section class="section reveal">
    <div class="container">
      <div class="grid-2" style="align-items:center; gap:3rem;">
        <div style="background:var(--blue-deep); border-radius:var(--radius-lg); padding:2.5rem; color:white;">
          <span class="kicker" style="color:var(--accent-gold);">Location</span>
          <h2 style="color:white; margin-bottom:1rem;">Valle Seriana,<br/>Bergamo hills</h2>
          <p style="color:rgba(255,255,255,0.75);">Orezzo is a small hamlet of Gazzaniga, on the right bank of the Serio river, at ~380m above sea level, 18km from Bergamo. Perfect for an evening out or a rustic festive lunch.</p>
          <a href={`${base}/en/area/`} class="btn btn-outline mt-2">Discover the area</a>
        </div>
        <div>
          <div class="contact-grid" style="display:grid; gap:1rem;">
            <div class="contact-item">
              <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
              <div class="contact-item-label">Address</div>
              <div class="contact-item-value">Via alla Chiesa, 4</div>
              <div class="contact-item-note">24025 Orezzo (BG), Italy</div>
            </div>
            <div class="contact-item">
              <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
              <div class="contact-item-label">Phone</div>
              <div class="contact-item-value"><a href="tel:+39035712021">+39 035 712021</a></div>
            </div>
          </div>
          <a href={`${base}/en/contact/`} class="btn btn-green mt-2">How to get here</a>
        </div>
      </div>
    </div>
  </section>


</BaseLayout>
