---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
const family = [
  {
    name: 'Alessandro Merelli',
    role: 'Il fondatore',
    text: 'Nel 1936 acquisisce l'edificio, gettando la prima pietra di ciò che diventerà un riferimento per Orezzo.',
  },
  {
    name: 'Tarcisio Merelli',
    role: 'Il maestro pizzaiolo',
    text: 'Apre la locanda nel 1959, costruisce forni, arriva finalista a Napoli nel 1989 e trasforma la trattoria in pizzeria.',
  },
  {
    name: 'Efrem Merelli',
    role: 'Seconda generazione',
    text: 'Affianca il padre nella trasformazione del locale e continua la tradizione con attenzione alla qualità e al cliente.',
  },
  {
    name: 'Laura Merla',
    role: 'Il cuore dell'accoglienza',
    text: 'Parte integrante della gestione fin dagli inizi della pizzeria, contribuisce a costruire il calore che i clienti ricordano.',
  },
];
---

<BaseLayout
  title="La famiglia — La Penzana del Merel"
  description="Tre generazioni della famiglia Merelli: il fondatore, il maestro pizzaiolo, chi ha fatto crescere il locale e chi lo tiene vivo ogni giorno."
  lang="it"
  currentPath={`${base}/famiglia/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">Famiglia</span>
      <h1 class="page-hero__title">Tre generazioni, un forno, lo stesso modo di accogliere.</h1>
      <p class="page-hero__lead">La Penzana del Merel non è solo un locale: è una storia di continuità. Persone diverse, stessa idea di cura, luogo e memoria.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="display:grid; gap:1.2rem; max-width:980px;">
      <div class="profile-grid">
        {family.map((member) => (
          <article class="profile-card reveal">
            <span class="profile-card__role">{member.role}</span>
            <h2>{member.name}</h2>
            <p>{member.text}</p>
          </article>
        ))}
      </div>

      <div class="story-quote reveal">
        <p>La famiglia Merelli non ha mai smesso di credere che il luogo contasse quanto la pizza. Forse è anche per questo che la gente continua a tornare.</p>
        <span class="story-quote__cite">Nota editoriale</span>
      </div>

      <div class="cta-row reveal">
        <a href={`${base}/storia/`} class="btn btn-primary">La storia completa</a>
        <a href={`${base}/contatti/`} class="btn btn-outline">Contattaci</a>
      </div>
    </div>
  </section>
</BaseLayout>
