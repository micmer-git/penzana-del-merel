---
import BaseLayout from '../layouts/BaseLayout.astro';
import Marquee from '../components/Marquee.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Contatti e come arrivare — La Penzana del Merel"
  description="Contatti e indicazioni per raggiungere La Penzana del Merel a Orezzo (BG). Via alla Chiesa 4, telefono 035 712021, Valle Seriana."
  lang="it"
  currentPath={`${base}/contatti/`}
>

  <section class="hero" style="padding-block:clamp(3rem,8vw,5rem);">
    <div class="container">
      <span class="hero-eyebrow">Contatti</span>
      <h1>Dove siamo e come prenotare</h1>
      <p>Siamo ad Orezzo, nella Valle Seriana. A 18 km da Bergamo, all'ombra del secolare ippocastano.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="contact-grid" style="margin-bottom:3rem;">
        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <div class="contact-item-label">Indirizzo</div>
          <div class="contact-item-value">Via alla Chiesa, 4</div>
          <div class="contact-item-note">24025 Orezzo (Gazzaniga), Bergamo, Italia</div>
        </div>

        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
          <div class="contact-item-label">Telefono</div>
          <div class="contact-item-value">
            <a href="tel:+390357121021">035 712021</a>
          </div>
          <div class="contact-item-note">Per prenotazioni e informazioni</div>
        </div>

        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div class="contact-item-label">Orari di apertura</div>
          <div class="contact-item-value">Contattare per orari</div>
          <div class="contact-item-note">
            Gli orari possono variare in base alla stagione. Chiamare per conferma.
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div class="contact-item-label">Prenotazioni</div>
          <div class="contact-item-value" style="color:var(--stone);">Su richiesta</div>
          <div class="contact-item-note">
            Contattare telefonicamente per prenotare il tavolo.
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></div>
          <div class="contact-item-label">Facebook</div>
          <div class="contact-item-value">
            <a href="https://www.facebook.com/LaPenzanaDelMerel/" target="_blank" rel="noopener noreferrer">
              LaPenzanaDelMerel
            </a>
          </div>
          <div class="contact-item-note">Aggiornamenti e foto</div>
        </div>

        <div class="contact-item">
          <div class="contact-item-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a4 4 0 0 0-8 0v2"/></svg></div>
          <div class="contact-item-label">Ordine dal tavolo</div>
          <div class="contact-item-value">QR code</div>
          <div class="contact-item-note">Scansiona il QR sul tavolo per ordinare via WhatsApp</div>
        </div>
      </div>

      <h2 style="margin-bottom:1.5rem;">Come raggiungerci</h2>
      <div class="grid-2" style="gap:2rem; margin-bottom:2rem;">
        <div>
          <h3>In auto</h3>
          <p>Autostrada A4 Milano–Venezia, uscita <strong>Seriate</strong> o <strong>Nembro</strong>, poi seguire la SP35 verso Gazzaniga–Orezzo. Circa 25–30 minuti dal casello.</p>
          <a
            href="https://www.google.com/maps/dir//Via+alla+Chiesa,+4,+24025+Orezzo+BG"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-green mt-2"
            style="display:inline-flex;"
          >Indicazioni stradali (Google Maps)</a>
        </div>
        <div>
          <h3>Con i mezzi pubblici</h3>
          <p>
            Verificare i collegamenti da Bergamo su <a href="https://www.bergamotrasporti.it" target="_blank" rel="noopener noreferrer">bergamotrasporti.it</a>. La Valle Seriana e servita da linee autobus SAB.
          </p>
        </div>
      </div>

      <!-- Map -->
      <div class="map-embed">
        <iframe
          title="Posizione La Penzana del Merel su mappa"
          src="https://www.openstreetmap.org/export/embed.html?bbox=9.79%2C45.78%2C9.86%2C45.83&layer=mapnik&marker=45.806%2C9.823"
          width="100%"
          height="400"
          style="border:0; display:block;"
          loading="lazy"
          aria-label="Mappa di Orezzo (BG)"
        ></iframe>
      </div>
      <p style="font-size:0.75rem; color:var(--stone); margin-top:0.5rem;">
        Mappa: OpenStreetMap contributors. Posizione indicativa — coordinate: 45.806, 9.823.
      </p>

    </div>
  </section>

  <Marquee lang="it" />

</BaseLayout>
