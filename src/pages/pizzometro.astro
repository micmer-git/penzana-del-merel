---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 200;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 1000;
const progressPct = Math.min((totalKm / trackMaxKm) * 100, 100);

const milestones = [
  { km: 0, label: 'La Penzana (Orezzo)', desc: 'Dove tutto è iniziato nel 1989', icon: '🏠' },
  { km: 3, label: 'Gazzaniga', desc: 'La conquista della valle', icon: '⛰️' },
  { km: 42.2, label: 'La Maratona della Pizza', desc: '42 km ininterrotti di impasto', icon: '🏃' },
  { km: 75, label: 'Piazza del Duomo, Milano', desc: 'Sotto lo sguardo della Madonnina', icon: '🏛️' },
  { km: 250, label: 'Venezia', desc: 'Attraverso la Pianura Padana', icon: '🛶' },
  { km: 500, label: 'Roma — Il Colosseo', desc: 'Mezzo migliaio di chilometri', icon: '🏟️' },
  { km: 800, label: 'Napoli', desc: 'La patria della pizza — obiettivo simbolico', icon: '🌋', isTarget: true },
];
---

<BaseLayout
  title="Pizzometro — Il Filo d'Oro"
  description="Dal 1989 ad oggi: quanta strada farebbero tutte le pizze della Penzana messe in fila? Un viaggio scrollytelling da Orezzo fino a Napoli."
  lang="it"
  pageType="website"
  currentPath={`${base}/pizzometro/`}
>

  <!-- Hero: animated km counter -->
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">Il Filo d'Oro</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzometro</span>
      </h1>
      <p class="pz-hero__subtitle">
        Dal {startYear}, ogni pizza sfornata aggiunge 33 cm al nostro filo d'oro.<br />
        Tarcisio diceva: <em>"Arriveremo fino a Napoli."</em>
      </p>
      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter" data-target={totalKm.toFixed(1)}>0</span>
        <span class="pz-hero__unit">km percorsi</span>
      </div>
      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{pizzasDelivered.toLocaleString('it-IT')}</span>
          <span class="pz-hero__stat-label">pizze sfornate</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} → {currentYear}</span>
          <span class="pz-hero__stat-label">anni di tradizione</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{annualKm.toFixed(1).replace('.', ',')} km</span>
          <span class="pz-hero__stat-label">ogni anno</span>
        </div>
      </div>
      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scorri per viaggiare</span>
      </div>
    </div>
  </section>

  <!-- Scrollytelling: sticky tracker + milestone cards -->
  <section class="pz-journey" aria-label="Viaggio simbolico da Orezzo a Napoli">
    <div class="pz-journey__container">

      <!-- Sticky left tracker -->
      <div class="pz-journey__tracker">
        <div class="pz-journey__line">
          <div class="pz-journey__line-fill" id="journey-line-fill"></div>
          <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
            <svg viewBox="0 0 48 48" width="48" height="48" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" fill="#f6d400" stroke="#101e8f" stroke-width="2"/>
              <circle cx="16" cy="18" r="3" fill="#dc2626" opacity="0.85"/>
              <circle cx="28" cy="14" r="2.5" fill="#dc2626" opacity="0.85"/>
              <circle cx="20" cy="28" r="2.8" fill="#dc2626" opacity="0.85"/>
              <circle cx="32" cy="26" r="2" fill="#dc2626" opacity="0.85"/>
              <circle cx="24" cy="22" r="2.2" fill="#16a34a" opacity="0.7"/>
              <circle cx="14" cy="26" r="1.5" fill="#16a34a" opacity="0.7"/>
              <circle cx="30" cy="32" r="1.8" fill="#16a34a" opacity="0.7"/>
            </svg>
          </div>
        </div>
        <div class="pz-journey__km-display" id="journey-km-display">
          <span class="pz-journey__km-value" id="journey-km-value">0</span>
          <span class="pz-journey__km-label">km</span>
        </div>
      </div>

      <!-- Milestone cards (right content) -->
      <div class="pz-journey__milestones">
        {milestones.map((m, i) => (
          <article
            class={`pz-milestone ${m.isTarget ? 'pz-milestone--target' : ''}`}
            data-km={m.km}
            data-index={i}
          >
            <div class="pz-milestone__icon">{m.icon}</div>
            <div class="pz-milestone__content">
              <span class="pz-milestone__km">{m.km} km</span>
              <h3 class="pz-milestone__title">{m.label}</h3>
              <p class="pz-milestone__desc">{m.desc}</p>
              {m.km <= totalKm ? (
                <span class="pz-milestone__badge pz-milestone__badge--reached">Raggiunto</span>
              ) : (
                <span class="pz-milestone__badge pz-milestone__badge--future">In arrivo</span>
              )}
            </div>
          </article>
        ))}

        <!-- ETA card -->
        <article class="pz-milestone pz-milestone--eta" data-km={trackMaxKm} data-index={milestones.length}>
          <div class="pz-milestone__icon">🎯</div>
          <div class="pz-milestone__content">
            <span class="pz-milestone__km">Stima arrivo Napoli</span>
            <h3 class="pz-milestone__title">Anno {etaNapoli}</h3>
            <p class="pz-milestone__desc">
              Con {annualKm.toFixed(2).replace('.', ',')} km/anno, mancano {Math.max(0, (napoliDistanceKm - totalKm)).toFixed(1).replace('.', ',')} km.
              Il filo d'oro continua a srotolarsi.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Post-order toast (hidden by default) -->
  <div class="pz-toast" id="pz-toast" role="alert" aria-live="assertive" hidden>
    <span class="pz-toast__icon">🍕</span>
    <span class="pz-toast__text" id="pz-toast-text"></span>
  </div>

  <style>
    /* ============================================
       PIZZOMETRO — IL FILO D'ORO
       Scrollytelling experience
       ============================================ */

    /* -- Hero -- */
    .pz-hero {
      min-height: 100svh;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--blue-deep);
      color: var(--white);
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .pz-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 20%, rgba(246,212,0,0.08) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 80%, rgba(25,51,197,0.15) 0%, transparent 50%);
      pointer-events: none;
    }
    /* Grain */
    .pz-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 150px;
      pointer-events: none;
      opacity: 0.25;
    }

    .pz-hero__inner {
      position: relative;
      z-index: 2;
      padding: 2rem clamp(1.25rem, 5vw, 3rem);
      max-width: 800px;
    }

    .pz-hero__kicker {
      display: inline-block;
      font-family: var(--font-subline);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent-gold);
      margin-bottom: 1rem;
    }

    .pz-hero__title {
      color: var(--white);
      margin-bottom: 1.5rem;
    }
    .pz-hero__script {
      font-family: var(--font-script);
      font-weight: 400;
      font-size: clamp(3.5rem, 10vw, 7rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
    }

    .pz-hero__subtitle {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.7);
      max-width: 560px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }
    .pz-hero__subtitle em {
      color: var(--accent-gold);
      font-family: var(--font-display);
    }

    /* Counter */
    .pz-hero__counter {
      margin-bottom: 2.5rem;
    }
    .pz-hero__number {
      display: block;
      font-family: var(--font-display);
      font-size: clamp(4rem, 12vw, 8rem);
      font-weight: 800;
      color: var(--accent-gold);
      line-height: 1;
      letter-spacing: -0.03em;
      text-shadow: 0 0 60px rgba(246,212,0,0.3);
    }
    .pz-hero__unit {
      display: block;
      font-family: var(--font-subline);
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-top: 0.5rem;
    }

    /* Stats row */
    .pz-hero__stats {
      display: flex;
      justify-content: center;
      gap: clamp(1.5rem, 4vw, 3rem);
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }
    .pz-hero__stat {
      text-align: center;
    }
    .pz-hero__stat-value {
      display: block;
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--white);
    }
    .pz-hero__stat-label {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-top: 0.2rem;
    }

    /* Scroll hint */
    .pz-hero__scroll-hint {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: rgba(255,255,255,0.35);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      animation: pzBounce 2s ease-in-out infinite;
    }
    @keyframes pzBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(8px); }
    }

    /* ============================================
       JOURNEY — Scrollytelling section
       ============================================ */
    .pz-journey {
      background: var(--blue-deep);
      position: relative;
      padding-block: clamp(4rem, 10vw, 8rem) clamp(6rem, 15vw, 12rem);
    }

    .pz-journey__container {
      max-width: var(--max-width);
      margin-inline: auto;
      padding-inline: clamp(1.25rem, 5vw, 3rem);
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: clamp(1.5rem, 4vw, 3rem);
    }

    /* Sticky tracker (left) */
    .pz-journey__tracker {
      position: sticky;
      top: 50%;
      transform: translateY(-50%);
      height: 300px;
      display: flex;
      flex-direction: column;
      align-items: center;
      z-index: 10;
      align-self: start;
    }

    .pz-journey__line {
      position: relative;
      width: 4px;
      height: 200px;
      background: rgba(255,255,255,0.12);
      border-radius: 999px;
      overflow: hidden;
    }
    .pz-journey__line-fill {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 0%;
      background: var(--accent-gold);
      border-radius: 999px;
      transition: height 0.1s linear;
    }

    .pz-journey__pizza {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translate(-50%, -50%);
      transition: top 0.1s linear;
      filter: drop-shadow(0 0 12px rgba(246,212,0,0.4));
    }

    .pz-journey__km-display {
      margin-top: 1rem;
      text-align: center;
    }
    .pz-journey__km-value {
      display: block;
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--accent-gold);
    }
    .pz-journey__km-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }

    /* Milestone cards (right) */
    .pz-journey__milestones {
      display: flex;
      flex-direction: column;
      gap: clamp(2rem, 5vw, 4rem);
    }

    .pz-milestone {
      display: flex;
      gap: 1.25rem;
      padding: clamp(1.25rem, 3vw, 2rem);
      border-radius: var(--radius-lg);
      border-left: 4px solid transparent;
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      opacity: 0;
      transform: translateY(40px) translateX(20px);
      transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out), border-color 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
    }
    .pz-milestone.is-active {
      opacity: 1;
      transform: translateY(0) translateX(0);
      border-left-color: var(--accent-gold);
      background: rgba(255,255,255,0.06);
    }

    .pz-milestone__icon {
      font-size: 2rem;
      flex-shrink: 0;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .pz-milestone__content {
      flex: 1;
      min-width: 0;
    }
    .pz-milestone__km {
      display: inline-block;
      font-family: var(--font-subline);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent-gold);
      margin-bottom: 0.3rem;
    }
    .pz-milestone__title {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2.5vw, 1.6rem);
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.4rem;
      line-height: 1.2;
    }
    .pz-milestone__desc {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      margin-bottom: 0.6rem;
    }
    .pz-milestone__badge {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
    }
    .pz-milestone__badge--reached {
      background: rgba(22,163,74,0.2);
      color: #4ade80;
    }
    .pz-milestone__badge--future {
      background: rgba(246,212,0,0.1);
      color: var(--accent-gold);
    }

    /* Target milestone (Napoli) glow */
    .pz-milestone--target.is-active {
      box-shadow: 0 0 40px rgba(246,212,0,0.15), inset 0 0 30px rgba(246,212,0,0.03);
      border-left-color: var(--accent-gold);
    }
    .pz-milestone--target .pz-milestone__title {
      color: var(--accent-gold);
    }

    /* ETA card */
    .pz-milestone--eta.is-active {
      background: rgba(246,212,0,0.06);
      border-left-color: rgba(255,255,255,0.3);
    }

    /* ============================================
       POST-ORDER TOAST
       ============================================ */
    .pz-toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(120%);
      background: var(--accent-gold);
      color: var(--blue-deep);
      padding: 0.8rem 1.5rem;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      z-index: var(--z-modal);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      transition: transform 0.5s var(--ease-spring);
      white-space: nowrap;
    }
    .pz-toast.is-visible {
      transform: translateX(-50%) translateY(0);
    }
    .pz-toast__icon {
      font-size: 1.3rem;
    }

    /* ============================================
       MOBILE RESPONSIVE
       ============================================ */
    @media (max-width: 768px) {
      .pz-journey__container {
        grid-template-columns: 40px 1fr;
        gap: 1rem;
      }
      .pz-journey__tracker {
        height: 200px;
      }
      .pz-journey__line {
        width: 3px;
        height: 140px;
      }
      .pz-journey__pizza svg {
        width: 32px;
        height: 32px;
      }
      .pz-journey__km-display {
        display: none;
      }
      .pz-milestone {
        flex-direction: column;
        gap: 0.75rem;
        padding: 1rem;
      }
      .pz-milestone__icon {
        width: 36px;
        height: 36px;
        font-size: 1.5rem;
      }
      .pz-hero__stats {
        gap: 1rem;
      }
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .pz-milestone {
        opacity: 1;
        transform: none;
      }
      .pz-hero__scroll-hint {
        animation: none;
      }
      .pz-journey__pizza,
      .pz-journey__line-fill {
        transition: none;
      }
    }
  </style>

  <!-- GSAP + ScrollTrigger CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // ---- HERO COUNTER ANIMATION ----
      const counterEl = document.getElementById('km-counter');
      if (counterEl) {
        const target = parseFloat(counterEl.dataset.target);
        const duration = 2500;
        const start = performance.now();

        function animateCounter(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          // Ease out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = (eased * target).toFixed(1).replace('.', ',');
          counterEl.textContent = current;
          if (progress < 1) requestAnimationFrame(animateCounter);
        }
        requestAnimationFrame(animateCounter);
      }

      // ---- SCROLLTRIGGER: MILESTONE REVEAL ----
      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);

        // Reveal milestones
        const milestones = document.querySelectorAll('.pz-milestone');
        milestones.forEach((el) => {
          ScrollTrigger.create({
            trigger: el,
            start: 'top 80%',
            onEnter: () => el.classList.add('is-active'),
          });
        });

        // Journey progress tracker
        const journeySection = document.querySelector('.pz-journey');
        const lineFill = document.getElementById('journey-line-fill');
        const pizza = document.getElementById('journey-pizza');
        const kmValue = document.getElementById('journey-km-value');
        const maxKm = 1000;

        if (journeySection && lineFill && pizza && kmValue) {
          ScrollTrigger.create({
            trigger: journeySection,
            start: 'top top',
            end: 'bottom bottom',
            scrub: 1,
            onUpdate: (self) => {
              const pct = self.progress * 100;
              lineFill.style.height = pct + '%';
              pizza.style.top = pct + '%';

              // Map scroll progress to km
              const currentKm = Math.round(self.progress * maxKm);
              kmValue.textContent = currentKm;
            },
          });
        }
      }

      // ---- POST-ORDER TOAST ----
      const params = new URLSearchParams(window.location.search);
      const addedPizzas = parseInt(params.get('addedPizzas'), 10);
      if (addedPizzas > 0) {
        const toast = document.getElementById('pz-toast');
        const toastText = document.getElementById('pz-toast-text');
        if (toast && toastText) {
          const addedMeters = (addedPizzas * 33 / 100).toFixed(1).replace('.', ',');
          toastText.textContent = '+' + addedPizzas + ' pizze ordinate! Il filo d\u2019oro cresce di ' + addedMeters + ' m';
          toast.removeAttribute('hidden');

          // Animate counter from (total - added) to total
          if (counterEl) {
            const totalTarget = parseFloat(counterEl.dataset.target);
            const addedKm = (addedPizzas * 33) / 100000;
            const fromKm = totalTarget - addedKm;
            counterEl.textContent = fromKm.toFixed(1).replace('.', ',');

            setTimeout(() => {
              const dur = 1500;
              const s = performance.now();
              function recount(now) {
                const elapsed = now - s;
                const p = Math.min(elapsed / dur, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                const val = (fromKm + eased * addedKm).toFixed(1).replace('.', ',');
                counterEl.textContent = val;
                if (p < 1) requestAnimationFrame(recount);
              }
              requestAnimationFrame(recount);
            }, 500);
          }

          // Show toast
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              toast.classList.add('is-visible');
            });
          });

          // Auto-dismiss
          setTimeout(() => {
            toast.classList.remove('is-visible');
            setTimeout(() => { toast.setAttribute('hidden', ''); }, 600);
          }, 8000);
        }
      }
    });
  </script>

</BaseLayout>
