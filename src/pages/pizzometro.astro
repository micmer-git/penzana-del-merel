---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 300;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const trackMaxKm = 800;

// --- Driver models ---
const familyEntries = [
  { name: 'Michele', year: 1994 + 4 },
  { name: 'Luca', year: 1995 + 4 },
  { name: 'Alessandro', year: 1998 + 4 },
  { name: 'Giacomo', year: 2004 + 4 },
  { name: 'Chiara', year: 2007 + 4 },
];

function weeksBetween(from: Date, to: Date) {
  return Math.max(0, Math.floor((to.getTime() - from.getTime()) / (1000 * 60 * 60 * 24 * 7)));
}

function computeBrunoModel(nowDate: Date) {
  const perWeek = 5;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeFamilyModel(nowDate: Date) {
  let pizzas = 0;
  let last = new Date(startYear, 0, 1);
  let people = 3;
  const perPerson = 3;
  const sorted = [...familyEntries].sort((a, b) => a.year - b.year);
  for (const e of sorted) {
    const eventDate = new Date(e.year, 0, 1);
    if (eventDate > nowDate) break;
    pizzas += weeksBetween(last, eventDate) * people * perPerson;
    people += 1;
    last = eventDate;
  }
  pizzas += weeksBetween(last, nowDate) * people * perPerson;
  const perWeekNow = people * perPerson;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeekNow * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeekNow, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeAllClientsModel(nowDate: Date) {
  const perWeek = pizzasPerWeek;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

const brunoModel = computeBrunoModel(now);
const familyModel = computeFamilyModel(now);
const allClientsModel = computeAllClientsModel(now);

// Birth years of the Merelli children
const births = [
  { name: 'Michele', birthYear: 1994 },
  { name: 'Luca', birthYear: 1995 },
  { name: 'Alessandro', birthYear: 1998 },
  { name: 'Giacomo', birthYear: 2004 },
  { name: 'Chiara', birthYear: 2007 },
];

// --- Build milestones (main journey 0–800 km) ---
interface Milestone {
  km: number;
  label: string;
  body: string;
  icon: string;
  fun: string;
  year: number;
  type: 'geo' | 'fun' | 'birth';
  isTarget?: boolean;
  isOrigin?: boolean;
}

const geoMilestones: Milestone[] = [
  { km: 0, label: 'La Penzana (Orezzo)', body: 'Dove tutto è iniziato: mani infarinate, brace viva, profumo di casa.', icon: '🏠', year: 1989, fun: 'Pizza numero uno: forse storta. Sicuramente memorabile.', type: 'geo', isOrigin: true },
  { km: 3, label: 'Gazzaniga', body: 'Tre chilometri di pizza messi in fila: abbastanza per farsi notare in valle.', icon: '⛰️', year: Math.round(startYear + 3 / annualKm), fun: 'Qui la domanda è una sola: ne portate ancora?', type: 'geo' },
  { km: 12, label: 'Bergamo — Città Alta', body: 'Il filo raggiunge la città alta e si arrampica con calma tra pietra e farina.', icon: '🏰', year: Math.round(startYear + 12 / annualKm), fun: 'Una rotonda di pizza in Piazza Vecchia? Quasi.', type: 'geo' },
  { km: 42.2, label: 'La Maratona della Pizza', body: 'Una maratona simbolica fatta di impasti stesi e serate che finiscono tardi.', icon: '🏃', year: Math.round(startYear + 42.2 / annualKm), fun: 'Niente scarpe tecniche: solo pala, forno e costanza.', type: 'geo' },
  { km: 60, label: 'Milano — Il Duomo', body: 'Sotto la Madonnina il filo resta semplice: pizza buona, senza sovrastrutture.', icon: '🏛️', year: Math.round(startYear + 60 / annualKm), fun: 'A Milano chiedono se è gourmet. A Orezzo basta che sia buonissima.', type: 'geo' },
  { km: 130, label: 'Piacenza', body: 'La strada si allunga e il viaggio comincia a parlare diverse cucine.', icon: '🧀', year: Math.round(startYear + 130 / annualKm), fun: 'Tra salumi e pizza, l\'intesa è immediata.', type: 'geo' },
  { km: 180, label: 'Parma', body: 'Il filo d\'oro continua senza cambiare accento: artigianale, diretto, sincero.', icon: '🍖', year: Math.round(startYear + 180 / annualKm), fun: 'Verdi scriveva opere. Noi scriviamo serate riuscite.', type: 'geo' },
  { km: 260, label: 'Bologna — Le Due Torri', body: 'Attraversa il cuore d\'Italia tenendo insieme tradizione e fame vera.', icon: '🏗️', year: Math.round(startYear + 260 / annualKm), fun: 'Bologna ha i tortellini. Noi portiamo la Diavola. Pari.', type: 'geo' },
  { km: 360, label: 'Firenze — Ponte Vecchio', body: 'Rinascimento e pizza condividono una dote: non stancano mai.', icon: '🎨', year: Math.round(startYear + 360 / annualKm), fun: 'Leonardo avrebbe progettato una macchina per stendere l\'impasto.', type: 'geo' },
  { km: 430, label: 'Siena — Piazza del Campo', body: 'Ogni pizza tiene il ritmo del viaggio: lento, preciso, ostinato.', icon: '🐎', year: Math.round(startYear + 430 / annualKm), fun: 'Il Palio è rapidissimo. La lievitazione no, e va bene così.', type: 'geo' },
  { km: 500, label: 'Orvieto', body: 'A questa altezza il viaggio sembra impossibile solo a chi non conosce la costanza.', icon: '⛪', year: Math.round(startYear + 500 / annualKm), fun: 'Cinquecento chilometri di pizza sono una misura che va rispettata.', type: 'geo' },
  { km: 560, label: 'Roma — Il Colosseo', body: 'La capitale osserva, il forno continua, la rotta non cambia.', icon: '🏟️', year: Math.round(startYear + 560 / annualKm), fun: 'Il pubblico alza il pollice: Margherita salva tutti.', type: 'geo' },
  { km: 650, label: 'Cassino — Montecassino', body: 'Tra memoria e silenzio il filo d\'oro resta acceso e va avanti.', icon: '🕍', year: Math.round(startYear + 650 / annualKm), fun: 'Pane, pizza, pazienza: certe cose stanno sempre bene insieme.', type: 'geo' },
  { km: 720, label: 'Caserta — La Reggia', body: 'Un palazzo da re e una pizza per tutti: equilibrio perfetto.', icon: '👑', year: Math.round(startYear + 720 / annualKm), fun: 'La Reggia ha mille stanze. A noi basta il forno giusto.', type: 'geo' },
  { km: 780, label: 'Aversa', body: 'Ultima salita emotiva prima della patria simbolica della pizza.', icon: '🔥', year: Math.round(startYear + 780 / annualKm), fun: 'Qui la tensione cresce come l\'impasto fatto bene.', type: 'geo' },
  { km: 800, label: 'Napoli — Via dei Tribunali', body: 'La patria della pizza è lì davanti: Tarcisio ci aveva visto lungo.', icon: '🌋', isTarget: true, year: Math.round(startYear + 800 / annualKm), fun: 'Arrivarci con un filo di pizze è poesia pratica.', type: 'geo' },
];

const funMilestones: Milestone[] = [
  { km: (1000 * 33) / 100000, label: '1.000 Pizze', body: 'Le prime mille. Mille volte l\'impasto ha preso forma, mille volte il forno ha fatto il suo dovere.', icon: '🎯', fun: 'Se le metti in fila: 330 metri di pizza. Quasi un giro di pista.', year: Math.round(startYear + ((1000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (10000 * 33) / 100000, label: '10.000 Pizze', body: 'Diecimila pizze significano diecimila serate, diecimila tavoli, diecimila storie diverse.', icon: '🎪', fun: 'A quest\'altezza il profumo si sente da Gazzaniga.', year: Math.round(startYear + ((10000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (50000 * 33) / 100000, label: '1 Elefante di Mozzarella', body: 'Cinquantamila pizze con 100g di mozzarella ciascuna. Totale: 5 tonnellate. Il peso di un elefante africano.', icon: '🐘', fun: 'Jumbo approverebbe.', year: Math.round(startYear + ((50000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (100000 * 33) / 100000, label: '100.000 Pizze', body: 'Un numero che non si visualizza, si sente: nel calore del forno, nelle mani della famiglia.', icon: '🏆', fun: 'Abbastanza per dar da mangiare a Bergamo intera. Due volte.', year: Math.round(startYear + ((100000 * 33) / 100000) / annualKm), type: 'fun' },
  { km: (1000000 * 33) / 100000, label: '1.000.000 Pizze', body: 'Un milione di pizze. A quel punto il filo d\'oro non è più un filo, è un\'autostrada.', icon: '💎', fun: 'Un milione di motivi per tornare a Orezzo.', year: Math.round(startYear + ((1000000 * 33) / 100000) / annualKm), type: 'fun' },
];

const birthMilestones: Milestone[] = births.map(b => ({
  km: (b.birthYear - startYear) * annualKm,
  label: `Nasce ${b.name}`,
  body: `${b.birthYear} — un Merelli in più al tavolo.`,
  icon: '👶',
  fun: `La famiglia cresce, il filo si allunga.`,
  year: b.birthYear,
  type: 'birth' as const,
}));

// Merge and sort all main milestones by km
const allMainMilestones = [...geoMilestones, ...funMilestones, ...birthMilestones].sort((a, b) => a.km - b.km);

// --- Compute positions with min-gap enforcement ---
const milestoneCount = allMainMilestones.length;
const minGapPct = 100 / (milestoneCount + 1);

let positions = allMainMilestones.map(m => ({
  ...m,
  pct: (m.km / trackMaxKm) * 100,
}));

// Enforce minimum gap
for (let i = 1; i < positions.length; i++) {
  if (positions[i].pct - positions[i - 1].pct < minGapPct) {
    positions[i].pct = positions[i - 1].pct + minGapPct;
  }
}

// Normalize so last milestone is at ~95% (leaving room for ETA)
const maxPct = positions[positions.length - 1].pct;
if (maxPct > 0) {
  positions = positions.map(p => ({ ...p, pct: (p.pct / maxPct) * 95 }));
}

// Build position-to-km mapping for JS interpolation
const posKmMap = positions.map(p => ({ pct: p.pct, km: p.km }));

// --- Post-Napoli dream milestones (separate section) ---
const dreamMilestones = [
  { label: 'Giro d\'Italia in Pizza', body: 'L\'intero stivale, coperto di impasto. Da Orezzo a Lampedusa e ritorno.', icon: '🇮🇹', fun: 'Lo stivale non è mai stato così saporito.', km: 1500 },
  { label: 'Equatore di Mozzarella', body: 'Abbastanza mozzarella da fare il giro dell\'equatore. Il peso? Non chiedere.', icon: '🧭', fun: 'L\'equatore è caldo. Come il forno.', km: 3500 },
  { label: '1 Piscina Olimpica di Pomodoro', body: `${Math.round(2500000000 / 150).toLocaleString('it-IT')} pizze con 150ml di pomodoro ciascuna. Una piscina olimpica intera.`, icon: '🏊', fun: 'Tuffarsi nel sugo: da bambini lo sognavamo tutti.', km: 5500 },
  { label: 'Da Orezzo a Tokyo', body: 'Diecimila chilometri di filo d\'oro. Il forno non conosce fuso orario.', icon: '🗾', fun: 'In Giappone la pizza è arte. A Orezzo anche.', km: 10000 },
  { label: 'Giro del Mondo', body: '40.075 km. Il filo d\'oro avvolge il pianeta. A quel punto, siamo leggenda.', icon: '🌍', fun: 'Tarcisio non si fermava ai confini. Nemmeno noi.', km: 40075 },
];

// Funny interstitial comments for post-Napoli scrolling
const dreamComments = [
  'Il forno non si spegne mai.',
  'A questo punto, il lievito ha diritto al passaporto.',
  'Tarcisio lo sapeva: non c\'è limite alla pasta.',
  'La pizza non conosce confini. Solo frontiere da superare.',
  'Ogni pizza ci avvicina. A cosa? A tutto.',
  'Il filo d\'oro non ha fretta. Ha costanza.',
];

// Timeline height: main = milestoneCount * 120vh, post-Napoli has its own section
---

<BaseLayout
  title="Pizzometro — Il Filo d'Oro"
  description="Dal 1989 ad oggi: quanta strada farebbero tutte le pizze della Penzana messe in fila? Un viaggio verticale da Orezzo fino a Napoli, attraverso la Val Seriana e l'Italia intera."
  lang="it"
  pageType="website"
  currentPath={`${base}/pizzometro/`}
>
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">Il Filo d'Oro</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzometro</span>
      </h1>
      <p class="pz-hero__subtitle">
        Dal {startYear}, ogni pizza sfornata aggiunge 33 cm al nostro filo d'oro.<br />
        Tarcisio diceva: <em>"Arriveremo fino a Napoli."</em>
      </p>

      <div class="pz-driver" aria-label="Selettore filometro">
        <span class="pz-driver__label">Chi mangia?</span>
        <div class="pz-driver__controls">
          <button type="button" class="pz-driver__btn is-active" data-mode="all" id="driver-btn-all">Tutti i clienti</button>
          <button type="button" class="pz-driver__btn" data-mode="bruno" id="driver-btn-bruno">Bruno</button>
          <button type="button" class="pz-driver__btn" data-mode="family" id="driver-btn-family">Famiglia Merelli</button>
          <button type="button" class="pz-driver__info" id="filometro-info-btn" aria-label="Info formula">i</button>
        </div>
        <div class="pz-driver__popup" id="filometro-popup" hidden>
          <button type="button" class="pz-driver__close" id="filometro-popup-close" aria-label="Chiudi">&times;</button>
          <strong>Tutti i clienti</strong> — 300 pizze a settimana, il forno intero dal 1989.<br/>
          <strong>Bruno</strong> — cliente fedele, 5 pizze a settimana dal 1989.<br/>
          <strong>Famiglia Merelli</strong> — 3 persone &times; 3 pizze/settimana, poi +1 persona per ogni figlio dopo i 4 anni.
        </div>
      </div>

      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter"
          data-target={allClientsModel.totalKm.toFixed(1)}
          data-bruno={brunoModel.totalKm.toFixed(1)}
          data-family={familyModel.totalKm.toFixed(1)}
          data-all={allClientsModel.totalKm.toFixed(1)}>0,0</span>
        <span class="pz-hero__unit">km percorsi</span>
        <span class="pz-hero__subcount">
          <strong id="pizza-counter"
            data-target={allClientsModel.pizzasDelivered}
            data-bruno={brunoModel.pizzasDelivered}
            data-family={familyModel.pizzasDelivered}
            data-all={allClientsModel.pizzasDelivered}>{allClientsModel.pizzasDelivered.toLocaleString('it-IT')}</strong>
          pizze sfornate in totale
        </span>
      </div>

      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} &rarr; {currentYear}</span>
          <span class="pz-hero__stat-label">anni di tradizione</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value"><span id="stat-annual"
            data-bruno={brunoModel.annualKm.toFixed(1)}
            data-family={familyModel.annualKm.toFixed(1)}
            data-all={allClientsModel.annualKm.toFixed(1)}>{allClientsModel.annualKm.toFixed(1).replace('.', ',')}</span> km</span>
          <span class="pz-hero__stat-label">ogni anno</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">33 cm</span>
          <span class="pz-hero__stat-label">per ogni pizza</span>
        </div>
      </div>

      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scorri per viaggiare</span>
      </div>
    </div>
  </section>

  <!-- Main journey: 0–800 km -->
  <section class="pz-journey" aria-label="Viaggio simbolico da Orezzo a Napoli">
    <div class="pz-journey__container">
      <div class="pz-journey__timeline" id="journey-timeline" style={`--mc: ${milestoneCount};`}>
        <div class="pz-journey__rail">
          <div class="pz-journey__rail-fill" id="journey-line-fill"></div>
        </div>

        <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
          <div class="pz-journey__pizza-body" id="journey-pizza-body">
            <svg viewBox="0 0 56 56" width="56" height="56" xmlns="http://www.w3.org/2000/svg">
              <path d="M28 4 L50 46 Q28 52 6 46 Z" fill="#f6d400" stroke="var(--blue-deep)" stroke-width="2" stroke-linejoin="round"/>
              <path d="M6 46 Q28 52 50 46" fill="#e2be00" stroke="var(--blue-deep)" stroke-width="2"/>
              <circle cx="24" cy="22" r="3.5" fill="#dc2626" opacity="0.9"/>
              <circle cx="33" cy="28" r="3" fill="#dc2626" opacity="0.85"/>
              <circle cx="22" cy="34" r="2.8" fill="#dc2626" opacity="0.85"/>
              <circle cx="28" cy="16" r="2" fill="#16a34a" opacity="0.7"/>
              <circle cx="18" cy="28" r="1.8" fill="#16a34a" opacity="0.7"/>
              <circle cx="34" cy="38" r="2.2" fill="#f5f5dc" opacity="0.6"/>
            </svg>
          </div>
          <div class="pz-journey__pizza-stats">
            <span class="pz-journey__counter-km" id="journey-km-value">0,0</span>
            <span class="pz-journey__counter-label" id="journey-unit-label">metri percorsi</span>
            <span class="pz-journey__counter-year" id="journey-year-value">{startYear}</span>
          </div>
        </div>

        {positions.map((ms, index) => {
          const side = index % 2 === 0 ? 'left' : 'right';
          const showQuoteOutside = ms.isOrigin || ms.type === 'fun';
          return (
            <article
              class={`pz-marker pz-marker--${side} ${ms.isTarget ? 'pz-marker--target' : ''} ${ms.type === 'fun' ? 'pz-marker--fun' : ''} ${ms.type === 'birth' ? 'pz-marker--birth' : ''}`}
              style={`top: ${ms.pct}%;`}
              data-km={ms.km}
              data-year={ms.year}
            >
              {showQuoteOutside && (
                <p class="pz-typo-quote">{ms.body}</p>
              )}
              <div class="pz-marker__body">
                <div class="pz-marker__dot">
                  <span class="pz-marker__icon">{ms.icon}</span>
                </div>
                <div class="pz-marker__card">
                  <div class="pz-marker__meta">
                    <span class="pz-marker__km-tag">{ms.km < 1 ? `${Math.round(ms.km * 1000)} m` : `${Math.round(ms.km * 10) / 10} km`}</span>
                    <span class="pz-marker__year-tag">~{ms.year}</span>
                    {ms.km <= totalKm ? (
                      <span class="pz-marker__badge pz-marker__badge--reached">raggiunta</span>
                    ) : (
                      <span class="pz-marker__badge pz-marker__badge--future">in vista</span>
                    )}
                  </div>
                  <h2 class="pz-marker__title">{ms.label}</h2>
                  {!showQuoteOutside && <p class="pz-marker__bodycopy">{ms.body}</p>}
                  <p class="pz-marker__fun">{ms.fun}</p>
                </div>
              </div>
            </article>
          );
        })}

        <article
          class="pz-marker pz-marker--left pz-marker--eta"
          style="top: 98%;"
          data-km={trackMaxKm}
        >
          <div class="pz-marker__body">
            <div class="pz-marker__dot"><span class="pz-marker__icon">🎯</span></div>
            <div class="pz-marker__card">
              <div class="pz-marker__meta">
                <span class="pz-marker__km-tag">stima arrivo</span>
                <span class="pz-marker__year-tag">~<span id="eta-year"
                  data-bruno={brunoModel.etaNapoli}
                  data-family={familyModel.etaNapoli}
                  data-all={allClientsModel.etaNapoli}>{allClientsModel.etaNapoli}</span></span>
              </div>
              <h2 class="pz-marker__title">Napoli — Anno <span id="eta-title-year">{allClientsModel.etaNapoli}</span></h2>
              <p class="pz-marker__bodycopy">
                Mancano <span id="eta-remaining"
                  data-bruno={Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1)}
                  data-family={Math.max(0, (napoliDistanceKm - familyModel.totalKm)).toFixed(1)}
                  data-all={Math.max(0, (napoliDistanceKm - allClientsModel.totalKm)).toFixed(1)}>{Math.max(0, (napoliDistanceKm - allClientsModel.totalKm)).toFixed(1).replace('.', ',')}</span> km. Ogni pizza accorcia il viaggio di 33 cm.
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Post-Napoli dream section -->
  <section class="pz-beyond" aria-label="E dopo Napoli?">
    <div class="pz-beyond__intro">
      <h2 class="pz-beyond__title">E dopo Napoli?</h2>
      <p class="pz-beyond__subtitle">Il forno non si spegne. Il filo continua.</p>
    </div>

    <div class="pz-beyond__timeline">
      {dreamMilestones.map((dm, i) => (
        <div class="pz-beyond__block">
          {i > 0 && (
            <p class="pz-beyond__comment">{dreamComments[i % dreamComments.length]}</p>
          )}
          <article class="pz-marker pz-marker--dream is-visible">
            <p class="pz-typo-quote">{dm.body}</p>
            <div class="pz-marker__body">
              <div class="pz-marker__dot">
                <span class="pz-marker__icon">{dm.icon}</span>
              </div>
              <div class="pz-marker__card">
                <div class="pz-marker__meta">
                  <span class="pz-marker__km-tag">{dm.km.toLocaleString('it-IT')} km</span>
                  <span class="pz-marker__badge pz-marker__badge--future">sogno</span>
                </div>
                <h2 class="pz-marker__title">{dm.label}</h2>
                <p class="pz-marker__fun">{dm.fun}</p>
              </div>
            </div>
          </article>
        </div>
      ))}

