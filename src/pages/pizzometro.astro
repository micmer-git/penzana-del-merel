---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 200;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const milestones = [
  { km: 10, label: 'Dintorni di Orezzo' },
  { km: 50, label: 'Verso la pianura bergamasca' },
  { km: 100, label: 'Area Milano-Brianza' },
  { km: 250, label: 'Emilia (proiezione)' },
  { km: 500, label: 'Centro Italia (proiezione)' },
  { km: 800, label: 'Napoli (obiettivo simbolico)' },
  { km: 1000, label: 'Oltre Napoli' },
];

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 1000;
const progressPct = Math.min((totalKm / trackMaxKm) * 100, 100);
---

<BaseLayout
  title="Pizzometro — La Penzana del Merel"
  description="Dal 1989 ad oggi: quanta strada farebbero tutte le pizze della Penzana messe in fila? Un viaggio simbolico da Orezzo fino a Napoli e oltre."
  lang="it"
  pageType="article"
  currentPath={`${base}/pizzometro/`}
>
  <section class="hero" style="padding-block:clamp(3rem,9vw,6rem);">
    <div class="container pizzometro-hero">
      <span class="hero-eyebrow">Pizzometro</span>
      <h1>Quanta strada hanno fatto le pizze della Penzana?</h1>
      <p>
        Tarcisio diceva spesso che, con tutte le pizze consegnate, si sarebbe arrivati fino a Napoli.
        Abbiamo fatto i conti con un'ipotesi semplice: <strong>dal 1989, circa 200 pizze a settimana</strong>,
        con fisiologiche variazioni stagionali.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container pizzometro-shell">
      <div class="pizzometro-stats">
        <article class="card stat-card">
          <p>Periodo considerato</p>
          <strong>{startYear} → {currentYear}</strong>
        </article>
        <article class="card stat-card">
          <p>Pizze stimate consegnate</p>
          <strong>{pizzasDelivered.toLocaleString('it-IT')}</strong>
        </article>
        <article class="card stat-card">
          <p>Strada totale (diametro 33 cm)</p>
          <strong>{totalKm.toFixed(1).replace('.', ',')} km</strong>
        </article>
      </div>

      <div class="path-card card">
        <h2>Il percorso simbolico: da Orezzo a Napoli (e oltre)</h2>
        <p class="path-sub">La pizza qui sotto avanza lentamente da sinistra verso destra: è il nostro “contachilometri” della tradizione.</p>

        <div class="pizza-track" style={`--progress:${progressPct}%;`}>
          {milestones.map((m) => (
            <div class="milestone" style={`left:${(m.km / trackMaxKm) * 100}%;`}>
              <span class="dot"></span>
              <span class="label">{m.km} km · {m.label}</span>
            </div>
          ))}

          <div class="pizza-runner" aria-hidden="true">
            <span>🍕</span>
          </div>

          <div class="current-marker" style={`left:${progressPct}%;`}>
            <span>Oggi: {totalKm.toFixed(1).replace('.', ',')} km</span>
          </div>
        </div>

        <p class="path-foot">
          Con questo ritmo medio (
          {annualKm.toFixed(2).replace('.', ',')} km/anno), la soglia simbolica di <strong>Napoli (800 km)</strong>
          verrebbe raggiunta intorno al <strong>{etaNapoli}</strong>.
        </p>
      </div>
    </div>
  </section>

  <style>
    .pizzometro-hero {
      max-width: 820px;
    }
    .pizzometro-shell {
      display: grid;
      gap: 1.2rem;
    }
    .pizzometro-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
    }
    .stat-card {
      padding: 1rem;
      border-radius: var(--radius-lg);
    }
    .stat-card p {
      margin: 0;
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }
    .stat-card strong {
      display: block;
      margin-top: 0.35rem;
      color: var(--blue-deep);
      font-size: clamp(1.1rem, 2vw, 1.5rem);
    }
    .path-card {
      padding: clamp(1rem, 2.5vw, 1.5rem);
      border-radius: var(--radius-lg);
    }
    .path-card h2 {
      margin-bottom: 0.45rem;
    }
    .path-sub {
      margin-top: 0;
      color: var(--text-muted);
    }

    .pizza-track {
      --track: #d9dee8;
      position: relative;
      margin-top: 1.25rem;
      height: 240px;
      border: 1px solid var(--slate-xlight);
      border-radius: var(--radius-lg);
      background:
        linear-gradient(to bottom, #fff 0%, #f7f8fb 100%);
      overflow: hidden;
    }
    .pizza-track::before {
      content: '';
      position: absolute;
      left: 3%;
      right: 3%;
      top: 52%;
      height: 4px;
      border-radius: 999px;
      background: var(--track);
    }
    .pizza-track::after {
      content: '';
      position: absolute;
      left: 3%;
      width: calc((var(--progress) * 0.94));
      max-width: 94%;
      top: 52%;
      height: 4px;
      border-radius: 999px;
      background: var(--accent-gold);
    }
    .milestone {
      position: absolute;
      top: 34%;
      transform: translateX(-50%);
      text-align: center;
      width: 120px;
    }
    .milestone .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--blue-deep);
      display: inline-block;
      margin-bottom: 0.45rem;
    }
    .milestone .label {
      display: block;
      color: var(--blue-deep);
      font-size: 0.68rem;
      line-height: 1.3;
      font-weight: 600;
    }

    .pizza-runner {
      position: absolute;
      top: 57%;
      left: 3%;
      transform: translate(-50%, -50%);
      animation: runPizza 14s ease-in-out infinite alternate;
    }
    .pizza-runner span {
      display: block;
      font-size: clamp(1.9rem, 4vw, 2.6rem);
      filter: drop-shadow(0 4px 6px rgba(15, 23, 42, 0.2));
    }

    .current-marker {
      position: absolute;
      bottom: 18px;
      transform: translateX(-50%);
      background: var(--blue-deep);
      color: var(--white);
      border-radius: 999px;
      padding: 0.3rem 0.7rem;
      font-size: 0.72rem;
      font-weight: 700;
      white-space: nowrap;
    }
    .path-foot {
      margin-top: 1rem;
      margin-bottom: 0;
    }

    @keyframes runPizza {
      from { left: 3%; }
      to { left: calc(3% + (var(--progress) * 0.94)); }
    }

    @media (max-width: 840px) {
      .pizzometro-stats {
        grid-template-columns: 1fr;
      }
      .pizza-track {
        height: 300px;
      }
      .milestone {
        width: 90px;
      }
      .milestone .label {
        font-size: 0.62rem;
      }
    }
  </style>
</BaseLayout>
