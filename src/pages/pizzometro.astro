---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/penzana-del-merel';
const startYear = 1989;
const now = new Date();
const currentYear = now.getFullYear();
const pizzasPerWeek = 300;
const pizzaDiameterCm = 33;

const weeksSinceStart = Math.floor((now.getTime() - new Date(startYear, 0, 1).getTime()) / (1000 * 60 * 60 * 24 * 7));
const pizzasDelivered = weeksSinceStart * pizzasPerWeek;
const totalKm = (pizzasDelivered * pizzaDiameterCm) / 100000;
const annualKm = (52 * pizzasPerWeek * pizzaDiameterCm) / 100000;

const napoliDistanceKm = 800;
const yearsToNapoli = Math.ceil((napoliDistanceKm - totalKm) / annualKm);
const etaNapoli = currentYear + Math.max(0, yearsToNapoli);
const trackMaxKm = 900;

// --- Driver models ---
const familyEntries = [
  { name: 'Michele', year: 1994 + 4 },
  { name: 'Luca', year: 1995 + 4 },
  { name: 'Alessandro', year: 1998 + 4 },
  { name: 'Giacomo', year: 2004 + 4 },
  { name: 'Chiara', year: 2007 + 4 },
];

function weeksBetween(from: Date, to: Date) {
  return Math.max(0, Math.floor((to.getTime() - from.getTime()) / (1000 * 60 * 60 * 24 * 7)));
}

function computeBrunoModel(nowDate: Date) {
  const perWeek = 5;
  const weeks = weeksBetween(new Date(startYear, 0, 1), nowDate);
  const pizzas = weeks * perWeek;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeek * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeek, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

function computeFamilyModel(nowDate: Date) {
  let pizzas = 0;
  let last = new Date(startYear, 0, 1);
  let people = 3;
  const perPerson = 3;
  const sorted = [...familyEntries].sort((a, b) => a.year - b.year);

  for (const e of sorted) {
    const eventDate = new Date(e.year, 0, 1);
    if (eventDate > nowDate) break;
    pizzas += weeksBetween(last, eventDate) * people * perPerson;
    people += 1;
    last = eventDate;
  }

  pizzas += weeksBetween(last, nowDate) * people * perPerson;
  const perWeekNow = people * perPerson;
  const km = (pizzas * pizzaDiameterCm) / 100000;
  const annual = (52 * perWeekNow * pizzaDiameterCm) / 100000;
  const yearsToNap = Math.ceil((napoliDistanceKm - km) / annual);
  return { pizzasPerWeek: perWeekNow, pizzasDelivered: pizzas, totalKm: km, annualKm: annual, etaNapoli: currentYear + Math.max(0, yearsToNap) };
}

const brunoModel = computeBrunoModel(now);
const familyModel = computeFamilyModel(now);

const milestones = [
  { km: 0, label: 'La Penzana (Orezzo)', preview: 'Il forno si accende e il filo d’oro parte dal borgo.', body: 'Dove tutto è iniziato: mani infarinate, brace viva, profumo di casa.', icon: '🏠', year: 1989, fun: 'Pizza numero uno: forse storta. Sicuramente memorabile.' },
  { km: 3, label: 'Gazzaniga', preview: 'Il profumo arriva già in paese.', body: 'Tre chilometri di pizza messi in fila: abbastanza per farsi notare in valle.', icon: '⛰️', year: Math.round(startYear + 3 / annualKm), fun: 'Qui la domanda è una sola: ne portate ancora?' },
  { km: 12, label: 'Bergamo — Città Alta', preview: 'Le mura si lasciano avvicinare, impasto dopo impasto.', body: 'Il filo raggiunge la città alta e si arrampica con calma tra pietra e farina.', icon: '🏰', year: Math.round(startYear + 12 / annualKm), fun: 'Una rotonda di pizza in Piazza Vecchia? Quasi.' },
  { km: 42.2, label: 'La Maratona della Pizza', preview: 'Quarantadue chilometri di corsa lenta, ma con più lievitazione.', body: 'Una maratona simbolica fatta di impasti stesi e serate che finiscono tardi.', icon: '🏃', year: Math.round(startYear + 42.2 / annualKm), fun: 'Niente scarpe tecniche: solo pala, forno e costanza.' },
  { km: 60, label: 'Milano — Il Duomo', preview: 'La linea arriva in città e si fa vedere bene.', body: 'Sotto la Madonnina il filo resta semplice: pizza buona, senza sovrastrutture.', icon: '🏛️', year: Math.round(startYear + 60 / annualKm), fun: 'A Milano chiedono se è gourmet. A Orezzo basta che sia buonissima.' },
  { km: 130, label: 'Piacenza', preview: 'Si entra in Emilia con rispetto per l’impasto.', body: 'La strada si allunga e il viaggio comincia a parlare diverse cucine.', icon: '🧀', year: Math.round(startYear + 130 / annualKm), fun: 'Tra salumi e pizza, l’intesa è immediata.' },
  { km: 180, label: 'Parma', preview: 'Prosciutto, parmigiano, forno acceso: qui si capisce tutto.', body: 'Il filo d’oro continua senza cambiare accento: artigianale, diretto, sincero.', icon: '🍖', year: Math.round(startYear + 180 / annualKm), fun: 'Verdi scriveva opere. Noi scriviamo serate riuscite.' },
  { km: 260, label: 'Bologna — Le Due Torri', preview: 'La strada si tinge di rosso e il filo si fa ancora più deciso.', body: 'Attraversa il cuore d’Italia tenendo insieme tradizione e fame vera.', icon: '🏗️', year: Math.round(startYear + 260 / annualKm), fun: 'Bologna ha i tortellini. Noi portiamo la Diavola. Pari.' },
  { km: 360, label: 'Firenze — Ponte Vecchio', preview: 'Il viaggio prende eleganza, ma resta concreto.', body: 'Rinascimento e pizza condividono una dote: non stancano mai.', icon: '🎨', year: Math.round(startYear + 360 / annualKm), fun: 'Leonardo avrebbe progettato una macchina per stendere l’impasto.' },
  { km: 430, label: 'Siena — Piazza del Campo', preview: 'Il filo curva tra le contrade e continua a crescere.', body: 'Ogni pizza tiene il ritmo del viaggio: lento, preciso, ostinato.', icon: '🐎', year: Math.round(startYear + 430 / annualKm), fun: 'Il Palio è rapidissimo. La lievitazione no, e va bene così.' },
  { km: 500, label: 'Orvieto', preview: 'Mezzo migliaio di chilometri: qui il filo inizia a stupire davvero.', body: 'A questa altezza il viaggio sembra impossibile solo a chi non conosce la costanza.', icon: '⛪', year: Math.round(startYear + 500 / annualKm), fun: 'Cinque cento chilometri di pizza sono una misura che va rispettata.' },
  { km: 560, label: 'Roma — Il Colosseo', preview: 'Tutti i fili portano a Roma, anche quelli fatti di impasto.', body: 'La capitale osserva, il forno continua, la rotta non cambia.', icon: '🏟️', year: Math.round(startYear + 560 / annualKm), fun: 'Il pubblico alza il pollice: Margherita salva tutti.' },
  { km: 650, label: 'Cassino — Montecassino', preview: 'Più a sud, più il viaggio sa di promessa mantenuta.', body: 'Tra memoria e silenzio il filo d’oro resta acceso e va avanti.', icon: '🕍', year: Math.round(startYear + 650 / annualKm), fun: 'Pane, pizza, pazienza: certe cose stanno sempre bene insieme.' },
  { km: 720, label: 'Caserta — La Reggia', preview: 'La strada si allarga, il filo no: resta essenziale.', body: 'Un palazzo da re e una pizza per tutti: equilibrio perfetto.', icon: '👑', year: Math.round(startYear + 720 / annualKm), fun: 'La Reggia ha mille stanze. A noi basta il forno giusto.' },
  { km: 780, label: 'Aversa', preview: 'L’aria cambia: Napoli ormai si sente vicina.', body: 'Ultima salita emotiva prima della patria simbolica della pizza.', icon: '🔥', year: Math.round(startYear + 780 / annualKm), fun: 'Qui la tensione cresce come l’impasto fatto bene.' },
  { km: 800, label: 'Napoli — Via dei Tribunali', preview: 'Il traguardo appare prima nel profumo, poi nella testa.', body: 'La patria della pizza è lì davanti: Tarcisio ci aveva visto lungo.', icon: '🌋', isTarget: true, year: Math.round(startYear + 800 / annualKm), fun: 'Arrivarci con un filo di pizze è poesia pratica.' },
];
---

<BaseLayout
  title="Pizzometro — Il Filo d'Oro"
  description="Dal 1989 ad oggi: quanta strada farebbero tutte le pizze della Penzana messe in fila? Un viaggio verticale da Orezzo fino a Napoli."
  lang="it"
  pageType="website"
  currentPath={`${base}/pizzometro/`}
>
  <section class="pz-hero" aria-labelledby="pz-heading">
    <div class="pz-hero__inner">
      <span class="pz-hero__kicker">Il Filo d'Oro</span>
      <h1 id="pz-heading" class="pz-hero__title">
        <span class="pz-hero__script">Pizzometro</span>
      </h1>
      <p class="pz-hero__subtitle">
        Dal {startYear}, ogni pizza sfornata aggiunge 33 cm al nostro filo d’oro.<br />
        Tarcisio diceva: <em>"Arriveremo fino a Napoli."</em>
      </p>

      <div class="pz-driver" aria-label="Selettore filometro">
        <span class="pz-driver__label">Chi guida il filometro?</span>
        <div class="pz-driver__controls">
          <button type="button" class="pz-driver__btn is-active" data-mode="bruno" id="driver-btn-bruno">Bruno</button>
          <button type="button" class="pz-driver__btn" data-mode="family" id="driver-btn-family">Famiglia Merelli</button>
          <button type="button" class="pz-driver__info" id="filometro-info-btn" aria-label="Info formula">i</button>
        </div>
        <div class="pz-driver__popup" id="filometro-popup" hidden>
          <button type="button" class="pz-driver__close" id="filometro-popup-close" aria-label="Chiudi">&times;</button>
          <strong>Bruno</strong> — cliente fedele, 5 pizze a settimana dal 1989.<br/>
          <strong>Famiglia Merelli</strong> — 3 persone &times; 3 pizze/settimana, poi +1 persona (e +3 pizze/sett.) per ogni figlio dopo i 4 anni: Michele (1998), Luca (1999), Alessandro (2002), Giacomo (2008), Chiara (2011).
        </div>
      </div>

      <div class="pz-hero__counter" aria-live="polite">
        <span class="pz-hero__number" id="km-counter"
          data-target={brunoModel.totalKm.toFixed(1)}
          data-bruno={brunoModel.totalKm.toFixed(1)}
          data-family={familyModel.totalKm.toFixed(1)}>0,0</span>
        <span class="pz-hero__unit">km percorsi</span>
        <span class="pz-hero__subcount">
          <strong id="pizza-counter"
            data-target={brunoModel.pizzasDelivered}
            data-bruno={brunoModel.pizzasDelivered}
            data-family={familyModel.pizzasDelivered}>{brunoModel.pizzasDelivered.toLocaleString('it-IT')}</strong>
          pizze sfornate in totale
        </span>
      </div>

      <div class="pz-hero__stats">
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">{startYear} &rarr; {currentYear}</span>
          <span class="pz-hero__stat-label">anni di tradizione</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value"><span id="stat-annual"
            data-bruno={brunoModel.annualKm.toFixed(1)}
            data-family={familyModel.annualKm.toFixed(1)}>{brunoModel.annualKm.toFixed(1).replace('.', ',')}</span> km</span>
          <span class="pz-hero__stat-label">ogni anno</span>
        </div>
        <div class="pz-hero__stat">
          <span class="pz-hero__stat-value">33 cm</span>
          <span class="pz-hero__stat-label">per ogni pizza</span>
        </div>
      </div>

      <div class="pz-hero__scroll-hint" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        <span>Scorri per viaggiare</span>
      </div>
    </div>
  </section>

  <section class="pz-journey" aria-label="Viaggio simbolico da Orezzo a Napoli">
    <div class="pz-journey__container">
      <div class="pz-journey__timeline" id="journey-timeline">
        <div class="pz-journey__rail">
          <div class="pz-journey__rail-fill" id="journey-line-fill"></div>
        </div>

        <div class="pz-journey__pizza" id="journey-pizza" aria-hidden="true">
          <div class="pz-journey__pizza-body" id="journey-pizza-body">
            <svg viewBox="0 0 56 56" width="56" height="56" xmlns="http://www.w3.org/2000/svg">
              <path d="M28 4 L50 46 Q28 52 6 46 Z" fill="#f6d400" stroke="var(--blue-deep)" stroke-width="2" stroke-linejoin="round"/>
              <path d="M6 46 Q28 52 50 46" fill="#e2be00" stroke="var(--blue-deep)" stroke-width="2"/>
              <circle cx="24" cy="22" r="3.5" fill="#dc2626" opacity="0.9"/>
              <circle cx="33" cy="28" r="3" fill="#dc2626" opacity="0.85"/>
              <circle cx="22" cy="34" r="2.8" fill="#dc2626" opacity="0.85"/>
              <circle cx="28" cy="16" r="2" fill="#16a34a" opacity="0.7"/>
              <circle cx="18" cy="28" r="1.8" fill="#16a34a" opacity="0.7"/>
              <circle cx="34" cy="38" r="2.2" fill="#f5f5dc" opacity="0.6"/>
            </svg>
          </div>
        </div>

        <div class="pz-journey__counter-float" id="journey-counter-float">
          <span class="pz-journey__counter-km" id="journey-km-value">0,0</span>
          <span class="pz-journey__counter-label" id="journey-unit-label">metri percorsi</span>
          <span class="pz-journey__counter-year" id="journey-year-value">{startYear}</span>
        </div>

        {milestones.slice(1).map((milestone, index) => {
          const previous = milestones[index];
          const midpointKm = (previous.km + milestone.km) / 2;
          const pct = (midpointKm / trackMaxKm) * 100;
          return (
            <p class="pz-note" style={`top: ${pct}%;`}>
              {milestone.preview}
            </p>
          );
        })}

        {milestones.map((milestone, index) => {
          const pct = (milestone.km / trackMaxKm) * 100;
          const side = index % 2 === 0 ? 'left' : 'right';
          const flowOffset = index * 5.2;
          return (
            <article
              class={`pz-marker pz-marker--${side} ${milestone.isTarget ? 'pz-marker--target' : ''}`}
              style={`top: calc(${pct}% + ${flowOffset}rem);`}
              data-km={milestone.km}
              data-year={milestone.year}
            >
              <div class="pz-marker__body">
                <div class="pz-marker__dot">
                  <span class="pz-marker__icon">{milestone.icon}</span>
                </div>
                <div class="pz-marker__card">
                  <div class="pz-marker__meta">
                    <span class="pz-marker__km-tag">{milestone.km} km</span>
                    <span class="pz-marker__year-tag">~{milestone.year}</span>
                    {milestone.km <= totalKm ? (
                      <span class="pz-marker__badge pz-marker__badge--reached">raggiunta</span>
                    ) : (
                      <span class="pz-marker__badge pz-marker__badge--future">in vista</span>
                    )}
                  </div>
                  <h2 class="pz-marker__title">{milestone.label}</h2>
                  <p class="pz-marker__bodycopy">{milestone.body}</p>
                  <p class="pz-marker__fun">{milestone.fun}</p>
                </div>
              </div>
            </article>
          );
        })}

        <article
          class="pz-marker pz-marker--left pz-marker--eta"
          style={`top: calc(100% + ${milestones.length * 5.2 + 2}rem);`}
          data-km={trackMaxKm}
          data-year={etaNapoli}
        >
          <div class="pz-marker__body">
            <div class="pz-marker__dot"><span class="pz-marker__icon">🎯</span></div>
            <div class="pz-marker__card">
              <div class="pz-marker__meta">
                <span class="pz-marker__km-tag">stima arrivo</span>
                <span class="pz-marker__year-tag">~<span id="eta-year"
                  data-bruno={brunoModel.etaNapoli}
                  data-family={familyModel.etaNapoli}>{etaNapoli}</span></span>
              </div>
              <h2 class="pz-marker__title">Napoli — Anno <span id="eta-title-year">{etaNapoli}</span></h2>
              <p class="pz-marker__bodycopy">
                Mancano <span id="eta-remaining"
                  data-bruno={Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1)}
                  data-family={Math.max(0, (napoliDistanceKm - familyModel.totalKm)).toFixed(1)}>{Math.max(0, (napoliDistanceKm - brunoModel.totalKm)).toFixed(1).replace('.', ',')}</span> km. Ogni pizza accorcia il viaggio di 33 cm.
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <div class="pz-toast" id="pz-toast" role="alert" aria-live="assertive" hidden>
    <span class="pz-toast__icon">🍕</span>
    <span class="pz-toast__text" id="pz-toast-text"></span>
  </div>

  <style>
    .pz-hero { min-height: 100svh; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--bg); color: var(--text); position: relative; overflow: clip; text-align: center; }
    .pz-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 18%, rgba(242, 123, 167, 0.24), transparent 48%), radial-gradient(circle at 82% 82%, rgba(194, 24, 79, 0.14), transparent 42%); pointer-events: none; }
    .pz-hero__inner { position: relative; z-index: 1; max-width: 820px; padding: 2rem clamp(1.25rem, 5vw, 3rem); }
    .pz-hero__kicker { display: inline-block; margin-bottom: 1rem; font-family: var(--font-subline); font-size: 0.78rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--blue-mid); }
    .pz-hero__title { margin-bottom: 1.5rem; color: var(--blue-deep); }
    .pz-hero__script { font-family: var(--font-script); font-size: clamp(3.7rem, 10vw, 7.2rem); line-height: 0.95; color: var(--blue-deep); }
    .pz-hero__subtitle { max-width: 580px; margin: 0 auto 2.5rem; color: var(--text-muted); font-size: 1.08rem; line-height: 1.7; }
    .pz-hero__subtitle em { color: var(--blue-mid); font-style: normal; font-family: var(--font-display); }
    .pz-hero__counter { display: grid; gap: 0.35rem; justify-items: center; margin-bottom: 2.4rem; }
    .pz-hero__number { font-family: var(--font-display); font-size: clamp(4.2rem, 12vw, 8.4rem); font-weight: 800; line-height: 1; letter-spacing: -0.04em; color: #dc2626; text-shadow: 0 0 60px rgba(220, 38, 38, 0.14); }
    .pz-hero__unit { font-family: var(--font-subline); font-size: 0.88rem; letter-spacing: 0.26em; text-transform: uppercase; color: #dc2626; }
    .pz-hero__subcount { display: inline-flex; align-items: baseline; gap: 0.55rem; padding: 0.5rem 0.95rem; border: 2px solid rgba(242, 123, 167, 0.55); background: rgba(255, 255, 255, 0.72); color: var(--blue-deep); font-family: var(--font-subline); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; }
    .pz-hero__subcount strong { font-family: var(--font-display); font-size: 1.2rem; color: var(--blue-mid); letter-spacing: 0; }
    .pz-hero__stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin-bottom: 2.8rem; }
    .pz-hero__stat { padding: 1rem; background: rgba(255, 255, 255, 0.68); border: 2px solid rgba(242, 123, 167, 0.35); }
    .pz-hero__stat-value { display: block; font-family: var(--font-display); font-size: 1.25rem; color: var(--blue-deep); }
    .pz-hero__stat-label { display: block; margin-top: 0.15rem; font-family: var(--font-subline); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); }
    .pz-hero__scroll-hint { display: inline-flex; flex-direction: column; align-items: center; gap: 0.45rem; color: var(--blue-light); font-family: var(--font-subline); font-size: 0.76rem; letter-spacing: 0.18em; text-transform: uppercase; animation: pzBounce 2.2s ease-in-out infinite; }
    .pz-hero__scroll-hint svg { stroke: currentColor; }
    @keyframes pzBounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(8px); } }
    .pz-journey { position: relative; padding: clamp(4rem, 8vw, 6rem) 0 clamp(6rem, 10vw, 8rem); background: linear-gradient(180deg, rgba(255, 240, 243, 1) 0%, rgba(255, 245, 247, 1) 34%, rgba(255, 240, 243, 1) 100%); }
    .pz-journey__container { max-width: min(1400px, calc(100vw - 2rem)); margin: 0 auto; padding: 0 clamp(1rem, 4vw, 3rem); }
    .pz-journey__timeline { position: relative; min-height: 21600px; padding-bottom: 24rem; }
    .pz-journey__rail { position: absolute; left: 50%; top: 0; bottom: 0; width: 6px; transform: translateX(-50%); background: rgba(242, 123, 167, 0.24); border-radius: 999px; }
    .pz-journey__rail-fill { position: absolute; inset: 0 0 auto; height: 0%; border-radius: inherit; background: linear-gradient(180deg, var(--blue-light), var(--blue-mid)); }
    .pz-journey__pizza { position: sticky; top: 50vh; left: 50%; width: 64px; height: 64px; margin-left: -32px; z-index: 3; pointer-events: none; }
    .pz-journey__pizza-body { width: 64px; height: 64px; filter: drop-shadow(0 6px 18px rgba(194, 24, 79, 0.28)); transform-origin: center; }
    .pz-journey__counter-float { position: sticky; top: calc(50vh + 76px); left: 50%; transform: translateX(-50%); z-index: 3; display: grid; justify-items: center; gap: 0.18rem; min-width: 170px; padding: 0.6rem 0.85rem; border: 2px solid rgba(194, 24, 79, 0.28); background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
    .pz-journey__counter-km { font-family: var(--font-display); font-size: 1.45rem; line-height: 1; color: var(--blue-mid); }
    .pz-journey__counter-label { font-family: var(--font-subline); font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); }
    .pz-journey__counter-year { font-family: var(--font-display); font-size: 0.88rem; color: var(--blue-deep); }
    .pz-note { position: absolute; left: calc(50% + 1.4rem); max-width: min(30ch, 32vw); padding: 0.5rem 0.8rem; background: rgba(242, 123, 167, 0.14); color: var(--blue-mid); font-family: var(--font-subline); font-size: 0.66rem; letter-spacing: 0.08em; line-height: 1.6; text-transform: uppercase; transform: translateY(-50%) rotate(-1.8deg); z-index: 1; }
    .pz-marker { position: absolute; width: min(42vw, 520px); opacity: 0; transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out); }
    .pz-marker--left { left: calc(50% - min(42vw, 520px) - 3.75rem); transform: translateX(-2rem); }
    .pz-marker--right { left: calc(50% + 3.75rem); transform: translateX(2rem); }
    .pz-marker.is-visible { opacity: 1; transform: translateX(0); }
    .pz-marker__body { display: flex; align-items: flex-start; gap: 1.1rem; }
    .pz-marker--left .pz-marker__body { flex-direction: row-reverse; text-align: right; }
    .pz-marker__dot { width: 48px; height: 48px; flex: none; display: grid; place-items: center; border-radius: 999px; border: 3px solid var(--blue-mid); background: var(--white); box-shadow: 0 0 0 8px rgba(255, 240, 243, 0.95); }
    .pz-marker__icon { font-size: 1.35rem; line-height: 1; }
    .pz-marker__card { width: min(100%, 430px); padding: 1.05rem 1.15rem 1.1rem; background: rgba(255, 255, 255, 0.96); border: 2px solid rgba(194, 24, 79, 0.14); box-shadow: 8px 8px 0 rgba(242, 123, 167, 0.16); }
    .pz-marker__meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.45rem; }
    .pz-marker--left .pz-marker__meta { justify-content: flex-end; }
    .pz-marker__km-tag, .pz-marker__badge { font-family: var(--font-subline); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; }
    .pz-marker__km-tag { color: var(--blue-mid); }
    .pz-marker__year-tag { font-family: var(--font-display); font-size: 0.78rem; color: var(--text-muted); }
    .pz-marker__badge { padding: 0.15rem 0.45rem; border: 1px solid rgba(194, 24, 79, 0.18); background: rgba(242, 123, 167, 0.12); color: var(--blue-mid); }
    .pz-marker__badge--reached { background: rgba(22, 163, 74, 0.12); border-color: rgba(22, 163, 74, 0.18); color: #15803d; }
    .pz-marker__title { margin-bottom: 0.45rem; font-size: clamp(1.2rem, 2vw, 1.55rem); color: var(--blue-deep); }
    .pz-marker__bodycopy { margin-bottom: 0.45rem; font-size: 0.92rem; line-height: 1.65; color: var(--text-muted); }
    .pz-marker__fun { font-family: var(--font-subline); font-size: 0.78rem; line-height: 1.45; letter-spacing: 0.11em; text-transform: uppercase; color: var(--blue-mid); opacity: 0.92; }
    .pz-marker--target .pz-marker__card, .pz-marker--eta .pz-marker__card { border-color: rgba(194, 24, 79, 0.32); background: rgba(255, 248, 250, 0.98); }
    .pz-toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(120%); z-index: var(--z-modal); display: flex; align-items: center; gap: 0.5rem; padding: 0.8rem 1.35rem; border: 2px solid var(--blue-deep); background: var(--blue-mid); color: var(--white); box-shadow: 6px 6px 0 var(--blue-deep); transition: transform 0.45s var(--ease-spring); white-space: nowrap; }
    .pz-toast.is-visible { transform: translateX(-50%) translateY(0); }
    .pz-toast__icon { font-size: 1.25rem; }
    @media (max-width: 1080px) { .pz-marker { width: min(44vw, 460px); } }
    /* Driver toggle */
    .pz-driver { margin: 0 auto 1.5rem; max-width: 680px; text-align: center; }
    .pz-driver__label { display: block; margin-bottom: 0.5rem; font-family: var(--font-subline); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--blue-deep); }
    .pz-driver__controls { display: flex; align-items: center; gap: 0.5rem; justify-content: center; position: relative; }
    .pz-driver__btn { padding: 0.55rem 1.1rem; border: 2px solid rgba(194, 24, 79, 0.25); background: rgba(255, 255, 255, 0.7); font-family: var(--font-subline); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); cursor: pointer; transition: all 0.25s ease; }
    .pz-driver__btn:hover { border-color: var(--blue-mid); color: var(--blue-mid); }
    .pz-driver__btn.is-active { background: var(--blue-mid); border-color: var(--blue-mid); color: var(--white); }
    .pz-driver__info { width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--blue-mid); background: rgba(255, 255, 255, 0.7); color: var(--blue-mid); font-weight: 800; font-size: 0.85rem; cursor: pointer; flex-shrink: 0; }
    .pz-driver__popup { position: absolute; top: 42px; right: 0; max-width: 480px; text-align: left; padding: 0.85rem 1rem; border: 2px solid var(--blue-mid); background: rgba(255, 255, 255, 0.96); color: var(--blue-deep); font-size: 0.82rem; line-height: 1.55; box-shadow: 4px 4px 0 rgba(242, 123, 167, 0.2); z-index: 20; }
    .pz-driver__close { position: absolute; right: 6px; top: 2px; border: 0; background: transparent; color: var(--blue-deep); font-size: 1.15rem; cursor: pointer; }
    @media (max-width: 768px) {
      .pz-journey__timeline { min-height: 14000px; padding-bottom: 16rem; }
      .pz-journey__rail { left: 2rem; transform: none; }
      .pz-journey__pizza { left: 2rem; margin-left: -32px; }
      .pz-journey__counter-float { left: 4.6rem; transform: none; min-width: 148px; }
      .pz-note { left: 4.7rem; max-width: calc(100% - 5.5rem); font-size: 0.62rem; }
      .pz-marker, .pz-marker--left, .pz-marker--right { left: 4.5rem; width: calc(100% - 5.25rem); transform: translateX(1.25rem); }
      .pz-marker.is-visible { transform: translateX(0); }
      .pz-marker__body, .pz-marker--left .pz-marker__body { flex-direction: row; text-align: left; }
      .pz-marker__meta, .pz-marker--left .pz-marker__meta { justify-content: flex-start; }
      .pz-hero__subcount { font-size: 0.7rem; letter-spacing: 0.1em; }
      .pz-hero__stat { padding: 0.65rem 0.5rem; }
      .pz-hero__stat-value { font-size: 1rem; }
      .pz-hero__stat-label { font-size: 0.62rem; }
      .pz-driver__btn { padding: 0.45rem 0.7rem; font-size: 0.68rem; }
      .pz-driver__popup { max-width: calc(100vw - 3rem); left: 0; right: 0; }
    }
    @media (prefers-reduced-motion: reduce) { .pz-hero__scroll-hint { animation: none; } .pz-marker { opacity: 1; transform: none !important; } }
  </style>

  <script is:inline define:vars={{ startYear, annualKm, trackMaxKm }}>
    document.addEventListener('DOMContentLoaded', () => {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const kmCounter = document.getElementById('km-counter');
      const pizzaCounter = document.getElementById('pizza-counter');
      const statAnnual = document.getElementById('stat-annual');
      const etaYear = document.getElementById('eta-year');
      const etaTitleYear = document.getElementById('eta-title-year');
      const etaRemaining = document.getElementById('eta-remaining');
      const formatKm = (value) => Number(value).toFixed(1).replace('.', ',');
      const formatPizzas = (value) => Math.round(value).toLocaleString('it-IT');
      let currentAnnualKm = annualKm;

      const animateNumber = (element, target, duration, formatter) => {
        if (!element) return;
        if (reducedMotion) {
          element.textContent = formatter(target);
          return;
        }
        const start = performance.now();
        const step = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          element.textContent = formatter(target * eased);
          if (progress < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };

      animateNumber(kmCounter, parseFloat(kmCounter?.dataset.target || '0'), 2600, formatKm);
      animateNumber(pizzaCounter, parseFloat(pizzaCounter?.dataset.target || '0'), 2600, formatPizzas);

      // ---- DRIVER TOGGLE ----
      const driverBtns = document.querySelectorAll('.pz-driver__btn');
      const infoBtn = document.getElementById('filometro-info-btn');
      const popup = document.getElementById('filometro-popup');
      const popupClose = document.getElementById('filometro-popup-close');

      function applyMode(mode) {
        if (!kmCounter) return;
        const km = parseFloat(kmCounter.dataset[mode] || kmCounter.dataset.target || '0');
        const pizzas = parseInt(pizzaCounter?.dataset[mode] || '0', 10);
        const annual = parseFloat(statAnnual?.dataset[mode] || '0');
        const eta = parseInt(etaYear?.dataset[mode] || '0', 10);
        const rem = parseFloat(etaRemaining?.dataset[mode] || '0');

        kmCounter.dataset.target = km.toFixed(1);
        kmCounter.textContent = formatKm(km);
        if (pizzaCounter) {
          pizzaCounter.dataset.target = String(pizzas);
          pizzaCounter.textContent = formatPizzas(pizzas);
        }
        if (statAnnual) statAnnual.textContent = formatKm(annual);
        if (etaYear) etaYear.textContent = String(eta);
        if (etaTitleYear) etaTitleYear.textContent = String(eta);
        if (etaRemaining) etaRemaining.textContent = formatKm(rem);
        currentAnnualKm = annual;

        driverBtns.forEach(btn => {
          btn.classList.toggle('is-active', btn.dataset.mode === mode);
        });
      }

      driverBtns.forEach(btn => {
        btn.addEventListener('click', () => applyMode(btn.dataset.mode));
      });

      if (infoBtn && popup) {
        infoBtn.addEventListener('click', () => {
          popup.toggleAttribute('hidden');
        });
      }
      if (popupClose && popup) {
        popupClose.addEventListener('click', () => popup.setAttribute('hidden', ''));
      }

      const markers = Array.from(document.querySelectorAll('.pz-marker'));
      if (reducedMotion || !('IntersectionObserver' in window)) {
        markers.forEach((marker) => marker.classList.add('is-visible'));
      } else {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        markers.forEach((marker) => revealObserver.observe(marker));
      }

      const journeySection = document.querySelector('.pz-journey');
      const railFill = document.getElementById('journey-line-fill');
      const pizzaBody = document.getElementById('journey-pizza-body');
      const journeyKm = document.getElementById('journey-km-value');
      const journeyUnitLabel = document.getElementById('journey-unit-label');
      const journeyYear = document.getElementById('journey-year-value');
      let ticking = false;

      const formatJourneyDistance = (km) => {
        if (km < 1) {
          const roundedMeters = Math.round((km * 1000) / 10) * 10;
          return { value: `${roundedMeters} m`, label: 'metri percorsi' };
        }
        return { value: `${formatKm(km)} km`, label: 'km percorsi' };
      };

      const updateJourney = () => {
        ticking = false;
        if (!journeySection || !railFill || !journeyKm || !journeyYear || !journeyUnitLabel) return;
        const rect = journeySection.getBoundingClientRect();
        const travel = Math.max(rect.height - window.innerHeight, 1);
        const progress = Math.min(Math.max(-rect.top / travel, 0), 1);
        const currentKm = progress * trackMaxKm;
        const distance = formatJourneyDistance(currentKm);
        railFill.style.height = `${progress * 100}%`;
        journeyKm.textContent = distance.value;
        journeyUnitLabel.textContent = distance.label;
        journeyYear.textContent = `${Math.round(startYear + currentKm / currentAnnualKm)}`;
        if (pizzaBody) {
          pizzaBody.style.transform = `rotate(${progress * 1080}deg)`;
        }
      };

      const requestJourneyUpdate = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateJourney);
      };

      updateJourney();
      window.addEventListener('scroll', requestJourneyUpdate, { passive: true });
      window.addEventListener('resize', requestJourneyUpdate);

      const params = new URLSearchParams(window.location.search);
      const addedPizzas = parseInt(params.get('addedPizzas') || '0', 10);
      if (addedPizzas > 0) {
        const toast = document.getElementById('pz-toast');
        const toastText = document.getElementById('pz-toast-text');
        if (toast && toastText) {
          const addedMeters = (addedPizzas * 33 / 100).toFixed(1).replace('.', ',');
          toastText.textContent = `+${addedPizzas} pizze ordinate! Il filo d’oro cresce di ${addedMeters} m`;
          toast.removeAttribute('hidden');
          requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('is-visible'); }); });
          setTimeout(() => {
            toast.classList.remove('is-visible');
            setTimeout(() => {
              toast.setAttribute('hidden', '');
              const storedWaUrl = sessionStorage.getItem('pz_wa_url');
              if (storedWaUrl) {
                sessionStorage.removeItem('pz_wa_url');
                const link = document.createElement('a');
                link.href = storedWaUrl;
                link.target = '_blank';
                link.rel = 'noopener noreferrer';
                link.style.position = 'fixed';
                link.style.opacity = '0';
                document.body.appendChild(link);
                link.click();
                setTimeout(() => link.remove(), 200);
              }
            }, 500);
          }, 4600);
        }
      }
    });
  </script>

</BaseLayout>
