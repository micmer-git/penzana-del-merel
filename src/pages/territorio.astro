---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
const stats = [
  { strong: '~380 m', label: 'altitudine' },
  { strong: '~18 km', label: 'da Bergamo' },
  { strong: 'Valle Seriana', label: 'contesto' },
  { strong: 'SP35', label: 'accesso stradale' },
];
---

<BaseLayout
  title="Il territorio — Orezzo e la Valle Seriana"
  description="Orezzo, Gazzaniga, Valle Seriana: il contesto della Penzana del Merel tra collina, boschi, borghi e cucina bergamasca."
  lang="it"
  currentPath={`${base}/territorio/`}
>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <span class="page-hero__eyebrow">Territorio</span>
      <h1 class="page-hero__title">Orezzo: collina, boschi e una deviazione che vale la sera.</h1>
      <p class="page-hero__lead">Piccolo, tranquillo, affacciato sul Serio: Orezzo è il tipo di posto che si cerca quando si vuole rallentare senza allontanarsi troppo da Bergamo.</p>
      <div class="stat-ribbon">
        {stats.map((item) => (
          <div class="stat-ribbon__item">
            <strong>{item.strong}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container travel-grid" style="max-width:1040px;">
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">Il borgo</span>
        <h3>Un ritmo diverso</h3>
        <p>Orezzo è una frazione di Gazzaniga, sul fianco orografico destro del Serio. Prati, boschi, viste aperte e quella sensazione di uscita dalla città senza dover andare lontano.</p>
      </article>
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">Come arrivare</span>
        <h3>Tra A4 e fondovalle</h3>
        <p>Dalla A4 si esce a Seriate o Nembro e si prosegue verso Gazzaniga–Orezzo. Parcheggio disponibile nelle vicinanze del locale.</p>
        <div class="cta-row">
          <a href="https://www.google.com/maps/dir//Via+alla+Chiesa,+4,+24025+Orezzo+BG" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Apri in Google Maps</a>
        </div>
      </article>
      <article class="travel-card reveal">
        <span class="travel-card__eyebrow">Contesto alpino</span>
        <h3>Valle Seriana</h3>
        <p>Una valle lunga oltre 70 km, con una doppia anima: industriale e naturalistica. Boschi, sentieri, borghi storici e una cucina che unisce montagna e pianura.</p>
      </article>
    </div>
  </section>
</BaseLayout>
