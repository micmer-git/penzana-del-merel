---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WHATSAPP_NUMBER } from '../data/site.js';
const base = '/penzana-del-merel';
const bgImages = [
  `${base}/img/general_pizza_overview.png`,
  `${base}/img/cucina_tipica.png`,
  `${base}/img/team_2020.png`,
  `${base}/img/trattoria_alpina_historical_photo.png`,
];
---

<BaseLayout
  title="La Penzana del Merel — Pizzeria a Orezzo, Valle Seriana"
  description="La Penzana del Merel e la pizzeria di famiglia ad Orezzo (BG) nel cuore della Valle Seriana. Tradizione, forno a legna e genuinita dal 1959."
  lang="it"
  pageType="restaurant"
  currentPath={`${base}/`}
  bodyClass="home-onepager"
>
  <section class="hero hero-full home-hero" aria-labelledby="hero-heading">
    <div
      class="hero-bg hero-bg-slider"
      data-hero-slider
      data-images={JSON.stringify(bgImages)}
      style={`background-image:url('${bgImages[0]}');`}
    ></div>

    <div class="home-floating-card home-floating-card--left" aria-hidden="true">
      <span class="home-floating-card__eyebrow">Dal 1959</span>
      <p>Forno a legna, serate in collina e una storia che sa di famiglia vera.</p>
    </div>

    <div class="home-floating-card home-floating-card--right" aria-hidden="true">
      <span class="home-floating-card__eyebrow">Valle Seriana</span>
      <p>Orezzo, aria fresca d'estate, panorama rustico e un ritmo più lento del solito.</p>
    </div>

    <div class="hero-center-mark" aria-hidden="true">
      <span class="hero-script">La Penzana</span>
      <span class="hero-subline">del Merel</span>
    </div>

    <button class="hero-booking-badge" type="button" id="open-booking-modal" aria-label="Prenota un tavolo su WhatsApp">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="booking-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#booking-circle">• PRENOTA UN TAVOLO • PRENOTA UN TAVOLO •</textPath></text>
      </svg>
      <span class="circle-center-label">WhatsApp</span>
    </button>

    <a class="hero-booking-badge hero-menu-badge" href={`${base}/menu/`} aria-label="Vai alla pagina menu">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="menu-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#menu-circle">• VAI AL MENU • VAI AL MENU • VAI AL MENU •</textPath></text>
      </svg>
      <span class="circle-center-label">Menu</span>
    </a>

    <div class="container hero-home-copy">
      <h1 id="hero-heading" class="hero-title-hidden">La Penzana del Merel</h1>
    </div>

    <div class="home-bottom-panel container">
      <p class="home-bottom-panel__lead">Pizzeria di famiglia nel cuore della Valle Seriana. Un posto da sera lunga, forno acceso, cucina bergamasca e tavoli che sembrano già ricordarti.</p>
      <div class="home-bottom-panel__facts">
        <span>Forno a legna dal 1959</span>
        <span>Orezzo · colline di Bergamo</span>
        <span>Menu + ordini dal tavolo via WhatsApp</span>
      </div>
    </div>
  </section>

  <div class="modal-overlay booking-modal" id="booking-modal" hidden>
    <div class="modal-box booking-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="booking-title">
      <div class="booking-modal__header">
        <div>
          <span class="modal-kicker">Prenotazione</span>
          <h2 id="booking-title">Prenota il tuo tavolo</h2>
          <p>Scrivi i dettagli qui sotto: prepariamo subito il messaggio WhatsApp già pronto da inviare.</p>
        </div>
        <button type="button" class="booking-modal__close" id="close-booking-modal" aria-label="Chiudi prenotazione">×</button>
      </div>

      <div class="booking-modal__meta">
        <span>Risposta rapida via WhatsApp</span>
        <span>Perfetto per cena, pranzo e richieste speciali</span>
      </div>

      <form id="booking-form" class="reservation-form reservation-form--refined">
        <div class="booking-grid">
          <label>
            Nome
            <input type="text" id="booking-name" required />
          </label>
          <label>
            Numero persone
            <input type="number" id="booking-guests" min="1" max="20" required />
          </label>
          <label>
            Data
            <input type="date" id="booking-date" required />
          </label>
          <label>
            Orario
            <input type="time" id="booking-time" required />
          </label>
          <label>
            Telefono
            <input type="tel" id="booking-phone" required />
          </label>
          <label style="grid-column: 1 / -1;">
            Note (opzionale)
            <textarea id="booking-notes" rows="3" placeholder="Es. tavolo all'aperto, seggiolone, richiesta allergeni..."></textarea>
          </label>
        </div>

        <div class="booking-modal__footer">
          <p class="booking-modal__hint">Se preferisci, puoi anche chiamare direttamente il numero fisso del locale: 035 712021.</p>
          <div class="cta-row" style="margin-top:0;">
            <button type="button" class="btn btn-outline" id="close-booking-modal-secondary">Chiudi</button>
            <button type="submit" class="btn btn-wa">Invia su WhatsApp</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ whatsappNumber: WHATSAPP_NUMBER }}>
    const slider = document.querySelector('[data-hero-slider]');
    const rawImages = slider?.getAttribute('data-images');
    const images = rawImages ? JSON.parse(rawImages) : [];
    let index = 0;

    if (slider && images.length > 1) {
      setInterval(() => {
        index = (index + 1) % images.length;
        slider.style.backgroundImage = `url('${images[index]}')`;
      }, 5000);
    }

    const modal = document.getElementById('booking-modal');
    const openBtn = document.getElementById('open-booking-modal');
    const closeBtn = document.getElementById('close-booking-modal');
    const closeBtnSecondary = document.getElementById('close-booking-modal-secondary');
    const form = document.getElementById('booking-form') as HTMLFormElement | null;

    const openModal = () => {
      modal?.removeAttribute('hidden');
      document.body.classList.add('scroll-locked');
    };

    const closeModal = () => {
      modal?.setAttribute('hidden', '');
      document.body.classList.remove('scroll-locked');
    };

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    closeBtnSecondary?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.hasAttribute('hidden')) closeModal();
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('booking-name') as HTMLInputElement).value.trim();
      const guests = (document.getElementById('booking-guests') as HTMLInputElement).value.trim();
      const date = (document.getElementById('booking-date') as HTMLInputElement).value.trim();
      const time = (document.getElementById('booking-time') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('booking-phone') as HTMLInputElement).value.trim();
      const notes = (document.getElementById('booking-notes') as HTMLTextAreaElement).value.trim();

      const lines = [
        'Ciao La Penzana del Merel! Vorrei prenotare un tavolo:',
        `Nome: ${name}`,
        `Persone: ${guests}`,
        `Data: ${date}`,
        `Orario: ${time}`,
        `Telefono: ${phone}`,
      ];

      if (notes) lines.push(`Note: ${notes}`);

      const message = encodeURIComponent(lines.join('
'));
      window.open(`https://wa.me/${whatsappNumber}?text=${message}`, '_blank');
      closeModal();
      form.reset();
    });
  </script>
</BaseLayout>
