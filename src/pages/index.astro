---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WHATSAPP_NUMBER } from '../data/site.js';
const base = '/penzana-del-merel';
const bgImages = [
  `${base}/img/general_pizza_overview.png`,
  `${base}/img/cucina_tipica.png`,
  `${base}/img/team_2020.png`,
  `${base}/img/trattoria_alpina_historical_photo.png`,
];
---

<BaseLayout
  title="La Penzana del Merel — Pizzeria a Orezzo, Valle Seriana"
  description="La Penzana del Merel e la pizzeria di famiglia ad Orezzo (BG) nel cuore della Valle Seriana. Tradizione, forno a legna e genuinita dal 1959."
  lang="it"
  pageType="restaurant"
  currentPath={`${base}/`}
  bodyClass="home-onepager"
>
  <section class="hero hero-full home-hero" aria-labelledby="hero-heading">
    <div
      class="hero-bg hero-bg-slider"
      data-hero-slider
      data-images={JSON.stringify(bgImages)}
      style={`background-image:url('${bgImages[0]}');`}
    ></div>

    <div class="hero-center-mark" aria-hidden="true">
      <span class="hero-script">La Penzana</span>
      <span class="hero-subline">del Merel</span>
    </div>

    <button class="hero-booking-badge" type="button" id="open-booking-modal" aria-label="Prenota un tavolo su WhatsApp">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="booking-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#booking-circle">• PRENOTA UN TAVOLO • PRENOTA UN TAVOLO •</textPath></text>
      </svg>
      <span class="circle-center-label">WhatsApp</span>
    </button>

    <a class="hero-booking-badge hero-menu-badge" href={`${base}/menu/`} aria-label="Vai alla pagina menu">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="menu-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#menu-circle">• VAI AL MENU • VAI AL MENU • VAI AL MENU •</textPath></text>
      </svg>
      <span class="circle-center-label">Menu</span>
    </a>

    <div class="container hero-home-copy">
      <h1 id="hero-heading" class="hero-title-hidden">La Penzana del Merel</h1>
    </div>
  </section>


  <!-- WhatsApp choice modal -->
  <div class="modal-overlay" id="wa-choice-modal" hidden>
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="wa-choice-title">
      <h2 id="wa-choice-title">Come possiamo aiutarti?</h2>
      <p>Scegli cosa vuoi fare e ti portiamo sulla strada giusta.</p>
      <div class="wa-choice-grid">
        <button type="button" class="wa-choice-card" id="wa-choice-booking">
          <span class="wa-choice-icon">📅</span>
          <span class="wa-choice-label">Prenotazione</span>
          <span class="wa-choice-desc">Prenota un tavolo</span>
        </button>
        <button type="button" class="wa-choice-card" id="wa-choice-menu">
          <span class="wa-choice-icon">🍕</span>
          <span class="wa-choice-label">Ordine</span>
          <span class="wa-choice-desc">Ordina dal menu</span>
        </button>
      </div>
      <button type="button" class="wa-choice-close" id="wa-choice-close">Chiudi</button>
    </div>
  </div>

  <!-- Booking form modal -->
  <div class="modal-overlay" id="booking-modal" hidden>
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="booking-title">
      <h2 id="booking-title">Prenota il tuo tavolo</h2>
      <p>Compila i dettagli e ti apriamo subito il messaggio WhatsApp pronto da inviare.</p>

      <form id="booking-form" class="reservation-form">
        <label>
          Nome
          <input type="text" id="booking-name" required />
        </label>
        <label>
          Numero persone
          <input type="number" id="booking-guests" min="1" max="20" required />
        </label>
        <label>
          Data
          <input type="date" id="booking-date" required />
        </label>
        <label>
          Orario
          <input type="time" id="booking-time" required />
        </label>
        <label>
          Telefono
          <input type="tel" id="booking-phone" required />
        </label>
        <label>
          Note (opzionale)
          <textarea id="booking-notes" rows="2" placeholder="Es. tavolo all'aperto, seggiolone..."></textarea>
        </label>

        <div class="modal-actions">
          <button type="button" class="btn btn-outline" id="close-booking-modal">Chiudi</button>
          <button type="submit" class="btn btn-wa">Invia su WhatsApp</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ whatsappNumber: WHATSAPP_NUMBER, base: '/penzana-del-merel' }}>
    // Hero slider
    const slider = document.querySelector('[data-hero-slider]');
    const rawImages = slider?.getAttribute('data-images');
    const images = rawImages ? JSON.parse(rawImages) : [];
    let index = 0;

    if (slider && images.length > 1) {
      setInterval(() => {
        index = (index + 1) % images.length;
        slider.style.backgroundImage = `url('${images[index]}')`;
      }, 5000);
    }

    // Modal helpers
    const lock = () => document.body.classList.add('scroll-locked');
    const unlock = () => document.body.classList.remove('scroll-locked');

    // Choice modal
    const choiceModal = document.getElementById('wa-choice-modal');
    const openBtn = document.getElementById('open-booking-modal');
    const choiceClose = document.getElementById('wa-choice-close');
    const choiceBooking = document.getElementById('wa-choice-booking');
    const choiceMenu = document.getElementById('wa-choice-menu');

    const openChoice = () => { choiceModal?.removeAttribute('hidden'); lock(); };
    const closeChoice = () => { choiceModal?.setAttribute('hidden', ''); unlock(); };

    openBtn?.addEventListener('click', openChoice);
    choiceClose?.addEventListener('click', closeChoice);
    choiceModal?.addEventListener('click', (e) => { if (e.target === choiceModal) closeChoice(); });

    // Choice → booking form
    choiceBooking?.addEventListener('click', () => {
      closeChoice();
      bookingModal?.removeAttribute('hidden');
      lock();
    });

    // Choice → menu page
    choiceMenu?.addEventListener('click', () => {
      closeChoice();
      window.location.href = base + '/menu/';
    });

    // Booking modal
    const bookingModal = document.getElementById('booking-modal');
    const closeBtn = document.getElementById('close-booking-modal');
    const form = document.getElementById('booking-form');

    const closeBooking = () => { bookingModal?.setAttribute('hidden', ''); unlock(); };

    closeBtn?.addEventListener('click', closeBooking);
    bookingModal?.addEventListener('click', (e) => { if (e.target === bookingModal) closeBooking(); });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('booking-name') as HTMLInputElement).value.trim();
      const guests = (document.getElementById('booking-guests') as HTMLInputElement).value.trim();
      const date = (document.getElementById('booking-date') as HTMLInputElement).value.trim();
      const time = (document.getElementById('booking-time') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('booking-phone') as HTMLInputElement).value.trim();
      const notes = (document.getElementById('booking-notes') as HTMLTextAreaElement).value.trim();

      const lines = [
        'Ciao La Penzana del Merel! Vorrei prenotare un tavolo:',
        `Nome: ${name}`,
        `Persone: ${guests}`,
        `Data: ${date}`,
        `Orario: ${time}`,
        `Telefono: ${phone}`,
      ];

      if (notes) lines.push(`Note: ${notes}`);

      const message = encodeURIComponent(lines.join('\n'));
      window.open(`https://wa.me/${whatsappNumber}?text=${message}`, '_blank');
      closeBooking();
      form.reset();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeChoice(); closeBooking(); }
    });
  </script>

</BaseLayout>
