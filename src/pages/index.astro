---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WHATSAPP_NUMBER } from '../data/site.js';
const base = '/penzana-del-merel';
const menuPath = `${base}/menu/`;
const bgImages = [
  `${base}/img/pizza_front_2_example.png`,
  `${base}/img/cucina_tipica.png`,
  `${base}/img/team_2020.png`,
  `${base}/img/trattoria_alpina_historical_photo.png`,
];
---

<BaseLayout
  title="La Penzana del Merel — Pizzeria a Orezzo, Valle Seriana"
  description="La Penzana del Merel è la pizzeria di famiglia ad Orezzo (BG) nel cuore della Valle Seriana. Tradizione, forno a legna e genuinità dal 1959."
  lang="it"
  pageType="restaurant"
  currentPath={`${base}/`}
  bodyClass="home-onepager"
>
  <section class="hero hero-full home-hero" aria-labelledby="hero-heading">
    <div
      class="hero-bg hero-bg-slider"
      data-hero-slider
      data-images={JSON.stringify(bgImages)}
      style={`background-image:url('${bgImages[0]}');`}
    ></div>

    <div class="hero-center-mark" aria-hidden="true">
      <span class="hero-script">La Penzana</span>
      <span class="hero-subline">del Merel</span>
    </div>

    <button class="hero-booking-badge" type="button" id="open-whatsapp-choice" aria-label="Prenota o ordina su WhatsApp">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="booking-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#booking-circle">• PRENOTA O ORDINA • PRENOTA O ORDINA •</textPath></text>
      </svg>
      <span class="circle-center-label">WhatsApp</span>
    </button>

    <a class="hero-booking-badge hero-menu-badge" href={menuPath} aria-label="Vai alla pagina menu">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="menu-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#menu-circle">• VAI AL MENU • VAI AL MENU • VAI AL MENU •</textPath></text>
      </svg>
      <span class="circle-center-label">Menu</span>
    </a>

    <div class="container hero-home-copy">
      <h1 id="hero-heading" class="hero-title-hidden">La Penzana del Merel</h1>
    </div>
  </section>

  <div class="modal-overlay" id="wa-choice-modal" hidden>
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="wa-choice-title">
      <h2 id="wa-choice-title">Come possiamo aiutarti?</h2>
      <p>Scegli se vuoi prenotare oppure ordinare. Ti portiamo subito al passaggio giusto.</p>
      <div class="wa-choice-grid">
        <button type="button" class="wa-choice-card" id="wa-choice-booking">
          <span class="wa-choice-icon">📅</span>
          <span class="wa-choice-label">Prenotazione</span>
          <span class="wa-choice-desc">Apri il messaggio per riservare un tavolo</span>
        </button>
        <button type="button" class="wa-choice-card" id="wa-choice-menu">
          <span class="wa-choice-icon">🍕</span>
          <span class="wa-choice-label">Ordine</span>
          <span class="wa-choice-desc">Vai al menu e componi l'ordine</span>
        </button>
      </div>
      <button type="button" class="wa-choice-close" id="wa-choice-close">Chiudi</button>
    </div>
  </div>

  <div class="modal-overlay" id="booking-modal" hidden>
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="booking-title">
      <h2 id="booking-title">Prenota il tuo tavolo</h2>
      <p>Compila i dettagli e apriamo un messaggio WhatsApp già pronto da inviare.</p>

      <form id="booking-form" class="reservation-form">
        <label>
          Nome
          <input type="text" id="booking-name" autocomplete="name" required />
        </label>
        <label>
          Numero persone
          <input type="number" id="booking-guests" min="1" max="20" inputmode="numeric" required />
        </label>
        <label>
          Data
          <input type="date" id="booking-date" required />
        </label>
        <label>
          Orario
          <input type="time" id="booking-time" required />
        </label>
        <label>
          Telefono
          <input type="tel" id="booking-phone" autocomplete="tel" required />
        </label>
        <label>
          Note (opzionale)
          <textarea id="booking-notes" rows="2" placeholder="Es. tavolo all'aperto, seggiolone..."></textarea>
        </label>

        <div class="modal-actions">
          <button type="button" class="btn btn-outline" id="close-booking-modal">Chiudi</button>
          <button type="submit" class="btn btn-wa">Invia su WhatsApp</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ whatsappNumber: WHATSAPP_NUMBER, menuPath }}>
    const openExternalLink = (url) => {
      const link = document.createElement('a');
      link.href = url;
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
      link.style.position = 'fixed';
      link.style.opacity = '0';
      link.style.pointerEvents = 'none';
      document.body.appendChild(link);
      link.click();
      window.setTimeout(() => link.remove(), 200);
    };

    const slider = document.querySelector('[data-hero-slider]');
    const rawImages = slider?.getAttribute('data-images');
    const images = rawImages ? JSON.parse(rawImages) : [];
    let imageIndex = 0;

    if (slider && images.length > 1) {
      window.setInterval(() => {
        imageIndex = (imageIndex + 1) % images.length;
        slider.style.backgroundImage = `url('${images[imageIndex]}')`;
      }, 5000);
    }

    const lock = () => document.body.classList.add('scroll-locked');
    const unlock = () => document.body.classList.remove('scroll-locked');

    const choiceModal = document.getElementById('wa-choice-modal');
    const bookingModal = document.getElementById('booking-modal');
    const openChoiceButton = document.getElementById('open-whatsapp-choice');
    const closeChoiceButton = document.getElementById('wa-choice-close');
    const bookingChoiceButton = document.getElementById('wa-choice-booking');
    const menuChoiceButton = document.getElementById('wa-choice-menu');
    const closeBookingButton = document.getElementById('close-booking-modal');
    const bookingForm = document.getElementById('booking-form');

    const openChoice = () => {
      choiceModal?.removeAttribute('hidden');
      lock();
    };

    const closeChoice = () => {
      choiceModal?.setAttribute('hidden', '');
      unlock();
    };

    const openBooking = () => {
      bookingModal?.removeAttribute('hidden');
      lock();
      const nameInput = document.getElementById('booking-name');
      if (nameInput instanceof HTMLElement) {
        window.setTimeout(() => nameInput.focus(), 50);
      }
    };

    const closeBooking = () => {
      bookingModal?.setAttribute('hidden', '');
      unlock();
    };

    openChoiceButton?.addEventListener('click', openChoice);
    closeChoiceButton?.addEventListener('click', closeChoice);
    choiceModal?.addEventListener('click', (event) => {
      if (event.target === choiceModal) closeChoice();
    });

    bookingChoiceButton?.addEventListener('click', () => {
      closeChoice();
      openBooking();
    });

    menuChoiceButton?.addEventListener('click', () => {
      closeChoice();
      window.location.href = menuPath;
    });

    closeBookingButton?.addEventListener('click', closeBooking);
    bookingModal?.addEventListener('click', (event) => {
      if (event.target === bookingModal) closeBooking();
    });

    bookingForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      const name = (document.getElementById('booking-name')).value.trim();
      const guests = (document.getElementById('booking-guests')).value.trim();
      const date = (document.getElementById('booking-date')).value.trim();
      const time = (document.getElementById('booking-time')).value.trim();
      const phone = (document.getElementById('booking-phone')).value.trim();
      const notes = (document.getElementById('booking-notes')).value.trim();

      const lines = [
        'Ciao La Penzana del Merel! Vorrei prenotare un tavolo:',
        `Nome: ${name}`,
        `Persone: ${guests}`,
        `Data: ${date}`,
        `Orario: ${time}`,
        `Telefono: ${phone}`,
      ];

      if (notes) {
        lines.push(`Note: ${notes}`);
      }

      const message = encodeURIComponent(lines.join('\n'));
      openExternalLink(`https://wa.me/${whatsappNumber}?text=${message}`);
      closeBooking();
      bookingForm.reset();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeChoice();
      closeBooking();
    });
  </script>

</BaseLayout>
