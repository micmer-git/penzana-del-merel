---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Galleria — La Penzana del Merel"
  description="Galleria fotografica della Penzana del Merel: le pizze, il locale, il territorio. Un posto rustico e genuino nel cuore della Valle Seriana."
  lang="it"
  currentPath={`${base}/galleria/`}
>

  <section class="hero" style="padding-block:clamp(3rem,8vw,5rem);">
    <div class="container">
      <span class="hero-eyebrow">Galleria</span>
      <h1>Le foto</h1>
      <p>Le nostre pizze, il locale, l'ippocastano centenario. Un posto autentico, ogni stagione.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Gallery placeholder — to be replaced with real photos -->
      <div class="gallery-placeholder" role="img" aria-label="Galleria fotografica in arrivo">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="margin:0 auto 1rem; color:var(--stone-light);">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
        <h2 style="color:var(--stone); font-size:1.3rem; margin-bottom:0.5rem;">Foto in arrivo</h2>
        <p style="max-width:400px; margin:0 auto;">
          <!-- TODO: Add real photos from the restaurant — pizzas, interior, outdoor seating, the historic chestnut tree -->
          La galleria fotografica verrà aggiornata presto. Nel frattempo, visita la nostra pagina Facebook per vedere le ultime foto.
        </p>
        <div style="margin-top:1.5rem;">
          <a
            href="https://www.facebook.com/LaPenzanaDelMerel/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-green"
          >Vedi le foto su Facebook</a>
        </div>
      </div>

      <!-- Photo grid skeleton (to populate with real images) -->
      <!--
      TODO: Replace placeholders below with actual <img> tags once photos are available.
      Recommended: 6–12 photos (JPG, WebP), 1200x900px max, placed in /public/gallery/
      -->
      <div class="grid-3" style="margin-top:3rem; opacity:0.3; pointer-events:none;" aria-hidden="true">
        {Array.from({ length: 6 }, (_, i) => (
          <div style="background:var(--stone-xlight); border-radius:var(--radius-lg); aspect-ratio:4/3; display:flex; align-items:center; justify-content:center; color:var(--stone);">
            <span style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase;">Foto {i+1}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
