---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/penzana-del-merel';
---

<BaseLayout
  title="Galleria — La Penzana del Merel"
  description="Galleria fotografica della Penzana del Merel: le pizze, il locale, il territorio. Un posto rustico e genuino nel cuore della Valle Seriana."
  lang="it"
  currentPath={`${base}/galleria/`}
>

  <section class="hero" style="padding-block:clamp(3rem,8vw,5rem);">
    <div class="container">
      <span class="hero-eyebrow">Galleria</span>
      <h1>Le foto</h1>
      <p>Le nostre pizze, il locale, l'ippocastano centenario. Un posto autentico, ogni stagione.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="gallery-grid">

        <figure class="gallery-item gallery-item-wide reveal">
          <img src={`${base}/img/trattoria_alpina_historical_photo.png`} alt="Foto storica della Trattoria Alpina a Orezzo, l'edificio originale con riflesso nell'acqua" loading="lazy" />
          <figcaption>La Trattoria Alpina di Orezzo — l'edificio originale, prima di diventare La Penzana del Merel</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/general_pizza_overview.png`} alt="Due pizze appena sfornate servite al tavolo, staff con maglietta Penzana" loading="lazy" />
          <figcaption>Pizze appena sfornate dal nostro forno a legna</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/cucina_tipica.png`} alt="Scena dalla cucina: cottura in pentoloni di piatti tradizionali bergamaschi" loading="lazy" />
          <figcaption>In cucina — polenta, casoncelli e piatti della tradizione bergamasca</figcaption>
        </figure>

        <figure class="gallery-item gallery-item-wide reveal">
          <img src={`${base}/img/team_2020.png`} alt="Foto di gruppo della famiglia e dello staff con cappellini natalizi" loading="lazy" />
          <figcaption>La famiglia e lo staff — festa di Natale</figcaption>
        </figure>

        <figure class="gallery-item reveal">
          <img src={`${base}/img/la_penzana_logo.jpg`} alt="Logo della Penzana del Merel con forme geometriche blu, turchesi e oro" loading="lazy" />
          <figcaption>Il logo della Penzana del Merel</figcaption>
        </figure>

      </div>

      <div style="margin-top:2.5rem; text-align:center;">
        <a
          href="https://www.facebook.com/LaPenzanaDelMerel/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-green"
        >Altre foto su Facebook</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.gallery-item {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--bg-warm);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s var(--ease-out), transform 0.3s var(--ease-out);
}
.gallery-item:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.gallery-item-wide {
  grid-column: 1 / -1;
}
.gallery-item img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}
.gallery-item-wide img {
  max-height: 420px;
}
.gallery-item figcaption {
  padding: 0.85rem 1rem;
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.4;
}
@media (max-width: 600px) {
  .gallery-grid { grid-template-columns: 1fr; }
  .gallery-item-wide img { max-height: 280px; }
}
</style>
