---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MENU, SECTIONS, COPERTO, SECTION_QUOTES } from '../data/menu.js';
import { WHATSAPP_NUMBER } from '../data/site.js';
const base = '/penzana-del-merel';
const waNumber = WHATSAPP_NUMBER;

// Serialize menu data for client JS (ingredients editing)
const menuDataJSON = JSON.stringify(
  SECTIONS.map(s => ({
    id: s.id,
    categories: s.categories.map(c => ({
      id: c.id,
      items: c.items.map(i => ({
        id: i.id,
        name: i.nameIT,
        price: i.price,
        desc: i.descIT || '',
        ingredients: (i.descIT || '').split(/,\s*| e /).map((x: string) => x.trim()).filter(Boolean),
      })),
    })),
  }))
);
---

<BaseLayout
  title="Menu 2026 — La Penzana del Merel"
  description="Il menu completo della Penzana del Merel: pizze classiche, sfiziose, giocose, focacce, cucina bergamasca, dolci e carta dei vini. Ordina direttamente dal tuo tavolo via WhatsApp."
  lang="it"
  currentPath={`${base}/menu/`}
>

  <!-- Table selector banner -->
  <div id="table-banner" class="table-banner-new">
    <div class="container table-banner-inner">
      <div id="banner-text" class="banner-text">
        <span id="banner-no-table">Seleziona il tuo tavolo per ordinare via WhatsApp</span>
        <span id="banner-has-table" class="banner-hidden">Stai ordinando dal <strong id="table-name-display"></strong></span>
      </div>
      <div class="table-select-wrap">
        <label for="table-select" class="sr-only">Seleziona tavolo</label>
        <select id="table-select" class="table-select-input" aria-label="Seleziona il tuo tavolo">
          <option value="">Tavolo...</option>
          {Array.from({length: 20}, (_, i) => {
            const id = `table-${String(i+1).padStart(2,'0')}`;
            return <option value={id}>Tavolo {String(i+1).padStart(2,'0')}</option>;
          })}
        </select>
      </div>
    </div>
  </div>

  <section class="hero hero-compact">
    <div class="container">
      <span class="hero-eyebrow">Menu 2026</span>
      <h1>Il nostro menu</h1>
      <p class="hero-sub">Pizze al forno a legna, cucina bergamasca, carta dei vini.</p>
    </div>
  </section>

  <!-- Coperto -->
  <div class="coperto-bar">
    Coperto: {COPERTO.toFixed(2).replace('.', ',')} &euro; per persona
  </div>

  <!-- Tabs -->
  <div class="menu-tabs-wrapper">
    <div class="container">
      <div class="menu-tabs" role="tablist" aria-label="Sezioni del menu">
        {SECTIONS.map((section, i) => (
          <button
            role="tab"
            class={`menu-tab ${i === 0 ? 'active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${section.id}`}
            data-section={section.id}
          >
            {section.labelIT}
          </button>
        ))}
      </div>
    </div>
  </div>

  <section class="section" style="padding-top:1.5rem; padding-bottom:6rem;">
    <div class="container" style="max-width:800px;">

      {SECTIONS.map((section, si) => (
        <div
          id={`panel-${section.id}`}
          role="tabpanel"
          class="menu-panel"
          style={si === 0 ? '' : 'display:none;'}
          data-section={section.id}
        >
          {SECTION_QUOTES[section.id] && (
            <blockquote class="pullquote" style="margin-bottom:2rem; font-size:0.95rem;">
              "{SECTION_QUOTES[section.id].text}"
              <span style="display:block; font-size:0.75rem; font-style:normal; color:var(--stone); margin-top:0.25rem;">— {SECTION_QUOTES[section.id].author}</span>
            </blockquote>
          )}

          {section.categories.map(category => (
            <div class="menu-section" id={`cat-${category.id}`}>
              <h2 class="menu-section-title">
                {category.labelIT}
                <span class="label-en">/ {category.labelEN}</span>
              </h2>
              {category.subtitleIT && (
                <p style="font-size:0.8rem; color:var(--text-muted); margin-top:-0.75rem; margin-bottom:1rem; font-style:italic;">{category.subtitleIT}</p>
              )}
              {category.items.map(item => (
                <div class="menu-card" data-item-id={item.id} data-item-name={item.nameIT} data-item-price={item.price} data-item-desc={item.descIT || ''}>
                  <div class="menu-card-main">
                    <div class="menu-card-info">
                      <div class="menu-card-name">{item.nameIT}</div>
                      {(item.descIT || '') !== '' && (
                        <div class="menu-card-desc">{item.descIT}</div>
                      )}
                    </div>
                    <div class="menu-card-right">
                      <div class="menu-card-price">
                        {item.priceRange ? item.priceRange + ' \u20AC' : item.price.toFixed(2).replace('.', ',') + ' \u20AC'}
                      </div>
                      <button class="add-btn" aria-label={`Aggiungi ${item.nameIT}`} data-id={item.id}>
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>
                  <!-- Expand panel (hidden by default) -->
                  <div class="menu-card-expand" style="display:none;">
                    <div class="ingredient-chips"></div>
                    <div class="expand-input-row">
                      <input type="text" class="add-ingredient-input expand-input" placeholder="+ aggiungi ingrediente..." aria-label={`Aggiungi ingrediente a ${item.nameIT}`} />
                    </div>
                    <div class="expand-input-row">
                      <input type="text" class="item-note-input expand-input expand-input-full" placeholder="Note (es. ben cotta, senza lattosio...)" aria-label={`Note per ${item.nameIT}`} />
                    </div>
                    <div class="expand-actions">
                      <div class="qty-row">
                        <button class="qty-btn-new qty-dec" data-id={item.id} aria-label="Rimuovi">&#8722;</button>
                        <span class="qty-val" data-id={item.id}>1</span>
                        <button class="qty-btn-new qty-inc" data-id={item.id} aria-label="Aggiungi">+</button>
                      </div>
                      <button class="confirm-add-btn" data-id={item.id}>Aggiungi al carrello</button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      ))}

      <div style="margin-top:2rem; padding:1rem; background:var(--bg-warm); border-radius:var(--radius); font-size:0.8rem; color:var(--text-muted);">
        <strong>Nota:</strong> I prezzi possono variare stagionalmente. Per allergeni, contattare il personale.
      </div>
    </div>
  </section>

  <!-- Floating cart button -->
  <div id="cart-fab" class="cart-fab" style="display:none;">
    <button id="cart-fab-btn" class="cart-fab-btn" aria-label="Apri carrello">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span id="cart-fab-count" class="cart-fab-count">0</span>
    </button>
  </div>

  <!-- Cart drawer -->
  <div id="cart-overlay" class="cart-overlay"></div>
  <div id="cart-drawer" class="cart-drawer" aria-label="Carrello">
    <div class="cart-drawer-header">
      <h3>Il tuo ordine</h3>
      <button id="cart-close" class="cart-close" aria-label="Chiudi carrello">&times;</button>
    </div>
    <div id="cart-items" class="cart-items">
      <div class="cart-empty">Nessun articolo nel carrello</div>
    </div>
    <div class="cart-footer">
      <div style="margin-bottom:0.5rem;">
        <label for="order-notes-global" style="font-size:0.75rem; color:var(--text-muted); display:block; margin-bottom:0.2rem;">Note generali:</label>
        <textarea id="order-notes-global" rows="2" placeholder="Intolleranze, richieste particolari..." style="width:100%; padding:0.4rem 0.6rem; border:1px solid var(--stone-xlight); border-radius:var(--radius); font-size:0.8rem; resize:none;"></textarea>
      </div>
      <div class="cart-total">
        <span>Totale</span>
        <strong id="cart-total-price">0,00 &euro;</strong>
      </div>
      <button id="cart-send-btn" class="btn btn-wa" style="width:100%; justify-content:center;" disabled>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Invia ordine via WhatsApp
      </button>
    </div>
  </div>

</BaseLayout>

<style>
/* ---- Hero compact (menu page) ---- */
.hero-compact { padding-block: clamp(2.5rem, 6vw, 4rem); }
.hero-sub { margin-bottom: 0.5rem; }

/* ---- Table Banner ---- */
.table-banner-new {
  background: var(--blue-deep);
  color: white;
  padding: 0.65rem 0;
}
.table-banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.banner-text { font-size: 0.9rem; }
.banner-hidden { display: none; }
.table-select-wrap { display: flex; gap: 0.5rem; align-items: center; }
.table-select-input {
  padding: 0.45rem 0.75rem;
  border-radius: var(--radius);
  border: 2px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.1);
  color: white;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  min-height: 44px;
  transition: border-color var(--transition);
}
.table-select-input:hover,
.table-select-input:focus { border-color: rgba(255,255,255,0.5); }
.table-select-input option { color: var(--text); background: var(--white); }

/* ---- Coperto bar ---- */
.coperto-bar {
  background: var(--bg-warm);
  padding: 0.55rem 1rem;
  text-align: center;
  font-size: 0.82rem;
  color: var(--text-muted);
  border-bottom: 1px solid var(--slate-xlight);
  font-weight: 500;
}

/* ---- Menu tabs wrapper ---- */
.menu-tabs-wrapper {
  background: var(--white);
  border-bottom: 1px solid var(--slate-xlight);
  position: sticky;
  top: 56px;
  z-index: var(--z-sticky);
}

/* ---- Menu Card ---- */
.menu-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 1rem 1.15rem;
  margin-bottom: 0.6rem;
  box-shadow: var(--shadow-xs);
  transition: all 0.25s var(--ease-out);
  border: 1px solid var(--slate-xlight);
  border-left: 3px solid transparent;
}
.menu-card:hover {
  box-shadow: var(--shadow-sm);
  border-left-color: var(--blue-xlight);
}
.menu-card.in-cart {
  border-left-color: var(--wa-green);
  background: var(--success-bg);
  border-color: var(--success-border);
}
.menu-card.expanding {
  box-shadow: var(--shadow-md);
  border-left-color: var(--blue-mid);
}
.menu-card-main {
  display: flex;
  align-items: flex-start;
  gap: 0.85rem;
  cursor: pointer;
}
.menu-card-info { flex: 1; min-width: 0; }
.menu-card-name {
  font-weight: 700;
  font-size: 0.97rem;
  color: var(--text);
  line-height: 1.3;
}
.menu-card-desc {
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.45;
  margin-top: 0.2rem;
}
.menu-card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
  flex-shrink: 0;
}
.menu-card-price {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--blue-deep);
  white-space: nowrap;
}

/* Add button */
.add-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 2px solid var(--blue-mid);
  background: transparent;
  color: var(--blue-mid);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s var(--ease-out);
  min-width: 44px;
  min-height: 44px;
}
.add-btn:hover {
  background: var(--blue-mid);
  color: white;
  transform: scale(1.08);
  box-shadow: 0 2px 8px rgba(59,125,216,0.3);
}
.add-btn:active { transform: scale(0.95); }

/* ---- Expand panel ---- */
.menu-card-expand {
  margin-top: 0.85rem;
  padding-top: 0.85rem;
  border-top: 1px solid var(--slate-xlight);
  animation: fadeIn 0.2s var(--ease-out);
}
.ingredient-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.ing-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  font-size: 0.77rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s var(--ease-out);
  border: 1.5px solid var(--slate-xlight);
  background: var(--bg-warm);
  color: var(--text);
  user-select: none;
  min-height: 36px;
}
.ing-chip:hover { border-color: var(--slate-light); }
.ing-chip.removed {
  background: var(--error-bg);
  border-color: var(--error-border);
  color: var(--error);
  text-decoration: line-through;
}
.ing-chip.added {
  background: var(--success-bg);
  border-color: var(--success-border);
  color: var(--success);
}
.ing-chip .chip-x { font-size: 0.92rem; line-height: 1; margin-left: 0.15rem; }

/* Expand inputs */
.expand-input-row {
  margin-top: 0.55rem;
  display: flex;
  gap: 0.5rem;
  align-items: center;
}
.expand-input {
  flex: 1;
  padding: 0.4rem 0.7rem;
  border: 1.5px solid var(--slate-xlight);
  border-radius: var(--radius);
  font-size: 0.82rem;
  font-family: var(--font-body);
  background: var(--white);
  transition: border-color var(--transition);
  min-height: 40px;
}
.expand-input:focus { border-color: var(--blue-mid); }
.expand-input-full { width: 100%; }
.expand-actions {
  margin-top: 0.7rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Qty row */
.qty-row { display: flex; align-items: center; gap: 0.6rem; }
.qty-btn-new {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 2px solid var(--slate-xlight);
  background: var(--white);
  color: var(--text);
  font-size: 1.1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s var(--ease-out);
  min-width: 44px;
  min-height: 44px;
}
.qty-btn-new:hover { border-color: var(--blue-mid); color: var(--blue-mid); }
.qty-val { font-weight: 700; font-size: 1.1rem; min-width: 28px; text-align: center; }

.confirm-add-btn {
  padding: 0.55rem 1.25rem;
  border-radius: var(--radius);
  border: none;
  background: var(--blue-mid);
  color: white;
  font-weight: 700;
  font-size: 0.85rem;
  font-family: var(--font-body);
  cursor: pointer;
  transition: all 0.2s var(--ease-out);
  min-height: 44px;
}
.confirm-add-btn:hover {
  background: var(--blue-deep);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

/* ---- Cart FAB ---- */
.cart-fab {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: var(--z-fab);
}
.cart-fab-btn {
  width: 62px;
  height: 62px;
  border-radius: 50%;
  border: none;
  background: var(--wa-green);
  color: white;
  box-shadow: 0 4px 20px rgba(37,211,102,0.35), 0 0 0 0 rgba(37,211,102,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.25s var(--ease-out);
  position: relative;
  animation: fabPulse 2s infinite;
}
@keyframes fabPulse {
  0%, 100% { box-shadow: 0 4px 20px rgba(37,211,102,0.35), 0 0 0 0 rgba(37,211,102,0.3); }
  50% { box-shadow: 0 4px 20px rgba(37,211,102,0.35), 0 0 0 8px rgba(37,211,102,0); }
}
.cart-fab-btn:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 28px rgba(37,211,102,0.45);
  animation: none;
}
.cart-fab-btn:active { transform: scale(0.95); }
.cart-fab-count {
  position: absolute;
  top: -5px;
  right: -5px;
  background: var(--blue-mid);
  color: white;
  font-size: 0.7rem;
  font-weight: 800;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--white);
  box-shadow: var(--shadow-sm);
}

/* ---- Cart Drawer ---- */
.cart-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.45);
  z-index: var(--z-cart-overlay);
  opacity: 0;
  transition: opacity 0.3s var(--ease-out);
  pointer-events: none;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.cart-overlay.open { opacity: 1; pointer-events: auto; }

.cart-drawer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-cart-drawer);
  background: var(--white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  box-shadow: var(--shadow-xl);
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s var(--ease-out);
  pointer-events: none;
  visibility: hidden;
}
.cart-drawer.open {
  transform: translateY(0);
  pointer-events: auto;
  visibility: visible;
}
.cart-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.15rem 1.5rem 0.65rem;
  border-bottom: 1px solid var(--slate-xlight);
}
.cart-drawer-header h3 { margin: 0; font-size: 1.15rem; }
.cart-close {
  width: 38px;
  height: 38px;
  border: none;
  background: var(--bg-warm);
  border-radius: 50%;
  font-size: 1.4rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  min-width: 44px;
  min-height: 44px;
  transition: all var(--transition);
}
.cart-close:hover { background: var(--slate-xlight); color: var(--text); }
.cart-items {
  flex: 1;
  overflow-y: auto;
  padding: 0.85rem 1.5rem;
  -webkit-overflow-scrolling: touch;
}
.cart-empty {
  text-align: center;
  color: var(--slate);
  padding: 2.5rem 0;
  font-size: 0.9rem;
}
.cart-item {
  display: flex;
  gap: 0.85rem;
  padding: 0.85rem 0;
  border-bottom: 1px solid var(--slate-xlight);
  align-items: flex-start;
}
.cart-item:last-child { border-bottom: none; }
.cart-item-info { flex: 1; min-width: 0; }
.cart-item-name { font-weight: 700; font-size: 0.92rem; }
.cart-item-mods { font-size: 0.77rem; color: var(--text-muted); margin-top: 0.2rem; }
.cart-item-mods .mod-remove { color: var(--error); }
.cart-item-mods .mod-add { color: var(--success); }
.cart-item-note { font-size: 0.75rem; color: var(--blue-mid); font-style: italic; margin-top: 0.15rem; }
.cart-item-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; }
.cart-item-price { font-weight: 700; font-size: 0.92rem; color: var(--blue-deep); white-space: nowrap; }
.cart-item-qty { display: flex; align-items: center; gap: 0.35rem; }
.cart-item-qty button {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 1.5px solid var(--slate-xlight);
  background: var(--white);
  font-size: 0.9rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  min-height: 38px;
  transition: all 0.15s var(--ease-out);
}
.cart-item-qty button:hover { border-color: var(--blue-mid); color: var(--blue-mid); }
.cart-item-qty button.cart-remove-btn { border-color: var(--error-border); color: var(--error); }
.cart-item-qty button.cart-remove-btn:hover { background: var(--error-bg); }
.cart-item-qty span { font-weight: 700; min-width: 20px; text-align: center; font-size: 0.88rem; }
.cart-footer {
  padding: 0.85rem 1.5rem 1.15rem;
  border-top: 1px solid var(--slate-xlight);
  background: var(--bg-warm);
  border-radius: 0 0 0 0;
}
.cart-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.85rem;
  font-size: 1.05rem;
}

@media (min-width: 600px) {
  .cart-drawer { max-width: 460px; left: auto; right: 0; }
}
</style>

<script define:vars={{ waNumber, menuDataJSON }}>
  window.__WA_NUMBER = waNumber;
  window.__MENU_DATA = menuDataJSON;
</script>

<script>
const WHATSAPP_NUMBER = (window as any).__WA_NUMBER || '393487024985';
const MENU_DATA: Array<{id:string, categories:Array<{id:string, items:Array<{id:string, name:string, price:number, desc:string, ingredients:string[]}>}>}> = JSON.parse((window as any).__MENU_DATA || '[]');

// Build lookup
const itemLookup = new Map<string, {name:string, price:number, ingredients:string[]}>();
MENU_DATA.forEach(s => s.categories.forEach(c => c.items.forEach(i => itemLookup.set(i.id, i))));

// ---- State ----
interface CartEntry {
  id: string;
  name: string;
  price: number;
  qty: number;
  removed: string[];     // removed ingredients
  added: string[];       // added ingredients
  note: string;
}

let cart: CartEntry[] = [];
let tableId: string | null = new URLSearchParams(window.location.search).get('table');

// ---- Tab switching ----
document.querySelectorAll('.menu-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const section = (tab as HTMLElement).dataset.section!;
    document.querySelectorAll('.menu-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
    document.querySelectorAll('.menu-panel').forEach(p => { (p as HTMLElement).style.display = (p as HTMLElement).dataset.section === section ? '' : 'none'; });
  });
});

// ---- Table selection ----
const tableSelect = document.getElementById('table-select') as HTMLSelectElement;
const bannerNoTable = document.getElementById('banner-no-table')!;
const bannerHasTable = document.getElementById('banner-has-table')!;
const tableNameDisplay = document.getElementById('table-name-display')!;

function setTable(id: string | null) {
  tableId = id;
  if (id) {
    const label = id.replace('table-', 'Tavolo ');
    bannerNoTable.style.display = 'none';
    bannerHasTable.style.display = '';
    tableNameDisplay.textContent = label;
    tableSelect.value = id;
    // Update URL without reload
    const url = new URL(window.location.href);
    url.searchParams.set('table', id);
    window.history.replaceState({}, '', url.toString());
  } else {
    bannerNoTable.style.display = '';
    bannerHasTable.style.display = 'none';
  }
}

if (tableId) setTable(tableId);
tableSelect.addEventListener('change', () => setTable(tableSelect.value || null));

// ---- Menu card expand ----
document.querySelectorAll('.menu-card').forEach(card => {
  const expandPanel = card.querySelector('.menu-card-expand') as HTMLElement;
  const addBtn = card.querySelector('.add-btn') as HTMLElement;
  const itemId = (card as HTMLElement).dataset.itemId!;
  const itemData = itemLookup.get(itemId);
  let tempQty = 1;
  let tempRemoved: Set<string> = new Set();
  let tempAdded: string[] = [];

  function renderChips() {
    const container = expandPanel.querySelector('.ingredient-chips')!;
    container.innerHTML = '';
    // Original ingredients
    (itemData?.ingredients || []).forEach(ing => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip' + (tempRemoved.has(ing) ? ' removed' : '');
      chip.innerHTML = `${ing} <span class="chip-x">${tempRemoved.has(ing) ? '+' : '\u00D7'}</span>`;
      chip.addEventListener('click', () => {
        if (tempRemoved.has(ing)) tempRemoved.delete(ing);
        else tempRemoved.add(ing);
        renderChips();
      });
      container.appendChild(chip);
    });
    // Added ingredients
    tempAdded.forEach((ing, idx) => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip added';
      chip.innerHTML = `+ ${ing} <span class="chip-x">\u00D7</span>`;
      chip.addEventListener('click', () => {
        tempAdded.splice(idx, 1);
        renderChips();
      });
      container.appendChild(chip);
    });
  }

  function openExpand() {
    // Close all others
    document.querySelectorAll('.menu-card-expand').forEach(p => (p as HTMLElement).style.display = 'none');
    document.querySelectorAll('.menu-card').forEach(c => c.classList.remove('expanding'));
    // Reset temp state
    tempQty = 1;
    tempRemoved = new Set();
    tempAdded = [];
    // Show
    expandPanel.style.display = '';
    card.classList.add('expanding');
    renderChips();
    // Update qty display
    const qtyEl = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
    if (qtyEl) qtyEl.textContent = '1';
    // Clear note
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    if (noteInput) noteInput.value = '';
    // Clear add ingredient input
    const addInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
    if (addInput) addInput.value = '';
    // Scroll into view
    setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
  }

  // Click on add button or card main area
  addBtn?.addEventListener('click', (e) => { e.stopPropagation(); openExpand(); });
  card.querySelector('.menu-card-main')?.addEventListener('click', () => openExpand());

  // Add ingredient input
  const addIngInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
  addIngInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && addIngInput.value.trim()) {
      tempAdded.push(addIngInput.value.trim());
      addIngInput.value = '';
      renderChips();
    }
  });

  // Qty buttons
  expandPanel.querySelector('.qty-dec')?.addEventListener('click', () => {
    if (tempQty > 1) { tempQty--; const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (el) el.textContent = String(tempQty); }
  });
  expandPanel.querySelector('.qty-inc')?.addEventListener('click', () => {
    tempQty++;
    const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
    if (el) el.textContent = String(tempQty);
  });

  // Confirm add to cart
  expandPanel.querySelector('.confirm-add-btn')?.addEventListener('click', () => {
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    const entry: CartEntry = {
      id: itemId + '_' + Date.now(),
      name: itemData?.name || itemId,
      price: itemData?.price || 0,
      qty: tempQty,
      removed: Array.from(tempRemoved),
      added: [...tempAdded],
      note: noteInput?.value?.trim() || '',
    };
    cart.push(entry);
    expandPanel.style.display = 'none';
    card.classList.remove('expanding');
    card.classList.add('in-cart');
    // Brief pulse animation
    card.animate([{transform:'scale(0.98)'},{transform:'scale(1)'}], {duration:200});
    updateCartUI();
  });
});

// ---- Cart UI ----
const cartFab = document.getElementById('cart-fab')!;
const cartFabCount = document.getElementById('cart-fab-count')!;
const cartDrawer = document.getElementById('cart-drawer')!;
const cartOverlay = document.getElementById('cart-overlay')!;
const cartItemsEl = document.getElementById('cart-items')!;
const cartTotalPrice = document.getElementById('cart-total-price')!;
const cartSendBtn = document.getElementById('cart-send-btn') as HTMLButtonElement;

function formatPrice(n: number): string { return n.toFixed(2).replace('.', ',') + ' \u20AC'; }

function totalQty(): number { return cart.reduce((s, e) => s + e.qty, 0); }
function totalPrice(): number { return cart.reduce((s, e) => s + e.price * e.qty, 0); }

function updateCartUI() {
  const count = totalQty();
  // FAB
  if (count > 0) { cartFab.style.display = ''; cartFabCount.textContent = String(count); }
  else { cartFab.style.display = 'none'; }
  // Drawer items
  if (cart.length === 0) {
    cartItemsEl.innerHTML = '<div class="cart-empty">Nessun articolo nel carrello</div>';
  } else {
    cartItemsEl.innerHTML = cart.map((entry, idx) => {
      let modsHtml = '';
      if (entry.removed.length) modsHtml += entry.removed.map(r => `<span class="mod-remove">senza ${r}</span>`).join(', ');
      if (entry.added.length) modsHtml += (modsHtml ? ', ' : '') + entry.added.map(a => `<span class="mod-add">+ ${a}</span>`).join(', ');
      return `<div class="cart-item" data-idx="${idx}">
        <div class="cart-item-info">
          <div class="cart-item-name">${entry.name}</div>
          ${modsHtml ? `<div class="cart-item-mods">${modsHtml}</div>` : ''}
          ${entry.note ? `<div class="cart-item-note">"${entry.note}"</div>` : ''}
        </div>
        <div class="cart-item-actions">
          <div class="cart-item-price">${formatPrice(entry.price * entry.qty)}</div>
          <div class="cart-item-qty">
            <button class="cart-remove-btn" data-idx="${idx}" aria-label="Rimuovi">\u{1F5D1}</button>
            <button data-action="dec" data-idx="${idx}">\u2212</button>
            <span>${entry.qty}</span>
            <button data-action="inc" data-idx="${idx}">+</button>
          </div>
        </div>
      </div>`;
    }).join('');
    // Bind buttons
    cartItemsEl.querySelectorAll('[data-action="dec"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        if (cart[idx].qty > 1) cart[idx].qty--;
        else cart.splice(idx, 1);
        updateCartUI();
      });
    });
    cartItemsEl.querySelectorAll('[data-action="inc"]').forEach(btn => {
      btn.addEventListener('click', () => { cart[parseInt((btn as HTMLElement).dataset.idx!)].qty++; updateCartUI(); });
    });
    cartItemsEl.querySelectorAll('.cart-remove-btn').forEach(btn => {
      btn.addEventListener('click', () => { cart.splice(parseInt((btn as HTMLElement).dataset.idx!), 1); updateCartUI(); });
    });
  }
  cartTotalPrice.textContent = formatPrice(totalPrice());
  cartSendBtn.disabled = cart.length === 0 || !tableId;
  // Update in-cart marks
  document.querySelectorAll('.menu-card').forEach(c => {
    const id = (c as HTMLElement).dataset.itemId!;
    const inCart = cart.some(e => e.id.startsWith(id + '_'));
    c.classList.toggle('in-cart', inCart);
  });
}

// Cart open/close
function openCart() {
  requestAnimationFrame(() => { cartOverlay.classList.add('open'); cartDrawer.classList.add('open'); });
  document.body.style.overflow = 'hidden';
}
function closeCart() {
  cartOverlay.classList.remove('open'); cartDrawer.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('cart-fab-btn')?.addEventListener('click', openCart);
document.getElementById('cart-close')?.addEventListener('click', closeCart);
cartOverlay.addEventListener('click', closeCart);
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCart(); });

// ---- Send order ----
cartSendBtn.addEventListener('click', () => {
  if (!tableId || cart.length === 0) return;
  const label = tableId.replace('table-', 'Tavolo ');
  const ts = new Date().toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' });
  const globalNotes = (document.getElementById('order-notes-global') as HTMLTextAreaElement)?.value?.trim();

  let msg = `*ORDINE \u2014 ${label}*\nData: ${ts}\n\n*Articoli:*\n`;
  cart.forEach(entry => {
    msg += `\u2022 ${entry.name} x${entry.qty} \u2014 ${formatPrice(entry.price * entry.qty)}`;
    const mods: string[] = [];
    if (entry.removed.length) mods.push('SENZA: ' + entry.removed.join(', '));
    if (entry.added.length) mods.push('CON: ' + entry.added.join(', '));
    if (mods.length) msg += `\n  _${mods.join(' | ')}_`;
    if (entry.note) msg += `\n  _Nota: ${entry.note}_`;
    msg += '\n';
  });
  msg += `\n*TOTALE STIMATO: ${formatPrice(totalPrice())}*`;
  if (globalNotes) msg += `\n\n*Note generali:* ${globalNotes}`;

  const waUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
  const a = document.createElement('a');
  a.href = waUrl;
  a.target = '_blank';
  a.rel = 'noopener noreferrer';
  a.click();
});

updateCartUI();
</script>
