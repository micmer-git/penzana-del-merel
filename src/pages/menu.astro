---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MENU, SECTIONS, COPERTO, SECTION_QUOTES } from '../data/menu.js';
import { WHATSAPP_NUMBER } from '../data/site.js';
const base = '/penzana-del-merel';
const waNumber = WHATSAPP_NUMBER;
---

<BaseLayout
  title="Menu 2026 — La Penzana del Merel"
  description="Il menu completo della Penzana del Merel: pizze classiche, sfiziose, giocose, focacce, cucina bergamasca, dolci e carta dei vini. Ordina direttamente dal tuo tavolo via WhatsApp."
  lang="it"
  currentPath={`${base}/menu/`}
>

  <!-- Table banner (shown only when ?table= is present) -->
  <div id="table-banner" class="table-banner" hidden aria-live="polite">
    Stai ordinando dal <strong id="table-name-banner">tavolo</strong>. Aggiungi gli articoli e premi "Invia ordine".
  </div>

  <section class="hero" style="padding-block:clamp(2.5rem,6vw,4rem);">
    <div class="container">
      <span class="hero-eyebrow">Menu 2026</span>
      <h1>Il nostro menu</h1>
      <p>Pizze al forno a legna, cucina bergamasca, carta dei vini. Ingredienti selezionati, tradizione dal 1959.</p>
    </div>
  </section>

  <!-- Coperto note -->
  <div style="background:var(--bg-warm); padding:0.6rem 1rem; text-align:center; font-size:0.85rem; color:var(--text-muted); border-bottom:1px solid var(--stone-xlight);">
    Coperto: {COPERTO.toFixed(2).replace('.', ',')} &euro; per persona
  </div>

  <!-- Section tabs -->
  <div class="menu-tabs-wrapper" style="background:var(--white); border-bottom:1px solid var(--stone-xlight); position:sticky; top:56px; z-index:50;">
    <div class="container">
      <div class="menu-tabs" role="tablist" aria-label="Sezioni del menu">
        {SECTIONS.map((section, i) => (
          <button
            role="tab"
            class={`menu-tab ${i === 0 ? 'active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${section.id}`}
            data-section={section.id}
          >
            {section.labelIT}
          </button>
        ))}
      </div>
    </div>
  </div>

  <section class="section" style="padding-top:2rem;">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr min(320px,35%); gap:2.5rem; align-items:start;" id="menu-layout">

        <!-- Menu content -->
        <div>
          {SECTIONS.map((section, si) => (
            <div
              id={`panel-${section.id}`}
              role="tabpanel"
              class="menu-panel"
              style={si === 0 ? '' : 'display:none;'}
              data-section={section.id}
            >
              {/* Section quote */}
              {SECTION_QUOTES[section.id] && (
                <blockquote class="pullquote" style="margin-bottom:2rem; font-size:1rem;">
                  "{SECTION_QUOTES[section.id].text}"
                  <span style="display:block; font-size:0.8rem; font-style:normal; color:var(--stone); margin-top:0.3rem;">— {SECTION_QUOTES[section.id].author}</span>
                </blockquote>
              )}

              {section.categories.map(category => (
                <div class="menu-section" id={`cat-${category.id}`}>
                  <h2 class="menu-section-title">
                    {category.labelIT}
                    <span class="label-en">/ {category.labelEN}</span>
                  </h2>
                  {category.subtitleIT && (
                    <p style="font-size:0.83rem; color:var(--text-muted); margin-top:-0.75rem; margin-bottom:1rem; font-style:italic;">{category.subtitleIT}</p>
                  )}
                  {category.items.map(item => (
                    <div class="menu-item" data-item-id={item.id} data-item-price={item.price}>
                      <div class="menu-item-info">
                        <div class="menu-item-name">{item.nameIT}</div>
                        {(item.descIT || '') !== '' && (
                          <div class="menu-item-desc">{item.descIT}</div>
                        )}
                      </div>
                      <div style="display:flex; flex-direction:column; align-items:flex-end; gap:0.5rem; min-width:80px;">
                        <div class="menu-item-price">
                          {item.priceRange ? item.priceRange + ' \u20AC' : item.price.toFixed(2).replace('.', ',') + ' \u20AC'}
                        </div>
                        <div
                          class="qty-control order-only"
                          style="display:none;"
                          aria-label={`Quantita per ${item.nameIT}`}
                        >
                          <button class="qty-btn qty-minus" aria-label="Rimuovi uno" data-id={item.id}>&#8722;</button>
                          <span class="qty-num" id={`qty-${item.id}`}>0</span>
                          <button class="qty-btn qty-plus" aria-label="Aggiungi uno" data-id={item.id} data-name={item.nameIT} data-price={item.price}>+</button>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          ))}

          <div style="margin-top:2rem; padding:1.25rem; background:var(--bg-warm); border-radius:var(--radius); font-size:0.83rem; color:var(--text-muted);">
            <strong>Nota:</strong> I prezzi indicati possono subire variazioni stagionali. Per gli allergeni, contattare il personale.
          </div>
        </div>

        <!-- Order sidebar -->
        <div class="order-sidebar" id="order-sidebar" style="display:none;" aria-label="Carrello ordine">
          <div class="order-widget" role="region" aria-live="polite" aria-label="Riepilogo ordine">
            <h3>Il tuo ordine</h3>
            <div class="table-badge" id="sidebar-table-badge">Tavolo —</div>
            <div class="order-count" id="order-count">Nessun articolo</div>
            <div class="order-total" id="order-total">Totale: 0,00 &euro;</div>

            <div style="margin-bottom:0.75rem;">
              <label for="order-notes" style="font-size:0.8rem; color:rgba(255,255,255,0.7); display:block; margin-bottom:0.3rem;">Note / allergie:</label>
              <textarea
                id="order-notes"
                rows="2"
                style="width:100%; border-radius:var(--radius); border:1px solid rgba(255,255,255,0.2); background:rgba(255,255,255,0.1); color:white; font-size:0.85rem; padding:0.4rem 0.6rem; resize:vertical;"
                placeholder="Intolleranze, preferenze..."
                aria-label="Note per l'ordine"
              ></textarea>
            </div>

            <button id="btn-send-order" class="btn btn-wa" style="width:100%;" disabled aria-disabled="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Invia ordine via WhatsApp
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile sticky order bar -->
  <div id="mobile-order-bar" class="mobile-order-bar" hidden>
    <div class="container" style="display:flex; align-items:center; justify-content:space-between; gap:1rem;">
      <div>
        <span id="mob-order-count" style="font-weight:700;">0 articoli</span>
        <span id="mob-order-total" style="margin-left:0.5rem; color:var(--accent-gold);"></span>
      </div>
      <button id="mob-btn-send" class="btn btn-wa" style="padding:0.5rem 1rem; font-size:0.85rem;" disabled>Invia ordine</button>
    </div>
  </div>

  <!-- Confirm modal -->
  <div class="modal-overlay" id="confirm-modal" hidden role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-box">
      <h2 id="modal-title">Conferma ordine</h2>
      <p>Controlla il tuo ordine prima di inviarlo via WhatsApp. Verra aperta l'app WhatsApp con il messaggio precompilato.</p>
      <div class="modal-order-summary" id="modal-summary" aria-label="Riepilogo ordine da confermare"></div>
      <div class="modal-actions">
        <button id="btn-confirm-wa" class="btn btn-wa">Apri WhatsApp e invia</button>
        <button id="btn-cancel" class="btn btn-outline" style="color:var(--text-muted); border-color:var(--stone-xlight);">Modifica ordine</button>
      </div>
    </div>
  </div>

</BaseLayout>

<script define:vars={{ waNumber }}>
  window.__WA_NUMBER = waNumber;
</script>

<script>
const WHATSAPP_NUMBER = (window as any).__WA_NUMBER || '393487024985';
const BASE = '/penzana-del-merel';

// Tab switching
document.querySelectorAll('.menu-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const section = (tab as HTMLElement).dataset.section!;
    document.querySelectorAll('.menu-tab').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');
    document.querySelectorAll('.menu-panel').forEach(p => {
      (p as HTMLElement).style.display = (p as HTMLElement).dataset.section === section ? '' : 'none';
    });
  });
});

interface OrderItem {
  id: string;
  name: string;
  price: number;
  qty: number;
}

const order: Map<string, OrderItem> = new Map();

function getTableId(): string | null {
  return new URLSearchParams(window.location.search).get('table');
}

function tableLabel(id: string): string {
  return id.replace('table-', 'Tavolo ').replace(/-/g, ' ').toUpperCase();
}

function formatPrice(n: number): string {
  return n.toFixed(2).replace('.', ',') + ' \u20AC';
}

function totalItems(): number {
  let t = 0;
  order.forEach(i => (t += i.qty));
  return t;
}

function totalPrice(): number {
  let t = 0;
  order.forEach(i => (t += i.price * i.qty));
  return t;
}

function updateSidebar(): void {
  const count = totalItems();
  const total = totalPrice();
  const countEl = document.getElementById('order-count');
  const totalEl = document.getElementById('order-total');
  const btn = document.getElementById('btn-send-order') as HTMLButtonElement;

  if (countEl) countEl.textContent = count === 0 ? 'Nessun articolo' : `${count} articolo${count !== 1 ? 'i' : ''}`;
  if (totalEl) totalEl.textContent = `Totale: ${formatPrice(total)}`;
  if (btn) {
    btn.disabled = count === 0;
    btn.setAttribute('aria-disabled', String(count === 0));
  }

  // Mobile bar
  const mobCount = document.getElementById('mob-order-count');
  const mobTotal = document.getElementById('mob-order-total');
  const mobBtn = document.getElementById('mob-btn-send') as HTMLButtonElement;
  if (mobCount) mobCount.textContent = `${count} articol${count !== 1 ? 'i' : 'o'}`;
  if (mobTotal) mobTotal.textContent = formatPrice(total);
  if (mobBtn) mobBtn.disabled = count === 0;
}

function updateQtyDisplay(id: string): void {
  const el = document.getElementById(`qty-${id}`);
  if (el) el.textContent = String(order.get(id)?.qty ?? 0);
}

function buildOrderMessage(tableId: string): string {
  const now = new Date();
  const ts = now.toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' });
  const notes = (document.getElementById('order-notes') as HTMLTextAreaElement)?.value?.trim();

  let msg = `*ORDINE — ${tableLabel(tableId)}*\n`;
  msg += `Data: ${ts}\n\n`;
  msg += `*Articoli:*\n`;
  order.forEach(item => {
    msg += `\u2022 ${item.name} x${item.qty} — ${formatPrice(item.price * item.qty)}\n`;
  });
  msg += `\n*TOTALE STIMATO: ${formatPrice(totalPrice())}*`;
  if (notes) msg += `\n\n*Note:* ${notes}`;
  return msg;
}

function openConfirmModal(tableId: string): void {
  if (!tableId || totalItems() === 0) return;
  const msg = buildOrderMessage(tableId);
  const summaryEl = document.getElementById('modal-summary');
  if (summaryEl) summaryEl.textContent = msg;
  const modal = document.getElementById('confirm-modal');
  if (modal) modal.removeAttribute('hidden');
  document.getElementById('btn-confirm-wa')?.focus();
}

function init(): void {
  const tableId = getTableId();

  if (tableId) {
    const banner = document.getElementById('table-banner');
    const nameBanner = document.getElementById('table-name-banner');
    if (banner) banner.removeAttribute('hidden');
    if (nameBanner) nameBanner.textContent = tableLabel(tableId);

    const sidebar = document.getElementById('order-sidebar');
    if (sidebar) sidebar.style.display = 'block';

    const badge = document.getElementById('sidebar-table-badge');
    if (badge) badge.textContent = tableLabel(tableId);

    document.querySelectorAll('.order-only').forEach(el => {
      (el as HTMLElement).style.display = 'inline-flex';
    });

    // Show mobile order bar
    const mobBar = document.getElementById('mobile-order-bar');
    if (mobBar) mobBar.removeAttribute('hidden');
  }

  // Qty plus buttons
  document.querySelectorAll('.qty-plus').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      const name = (btn as HTMLElement).dataset.name!;
      const price = parseFloat((btn as HTMLElement).dataset.price!);
      const cur = order.get(id) ?? { id, name, price, qty: 0 };
      cur.qty++;
      order.set(id, cur);
      updateQtyDisplay(id);
      updateSidebar();
    });
  });

  // Qty minus buttons
  document.querySelectorAll('.qty-minus').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      const cur = order.get(id);
      if (!cur || cur.qty === 0) return;
      cur.qty--;
      if (cur.qty === 0) order.delete(id);
      else order.set(id, cur);
      updateQtyDisplay(id);
      updateSidebar();
    });
  });

  // Send order buttons
  const sendBtn = document.getElementById('btn-send-order');
  sendBtn?.addEventListener('click', () => openConfirmModal(tableId!));
  document.getElementById('mob-btn-send')?.addEventListener('click', () => openConfirmModal(tableId!));

  // Confirm WA send
  document.getElementById('btn-confirm-wa')?.addEventListener('click', () => {
    if (!tableId) return;
    const msg = buildOrderMessage(tableId);
    const encoded = encodeURIComponent(msg);
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encoded}`, '_blank', 'noopener,noreferrer');
    document.getElementById('confirm-modal')?.setAttribute('hidden', '');
  });

  // Cancel modal
  document.getElementById('btn-cancel')?.addEventListener('click', () => {
    document.getElementById('confirm-modal')?.setAttribute('hidden', '');
  });

  // Close modal on overlay click
  document.getElementById('confirm-modal')?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'confirm-modal') {
      document.getElementById('confirm-modal')?.setAttribute('hidden', '');
    }
  });

  // Escape key closes modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('confirm-modal')?.setAttribute('hidden', '');
    }
  });

  // Responsive: collapse sidebar on mobile
  const mq = window.matchMedia('(max-width: 768px)');
  function handleMQ(e: MediaQueryListEvent | MediaQueryList): void {
    const layout = document.getElementById('menu-layout');
    if (!layout) return;
    if (e.matches) {
      layout.style.gridTemplateColumns = '1fr';
      const sidebar = document.getElementById('order-sidebar');
      if (sidebar && tableId) sidebar.style.display = 'none';
    } else {
      layout.style.gridTemplateColumns = tableId ? '1fr min(320px,35%)' : '1fr';
      const sidebar = document.getElementById('order-sidebar');
      if (sidebar && tableId) sidebar.style.display = 'block';
    }
  }
  mq.addEventListener('change', handleMQ as (e: MediaQueryListEvent) => void);
  handleMQ(mq);

  updateSidebar();
}

document.addEventListener('DOMContentLoaded', init);
</script>
