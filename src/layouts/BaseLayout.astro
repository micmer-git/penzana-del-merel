---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'it' | 'en';
  canonical?: string;
  ogImage?: string;
  pageType?: 'website' | 'restaurant';
  currentPath?: string;
  bodyClass?: string;
  mainClass?: string;
}

const {
  title,
  description,
  lang = 'it',
  canonical,
  ogImage = '/og/default.jpg',
  pageType = 'website',
  currentPath = Astro.url.pathname,
  bodyClass = '',
  mainClass = '',
} = Astro.props;

const siteName = 'La Penzana del Merel';
const siteUrl = 'https://micmer-git.github.io/penzana-del-merel';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const canonicalUrl = canonical ?? `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const itPath = currentPath.replace(/^\/penzana-del-merel\/en(\/.*)?$/, '/penzana-del-merel$1').replace(/\/\/$/, '/') || '/penzana-del-merel/';
const enPath = currentPath.startsWith('/penzana-del-merel/en')
  ? currentPath
  : currentPath.replace(/^\/penzana-del-merel(\/?.*)$/, '/penzana-del-merel/en$1').replace(/\/\/$/, '/');
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="pizzeria Val Seriana, pizza Bergamo, ristorante Orezzo, forno a legna, pizza artigianale, La Penzana del Merel, pizzeria bergamasca, cucina bergamasca, consegna pizza Val Seriana" />
  <meta name="geo.region" content="IT-BG" />
  <meta name="geo.placename" content="Orezzo, Val Seriana, Bergamo" />
  <meta name="geo.position" content="45.806;9.823" />
  <meta name="ICBM" content="45.806, 9.823" />
  <link rel="canonical" href={canonicalUrl} />

  <link rel="alternate" hreflang="it" href={`${siteUrl}${itPath}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}${enPath}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${itPath}`} />

  <meta property="og:type" content={pageType === 'restaurant' ? 'restaurant.restaurant' : 'website'} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
  {lang === 'it' && <meta property="og:locale:alternate" content="en_US" />}
  {lang === 'en' && <meta property="og:locale:alternate" content="it_IT" />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href="/penzana-del-merel/favicon.svg" />

  {pageType === 'restaurant' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "La Penzana del Merel",
      "description": "Pizzeria di famiglia nel cuore della Val Seriana, Bergamo. Forno a legna dal 1959. Pizza artigianale, cucina bergamasca, consegna a domicilio.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Via alla Chiesa, 4",
        "addressLocality": "Orezzo",
        "addressRegion": "BG",
        "postalCode": "24025",
        "addressCountry": "IT"
      },
      "telephone": "+39 035 712021",
      "url": "https://micmer-git.github.io/penzana-del-merel/",
      "menu": "https://micmer-git.github.io/penzana-del-merel/menu/",
      "servesCuisine": ["Pizza", "Italian", "Bergamasca"],
      "priceRange": "€€",
      "acceptsReservations": true,
      "areaServed": [
        { "@type": "City", "name": "Bergamo" },
        { "@type": "Place", "name": "Val Seriana" },
        { "@type": "Place", "name": "Orezzo" },
        { "@type": "Place", "name": "Gazzaniga" }
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 45.806,
        "longitude": 9.823
      },
      "sameAs": ["https://www.facebook.com/LaPenzanaDelMerel/", "https://www.instagram.com/lapenzanadelmerel/"]
    })} />
  )}
</head>
<body class={bodyClass}>
  <a href="#main-content" class="sr-only" style="position:fixed;top:0;left:0;z-index:9999;background:var(--accent-gold);padding:0.5rem 1rem;">Skip to content</a>
  <Header lang={lang} currentPath={currentPath} />
  <main id="main-content" class={mainClass}>
    <slot />
  </main>
  <div class="layout-bottom-marquee">
    <Marquee lang={lang} />
  </div>
  <Footer lang={lang} />

  <script>
    const initRevealObserver = () => {
      const items = document.querySelectorAll('.reveal');
      if (!items.length) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        items.forEach((el) => el.classList.add('visible'));
        return;
      }

      if (!('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('visible'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -8% 0px' });

      items.forEach((el) => observer.observe(el));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initRevealObserver, { once: true });
    } else {
      initRevealObserver();
    }
  </script>
</body>
</html>
